{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gameforge.bot-playtest-scenario.v1.schema.json",
  "title": "GameForge Bot Playtest Scenario V1",
  "type": "object",
  "required": [
    "schema",
    "scenario_id",
    "title",
    "max_runtime_seconds",
    "probes"
  ],
  "properties": {
    "schema": {
      "const": "gameforge.bot_playtest_scenario.v1"
    },
    "scenario_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "max_runtime_seconds": {
      "type": "integer",
      "minimum": 1
    },
    "probes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "probe_id",
          "probe_type",
          "target",
          "expected"
        ],
        "properties": {
          "probe_id": {
            "type": "string",
            "minLength": 1
          },
          "probe_type": {
            "type": "string",
            "enum": [
              "file_exists",
              "json_field_equals"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "expected": {},
          "required": {
            "type": "boolean",
            "default": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
