{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gameforge.local/schemas/interview-session.v1.schema.json",
  "title": "GameForge Interview Session V1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "session_id",
    "created_at_utc",
    "updated_at_utc",
    "concept",
    "genre_weights",
    "mechanics",
    "narrative",
    "style",
    "constraints",
    "uncertainty_decisions"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "session_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "concept": {
      "type": "string"
    },
    "genre_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rts_sim",
        "rpg"
      ],
      "properties": {
        "rts_sim": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "rpg": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "mechanics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "core_loop",
        "progression_systems",
        "failure_states",
        "simulation_depth_notes"
      ],
      "properties": {
        "core_loop": {
          "type": "string"
        },
        "progression_systems": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failure_states": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "simulation_depth_notes": {
          "type": "string"
        }
      }
    },
    "narrative": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "premise",
        "player_fantasy",
        "tone",
        "world_notes",
        "quest_structure"
      ],
      "properties": {
        "premise": {
          "type": "string"
        },
        "player_fantasy": {
          "type": "string"
        },
        "tone": {
          "type": "string"
        },
        "world_notes": {
          "type": "string"
        },
        "quest_structure": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "style": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "preset",
        "art_direction",
        "camera_direction",
        "ui_direction",
        "audio_direction"
      ],
      "properties": {
        "preset": {
          "type": "string"
        },
        "art_direction": {
          "type": "string"
        },
        "camera_direction": {
          "type": "string"
        },
        "ui_direction": {
          "type": "string"
        },
        "audio_direction": {
          "type": "string"
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_platforms",
        "content_rating_target",
        "scope_constraints",
        "technical_constraints",
        "accessibility_constraints"
      ],
      "properties": {
        "target_platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "windows",
              "ubuntu"
            ]
          },
          "minItems": 1
        },
        "content_rating_target": {
          "type": "string"
        },
        "scope_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "technical_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accessibility_constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "uncertainty_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "topic",
          "source_input",
          "options",
          "selected_option_id"
        ],
        "properties": {
          "topic": {
            "type": "string"
          },
          "source_input": {
            "type": "string"
          },
          "options": {
            "type": "array",
            "minItems": 3,
            "maxItems": 3,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "option_id",
                "title",
                "summary",
                "tradeoff"
              ],
              "properties": {
                "option_id": {
                  "type": "string",
                  "minLength": 1
                },
                "title": {
                  "type": "string",
                  "minLength": 1
                },
                "summary": {
                  "type": "string",
                  "minLength": 1
                },
                "tradeoff": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "selected_option_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
