<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:vm="clr-namespace:GameForge.Editor.EditorShell.ViewModels"
        x:Name="RootWindow"
        x:Class="GameForge.Editor.EditorShell.UI.MainWindow"
        Title="{Binding WindowTitle}"
        Width="1460"
        Height="920"
        WindowState="Maximized"
        MinWidth="1024"
        MinHeight="700"
        Background="#1E1E1E"
        mc:Ignorable="d">

  <Window.Styles>
    <!-- Tool rail (Godot-style vertical tool strip) -->
    <Style Selector="Button.ribbon-icon">
      <Setter Property="Background" Value="#353535" />
      <Setter Property="BorderBrush" Value="#484848" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E0E0E0" />
      <Setter Property="Padding" Value="4" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="40" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Button.ribbon-icon:pointerover">
      <Setter Property="Background" Value="#404040" />
      <Setter Property="BorderBrush" Value="#5A5A5A" />
    </Style>
    <Style Selector="Button.ribbon-icon:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.ribbon-compact">
      <Setter Property="Background" Value="#353535" />
      <Setter Property="BorderBrush" Value="#484848" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E0E0E0" />
      <Setter Property="Padding" Value="6,4" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="MinWidth" Value="56" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Button.ribbon-compact:pointerover">
      <Setter Property="Background" Value="#404040" />
      <Setter Property="BorderBrush" Value="#5A5A5A" />
    </Style>
    <Style Selector="Button.ribbon-compact:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <!-- Top Menu Buttons -->
    <Style Selector="Button.menu-link">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="#E0E0E0" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.menu-link:pointerover">
      <Setter Property="Background" Value="#404040" />
    </Style>

    <!-- Main toolbar -->
    <Style Selector="Button.toolbar-action">
      <Setter Property="Background" Value="#3A3A3A" />
      <Setter Property="BorderBrush" Value="#4A4A4A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E8E8E8" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinWidth" Value="72" />
    </Style>
    <Style Selector="Button.toolbar-action:pointerover">
      <Setter Property="Background" Value="#454545" />
      <Setter Property="BorderBrush" Value="#606060" />
    </Style>
    <Style Selector="Button.toolbar-action:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.toolbar-action.primary">
      <Setter Property="Background" Value="#478CBF" />
      <Setter Property="BorderBrush" Value="#5AA0D4" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.toolbar-action.primary:pointerover">
      <Setter Property="Background" Value="#5599CC" />
      <Setter Property="BorderBrush" Value="#6BADCF" />
    </Style>

    <Style Selector="Button.toolbar-action.quiet">
      <Setter Property="Background" Value="#2E2E2E" />
      <Setter Property="Foreground" Value="#BDBDBD" />
      <Setter Property="MinWidth" Value="52" />
      <Setter Property="Padding" Value="8,6" />
    </Style>
    <Style Selector="Button.toolbar-action.quiet:pointerover">
      <Setter Property="Background" Value="#3A3A3A" />
      <Setter Property="BorderBrush" Value="#555555" />
    </Style>

    <!-- Ribbon And Status Surfaces -->
    <Style Selector="Border.ribbon-group">
      <Setter Property="Background" Value="#2A2A2A" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="TextBlock.ribbon-caption">
      <Setter Property="Foreground" Value="#A0A0A0" />
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.status-chip">
      <Setter Property="Background" Value="#2E2E2E" />
      <Setter Property="BorderBrush" Value="#454545" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="8,4" />
    </Style>

    <!-- Panel Shells (flat dock panels) -->
    <Style Selector="Border.panel-shell">
      <Setter Property="Background" Value="{StaticResource PanelShellBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Padding" Value="{StaticResource SpacingLarge}" />
    </Style>

    <Style Selector="Border.subpanel-shell">
      <Setter Property="Background" Value="{StaticResource PanelSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelSurfaceBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Padding" Value="{StaticResource SpacingMedium}" />
    </Style>

    <Style Selector="Grid.panel-header">
      <Setter Property="ColumnSpacing" Value="10" />
    </Style>

    <Style Selector="TextBlock.panel-title">
      <Setter Property="Foreground" Value="#E8E8E8" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.panel-subtitle">
      <Setter Property="Foreground" Value="#A8A8A8" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style Selector="Button.panel-header-action">
      <Setter Property="Background" Value="#353535" />
      <Setter Property="BorderBrush" Value="#4A4A4A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E0E0E0" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinWidth" Value="34" />
    </Style>

    <Style Selector="Button.panel-header-action:pointerover">
      <Setter Property="Background" Value="#404040" />
      <Setter Property="BorderBrush" Value="#606060" />
    </Style>
    <Style Selector="Button.panel-header-action:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.edge-revealer">
      <Setter Property="Width" Value="28" />
      <Setter Property="MinHeight" Value="120" />
      <Setter Property="Padding" Value="4,8" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Background" Value="#2A2A2ACC" />
      <Setter Property="BorderBrush" Value="#505050" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#D0D0D0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Opacity" Value="0.92" />
    </Style>
    <Style Selector="Button.edge-revealer:pointerover">
      <Setter Property="Background" Value="#353535E6" />
      <Setter Property="BorderBrush" Value="#707070" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.edge-revealer:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>
    <Style Selector="TextBlock.edge-revealer-label">
      <Setter Property="FontSize" Value="10" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="11" />
      <Setter Property="MaxWidth" Value="16" />
    </Style>

    <!-- Panel Buttons -->
    <Style Selector="Button.panel-action-button">
      <Setter Property="Background" Value="#3A3A3A" />
      <Setter Property="BorderBrush" Value="#4A4A4A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E8E8E8" />
      <Setter Property="Padding" Value="10,6" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="MinWidth" Value="80" />
    </Style>

    <Style Selector="Button.panel-action-button:pointerover">
      <Setter Property="Background" Value="#454545" />
      <Setter Property="BorderBrush" Value="#606060" />
    </Style>
    <Style Selector="Button.panel-action-button:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.panel-action-button.primary">
      <Setter Property="Background" Value="#478CBF" />
      <Setter Property="BorderBrush" Value="#5AA0D4" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Button.panel-action-button.primary:pointerover">
      <Setter Property="Background" Value="#5599CC" />
      <Setter Property="BorderBrush" Value="#6BADCF" />
    </Style>

    <Style Selector="Button.panel-action-button.empty-state-cta">
      <Setter Property="MinWidth" Value="184" />
      <Setter Property="Padding" Value="16,11" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style Selector="Button.panel-action-button.danger">
      <Setter Property="Background" Value="#3B1A1F" />
      <Setter Property="BorderBrush" Value="#8D4853" />
      <Setter Property="Foreground" Value="#FFE6E8" />
    </Style>

    <Style Selector="Button.panel-action-button.danger:pointerover">
      <Setter Property="Background" Value="#4A2028" />
      <Setter Property="BorderBrush" Value="#B05E6B" />
    </Style>

    <!-- Badges And Chips -->
    <Style Selector="Border.badge">
      <Setter Property="Background" Value="{StaticResource BadgeBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BadgeBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Padding" Value="8,3" />
    </Style>

    <Style Selector="Border.viewport-chip">
      <Setter Property="Background" Value="{StaticResource BadgeBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BadgeBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Padding" Value="8,3" />
    </Style>

    <!-- Toasts -->
    <Style Selector="Border.toast-shell">
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="12,10" />
      <Setter Property="BorderThickness" Value="1.2" />
    </Style>
    <Style Selector="Border.toast-shell.toast-success">
      <Setter Property="Background" Value="{StaticResource ToastSuccessBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ToastSuccessBorderBrush}" />
    </Style>
    <Style Selector="Border.toast-shell.toast-warning">
      <Setter Property="Background" Value="{StaticResource ToastWarningBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ToastWarningBorderBrush}" />
    </Style>
    <Style Selector="Border.toast-shell.toast-error">
      <Setter Property="Background" Value="{StaticResource ToastErrorBackgroundBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource ToastErrorBorderBrush}" />
    </Style>

    <!-- Assets And Suggestion Cards -->
    <Style Selector="Button.suggestion-card">
      <Setter Property="Background" Value="#333333" />
      <Setter Property="BorderBrush" Value="#505050" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#EEEEEE" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="MinHeight" Value="72" />
    </Style>

    <Style Selector="Button.suggestion-card:pointerover">
      <Setter Property="Background" Value="#3D3D3D" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.suggestion-card:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Border.workspace-chip">
      <Setter Property="Background" Value="#2E2E2E" />
      <Setter Property="BorderBrush" Value="#505050" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style Selector="Button.generate-cta">
      <Setter Property="Background" Value="#478CBF" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Padding" Value="14,9" />
      <Setter Property="CornerRadius" Value="3" />
    </Style>
    <Style Selector="Button.generate-cta:pointerover">
      <Setter Property="Background" Value="#5599CC" />
      <Setter Property="BorderBrush" Value="#6BADCF" />
    </Style>
    <Style Selector="Button.generate-cta:focus">
      <Setter Property="BorderBrush" Value="#8BC4E0" />
    </Style>

    <Style Selector="ToggleSwitch.deep-toggle">
      <Setter Property="OnContent" Value="On" />
      <Setter Property="OffContent" Value="Off" />
    </Style>

    <!-- Timeline And History -->
    <Style Selector="Button.history-chip">
      <Setter Property="Background" Value="#2E2E2E" />
      <Setter Property="BorderBrush" Value="#454545" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#D8D8D8" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Button.history-chip:pointerover">
      <Setter Property="Background" Value="#383838" />
      <Setter Property="BorderBrush" Value="#606060" />
    </Style>
    <Style Selector="Button.history-chip:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.timeline-icon">
      <Setter Property="Background" Value="#353535" />
      <Setter Property="BorderBrush" Value="#484848" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E8E8E8" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="FontSize" Value="14" />
    </Style>
    <Style Selector="Button.timeline-icon:pointerover">
      <Setter Property="Background" Value="#404040" />
      <Setter Property="BorderBrush" Value="#606060" />
    </Style>
    <Style Selector="Button.timeline-icon:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.timeline-mode">
      <Setter Property="Background" Value="#2E2E2E" />
      <Setter Property="BorderBrush" Value="#454545" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="Foreground" Value="#B8B8B8" />
      <Setter Property="Padding" Value="8,5" />
      <Setter Property="MinWidth" Value="52" />
    </Style>
    <Style Selector="Button.timeline-mode:pointerover">
      <Setter Property="Background" Value="#383838" />
      <Setter Property="BorderBrush" Value="#606060" />
    </Style>
    <Style Selector="Button.timeline-mode:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <!-- Dock-style panel tabs (readable labels, Godot-like) -->
    <Style Selector="Button.panel-tab">
      <Setter Property="Background" Value="#2E2E2E" />
      <Setter Property="BorderBrush" Value="#454545" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#B0B0B0" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="CornerRadius" Value="2" />
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.panel-tab:pointerover">
      <Setter Property="Background" Value="#383838" />
      <Setter Property="BorderBrush" Value="#606060" />
      <Setter Property="Foreground" Value="#E0E0E0" />
    </Style>
    <Style Selector="Button.panel-tab:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Button.panel-tab.active">
      <Setter Property="Background" Value="#3A3A3A" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="#F0F0F0" />
    </Style>

    <Style Selector="Button.system-action">
      <Setter Property="Background" Value="#3A4A52" />
      <Setter Property="BorderBrush" Value="#556B75" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#EAF3FF" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="10,6" />
    </Style>
    <Style Selector="Button.system-action:pointerover">
      <Setter Property="Background" Value="#455A65" />
      <Setter Property="BorderBrush" Value="#6A828E" />
    </Style>
    <Style Selector="Button.system-action:focus">
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
    </Style>

    <Style Selector="Border.asset-card">
      <Setter Property="Background" Value="#2A2A2A" />
      <Setter Property="BorderBrush" Value="#454545" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.asset-card:pointerover">
      <Setter Property="Background" Value="#333333" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- Bottom dock TabControl (Godot-style strip) -->
    <Style Selector="TabControl.editor-dock-tabs">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="TabControl.editor-dock-tabs TabStrip">
      <Setter Property="Background" Value="#2D2D2D" />
      <Setter Property="BorderBrush" Value="#3D3D3D" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
      <Setter Property="Margin" Value="0,0,0,0" />
    </Style>
    <Style Selector="TabControl.editor-dock-tabs TabItem">
      <Setter Property="Background" Value="#353535" />
      <Setter Property="BorderBrush" Value="#484848" />
      <Setter Property="BorderThickness" Value="1,1,1,0" />
      <Setter Property="Foreground" Value="#C8C8C8" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Padding" Value="14,6" />
      <Setter Property="Margin" Value="0,0,2,0" />
    </Style>
    <Style Selector="TabControl.editor-dock-tabs TabItem:pointerover">
      <Setter Property="Background" Value="#404040" />
    </Style>
    <Style Selector="TabControl.editor-dock-tabs TabItem:selected">
      <Setter Property="Background" Value="#252525" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="#F0F0F0" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <!-- Top menu strip -->
    <Style Selector="Menu">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#E0E0E0" />
    </Style>

    <!-- Hierarchy -->
    <Style Selector="TreeView#HierarchyTree TreeViewItem">
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
    </Style>
    <Style Selector="TreeView.panel-tree">
      <Setter Property="Background" Value="#1E1E1E" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelShellBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6" />
    </Style>
  </Window.Styles>
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding PlayRuntimeCommand}" />
  </Window.KeyBindings>

  <Grid x:Name="RootLayoutGrid" RowDefinitions="Auto,*,4,200,4,140,Auto" Margin="0" RowSpacing="0">
    <Border x:Name="TopRibbonBorder" Grid.Row="0" Background="{StaticResource ChromeToolbarBrush}" BorderBrush="{StaticResource PanelShellBorderBrush}" BorderThickness="0,0,0,1" CornerRadius="0" Padding="0">
      <Grid RowDefinitions="Auto,48" RowSpacing="0">
        <DockPanel Grid.Row="0" Background="{StaticResource ChromeMenuBrush}" LastChildFill="True">
          <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="10,4,10,4">
            <Border Classes="status-chip" Margin="0,0,6,4">
              <TextBlock Text="{Binding ProjectFileStatusLabel}" Foreground="#C8C8C8" FontSize="11" />
            </Border>
            <Border Classes="status-chip" Margin="0,0,6,4">
              <TextBlock Text="{Binding AutosaveStatusLabel}" Foreground="#C8C8C8" FontSize="11" />
            </Border>
            <Border Classes="status-chip" Margin="0,0,6,4" MinWidth="130">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Code Mode" VerticalAlignment="Center" Foreground="#D0D0D0" FontSize="11" />
                <ToggleSwitch Classes="deep-toggle" IsChecked="{Binding IsCodeMode}" VerticalAlignment="Center" />
              </StackPanel>
            </Border>
            <Border Classes="workspace-chip" Margin="0,0,0,4">
              <StackPanel Orientation="Horizontal" Spacing="10">
                <StackPanel Spacing="1">
                  <TextBlock Text="{Binding WorkspaceModeLabel}" Foreground="#E8E8E8" FontSize="11" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding WorkspaceModeDescription}" Foreground="#A0A0A0" FontSize="10" MaxWidth="220" TextTrimming="CharacterEllipsis" />
                </StackPanel>
                <Button Classes="toolbar-action quiet"
                        Content="{Binding WorkspaceModeToggleLabel}"
                        Click="OnToggleWorkspaceModeClick"
                        ToolTip.Tip="Toggle between Creator Mode and Pro Mode layouts." />
              </StackPanel>
            </Border>
          </WrapPanel>

          <Menu Background="Transparent"
                Foreground="#E0E0E0"
                Margin="6,0,0,0"
                VerticalAlignment="Center">
            <MenuItem Header="_File">
              <MenuItem Header="_New Scene    Ctrl+N" Click="OnNewSceneClick" />
              <MenuItem Header="_Open Scene...    Ctrl+O" Click="OnOpenSceneClick" />
              <MenuItem Header="_Save Scene    Ctrl+S" Click="OnSaveSceneClick" IsEnabled="{Binding CanSaveScene}" />
              <MenuItem Header="Save Scene _As...    Ctrl+Shift+S" Click="OnSaveSceneAsClick" IsEnabled="{Binding CanSaveScene}" />
              <Separator />
              <MenuItem Header="Open Project _Folder...    Ctrl+Alt+O" Click="OnOpenProjectFolderClick" />
              <MenuItem Header="_Project Settings...    Ctrl+," Click="OnOpenSettingsClick" />
              <Separator />
              <MenuItem Header="_Export...    Ctrl+E" Click="OnOpenExportChecklistClick" />
              <Separator />
              <MenuItem Header="E_xit" Click="OnExitClick" />
            </MenuItem>
            <MenuItem Header="_Edit">
              <MenuItem Header="_Undo    Ctrl+Z" Command="{Binding UndoCommand}" />
              <MenuItem Header="_Redo    Ctrl+Y" Command="{Binding RedoCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
              <MenuItem Header="Command _Palette…" Click="OnQuickCommandsClick" />
              <Separator />
              <MenuItem Header="Toggle _Left Dock" Click="OnToggleLeftPaneClick" />
              <MenuItem Header="Toggle _Right Dock" Click="OnToggleRightPaneClick" />
              <MenuItem Header="Toggle _Bottom Dock" Click="OnToggleBottomDockClick" />
              <MenuItem Header="Toggle _Timeline" Click="OnToggleTimelineDockClick" />
              <MenuItem Header="Toggle _Activity" Click="OnToggleActivityDockClick" />
              <MenuItem Header="_Focus Mode" Click="OnToggleFocusModeClick" />
            </MenuItem>
            <MenuItem Header="_Tools">
              <MenuItem Header="_AI Interview" Click="OnOpenAiInterviewFloatingClick">
                <MenuItem Header="Dock to _Bottom" Click="OnOpenAiInterviewBottomClick" />
              </MenuItem>
              <MenuItem Header="_Activity Log" Click="OnOpenActivityLogFloatingClick">
                <MenuItem Header="Dock to _Bottom" Click="OnOpenActivityLogBottomClick" />
              </MenuItem>
              <MenuItem Header="Generate _Asset" Click="OnGenerateAssetClick" />
              <MenuItem Header="_Run Orchestrator" Click="OnGenerateFromBriefClick" />
              <MenuItem Header="_Models &amp; LLM" Click="OnOpenModelsAndLlmSettingsClick" />
              <MenuItem Header="_Help Overlay" Command="{Binding ToggleHelpOverlayCommand}" />
            </MenuItem>
            <MenuItem Header="_Help">
              <MenuItem Header="_Settings" Click="OnOpenSettingsClick" />
              <MenuItem Header="_Build Installer" Click="OnBuildInstallerClick" />
            </MenuItem>
          </Menu>
        </DockPanel>

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="10" Margin="10,6,10,6">
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="5">
              <Button Classes="toolbar-action" Content="New Scene" Click="OnNewSceneClick" />
              <Button Classes="toolbar-action" Content="Open Scene" Click="OnOpenSceneClick" />
              <Button Classes="toolbar-action" Content="Save Scene" Click="OnSaveSceneClick" IsEnabled="{Binding CanSaveScene}" />
              <Button Classes="toolbar-action primary" Content="Generate" Click="OnGenerateFromBriefClick" />
              <Button Classes="toolbar-action primary" Content="Generate + Play" Click="OnGenerateAndPlayClick" />
              <Button Classes="toolbar-action primary" Content="▶ Play" Click="OnPlayRuntimeClick" ToolTip.Tip="Run the game runtime (Ctrl+Shift+P)" />
              <Button Classes="toolbar-action" Content="Project Folder" Click="OnOpenProjectFolderClick" />
              <Button Classes="toolbar-action" Content="Settings" Click="OnOpenSettingsClick" />
              <Button Classes="toolbar-action" Content="Export" Click="OnOpenExportChecklistClick" />
            </StackPanel>
          </ScrollViewer>

          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5">
            <Border Classes="status-chip">
              <TextBlock Text="{Binding RuntimePreferencesSummary}" Foreground="#C8C8C8" FontSize="11" />
            </Border>
            <Button Classes="toolbar-action quiet" Content="Left" Click="OnToggleLeftPaneClick" />
            <Button Classes="toolbar-action quiet" Content="Right" Click="OnToggleRightPaneClick" />
            <Button Classes="toolbar-action quiet" Content="Bottom" Click="OnToggleBottomDockClick" />
            <Button Classes="toolbar-action quiet" Content="Focus" Click="OnToggleFocusModeClick" />
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <Grid x:Name="WorkspaceGrid" Grid.Row="1" ColumnDefinitions="52,2.3*,4,4.8*,4,2.8*" RowDefinitions="*" ColumnSpacing="0" Margin="0">
      <Border x:Name="ToolRailBorder" Grid.Column="0" Background="#252525" BorderBrush="{StaticResource PanelShellBorderBrush}" BorderThickness="0,0,1,0" CornerRadius="0" Padding="6,8,6,8">
        <StackPanel Spacing="6" HorizontalAlignment="Center">
          <Button Classes="ribbon-icon" Content="🖱" ToolTip.Tip="Select" />
          <Button Classes="ribbon-icon" Content="✏" ToolTip.Tip="Paint" />
          <Button Classes="ribbon-icon" Content="⬛" ToolTip.Tip="Terrain" />
          <Button Classes="ribbon-icon" Content="💡" ToolTip.Tip="Lighting" />
          <Button Classes="ribbon-icon" Content="🎥" ToolTip.Tip="Camera" />
        </StackPanel>
      </Border>

      <Border x:Name="LeftDockBorder" Grid.Column="1" Classes="panel-shell">
        <Grid x:Name="LeftDockContentGrid" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
          <Grid Classes="panel-header" ColumnDefinitions="*,Auto">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border Classes="badge">
                <TextBlock Text="{Binding ActiveLeftPanelIcon}" FontSize="16" />
              </Border>
              <StackPanel Spacing="1">
                <TextBlock Text="{Binding ActiveLeftPanelTitle}" Classes="panel-title" ToolTip.Tip="Primary left-dock workspace panel." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                  <TextBlock Text="{Binding ActiveLeftPanelSubtitle}" Classes="panel-subtitle" />
                  <TextBlock Text="{Binding HierarchyEntityCountBadge}" Foreground="#7EC0FF" FontSize="11" IsVisible="{Binding IsHierarchyTabActive}" />
                  <TextBlock Text="{Binding HierarchySelectionBadge}" Foreground="#7EC0FF" FontSize="11" IsVisible="{Binding IsHierarchyTabActive}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Classes="panel-header-action" Content="Hide" Click="OnToggleLeftPaneClick" ToolTip.Tip="Hide the left dock." />
          </Grid>

          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4">
            <Button Classes="panel-tab active"
                    Content="Scene"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Hierarchy"
                    IsVisible="{Binding IsHierarchyTabActive}"
                    ToolTip.Tip="Scene tree: entities and parenting." />
            <Button Classes="panel-tab"
                    Content="Scene"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Hierarchy"
                    IsVisible="{Binding IsHierarchyTabInactive}"
                    ToolTip.Tip="Scene tree: entities and parenting." />
            <Button Classes="panel-tab active"
                    Content="FileSystem"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Assets"
                    IsVisible="{Binding IsAssetsTabActive}"
                    ToolTip.Tip="Assets: browse and drag into the viewport." />
            <Button Classes="panel-tab"
                    Content="FileSystem"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Assets"
                    IsVisible="{Binding IsAssetsTabInactive}"
                    ToolTip.Tip="Assets: browse and drag into the viewport." />
            <Button Classes="panel-tab active"
                    Content="History"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="History"
                    IsVisible="{Binding IsHistoryTabActive}"
                    ToolTip.Tip="Local history stub; full timeline is in the bottom panel." />
            <Button Classes="panel-tab"
                    Content="History"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="History"
                    IsVisible="{Binding IsHistoryTabInactive}"
                    ToolTip.Tip="Local history stub; full timeline is in the bottom panel." />
          </StackPanel>

          <Border Grid.Row="2"
                  IsVisible="{Binding IsHierarchyTabActive}"
                  Classes="subpanel-shell"
                  Padding="8,6"
                  Margin="0,0,0,8"
                  VerticalAlignment="Top">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
              <StackPanel Spacing="1">
                <TextBlock Text="🖱 Inspect • 🧲 drag selected entities onto a 🗂 group"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding HierarchyTreeSummary}"
                           Foreground="#6FA8FF"
                           FontSize="10" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="panel-tab"
                      Content="⤢"
                      Command="{Binding ExpandHierarchyCommand}"
                      ToolTip.Tip="Expand all hierarchy nodes." />
              <Button Grid.Column="2"
                      Classes="panel-tab"
                      Content="⤡"
                      Command="{Binding CollapseHierarchyCommand}"
                      ToolTip.Tip="Collapse all hierarchy nodes." />
              <Button Grid.Column="3"
                      Classes="panel-tab"
                      Content="🗂 Create Group"
                      Command="{Binding CreateHierarchyGroupCommand}"
                      ToolTip.Tip="Create Group: add an empty hierarchy group entity for organizing scene objects." />
            </Grid>
          </Border>

          <TreeView Grid.Row="3"
                    Classes="panel-tree"
                    Name="HierarchyTree"
                    ItemsSource="{Binding HierarchyRoots}"
                    SelectedItem="{Binding SelectedHierarchyNode}"
                    IsVisible="{Binding IsHierarchyTabActive}"
                    Padding="8">
            <TreeView.ItemTemplate>
              <TreeDataTemplate DataType="vm:MainWindowViewModel+HierarchyNode" ItemsSource="{Binding Children}">
                <Border Padding="5,4" CornerRadius="5" Tag="{Binding EntityId}" PointerPressed="OnHierarchyNodePointerPressed" DragDrop.AllowDrop="True" DragDrop.Drop="OnHierarchyNodeDrop" DragDrop.DragOver="OnHierarchyNodeDragOver" ToolTip.Tip="Hierarchy item&#x0a;Click to select, drag to re-parent onto groups in scene tree.">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Classes="badge"
                            Padding="4,2"
                            VerticalAlignment="Top">
                      <TextBlock Text="{Binding Icon}" Foreground="#D6E9FF" />
                    </Border>
                    <StackPanel Spacing="1">
                      <TextBlock Text="{Binding Label}" Foreground="#D6E9FF" />
                      <TextBlock Text="{Binding DetailText}"
                                 Foreground="#7FA2CD"
                                 FontSize="10"
                                 IsVisible="{Binding HasDetailText}" />
                    </StackPanel>
                  </StackPanel>
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="✏ Rename"
                                Tag="{Binding EntityId}"
                                Click="OnHierarchyRenameClick" />
                      <MenuItem Header="🗑 Delete"
                                Tag="{Binding EntityId}"
                                Click="OnHierarchyDeleteClick" />
                      <MenuItem Header="🧩 Ungroup / Detach"
                                Tag="{Binding EntityId}"
                                Click="OnHierarchyUngroupClick" />
                    </ContextMenu>
                  </Border.ContextMenu>
                </Border>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>

          <Border Grid.Row="3"
                  IsVisible="{Binding IsHierarchyTabActive}"
                  Classes="subpanel-shell"
                  Padding="8,6"
                  Margin="8"
                  VerticalAlignment="Bottom"
                  DragDrop.AllowDrop="True"
                  DragDrop.Drop="OnHierarchyRootDrop"
                  DragDrop.DragOver="OnHierarchyNodeDragOver"
                  ToolTip.Tip="Drop any hierarchy entity here to move it to root.">
            <TextBlock Text="↥ Drop here to move entity to root"
                       Foreground="#8EA5C7"
                       FontSize="11"
                       HorizontalAlignment="Center" />
          </Border>

          <ContentControl Grid.Row="3"
                          x:Name="AssetsPanelLeftHost"
                          IsVisible="{Binding IsAssetsPanelVisibleInLeftDock}">
          <Border Name="AssetsPanelHost"
                  SizeChanged="OnAssetsPanelSizeChanged"
                  Classes="subpanel-shell">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*" RowSpacing="10">
              <Grid Classes="panel-header" ColumnDefinitions="*,Auto">
                <StackPanel Spacing="2">
                  <TextBlock Classes="panel-title" Text="Assets" ToolTip.Tip="Generated and reviewed graphics assets." />
                  <TextBlock Classes="panel-subtitle" Text="Generate, review, approve, and place approved art assets." />
                </StackPanel>
                <Button Grid.Column="1" Classes="panel-header-action" Content="⋯" ToolTip.Tip="Assets panel placement">
                  <Button.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="Dock Left" Click="OnDockAssetsLeftClick" />
                      <MenuItem Header="Dock Right" Click="OnDockAssetsRightClick" />
                      <MenuItem Header="Dock Bottom" Click="OnDockAssetsBottomClick" />
                      <MenuItem Header="Float" Click="OnFloatAssetsClick" />
                      <MenuItem Header="Hide" Click="OnHideAssetsClick" />
                    </ContextMenu>
                  </Button.ContextMenu>
                </Button>
              </Grid>

              <Border Grid.Row="1" Classes="subpanel-shell" Padding="10,10,10,8">
                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                  <Grid ColumnDefinitions="*,120,Auto" ColumnSpacing="8">
                    <TextBox Watermark="Describe the asset to generate..."
                             Text="{Binding AssetGenerationPrompt}" />
                    <ComboBox Grid.Column="1"
                              SelectedItem="{Binding AssetGenerationType}"
                              ItemsSource="{Binding AssetGenerationTypeOptions}" />
                    <Button Grid.Column="2"
                            Classes="panel-action-button primary"
                            Content="Generate"
                            Click="OnGenerateAssetClick"
                            IsEnabled="{Binding IsAssetGenerationIdle}"
                            ToolTip.Tip="Generate a new asset from the current prompt and type." />
                  </Grid>
                  <Border Grid.Row="1"
                          IsVisible="{Binding IsAssetGenerationInProgress}"
                          Classes="badge"
                          Background="#10213A"
                          BorderBrush="#355B85"
                          Padding="10,7">
                    <Grid ColumnDefinitions="120,*" ColumnSpacing="10">
                      <ProgressBar Width="120" IsIndeterminate="True" Height="6" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="{Binding AssetGenerationStatus}" Foreground="#CFE5FF" VerticalAlignment="Center" TextWrapping="Wrap" />
                    </Grid>
                  </Border>
                </Grid>
              </Border>

              <Grid Grid.Row="2" ColumnDefinitions="*,120,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="6">
                <TextBox Watermark="Search assets" Text="{Binding AssetSearchText}" />
                <ComboBox Grid.Column="1" SelectedItem="{Binding SelectedAssetKindFilter}" ItemsSource="{Binding AssetKindFilterOptions}" />
                <Button Grid.Column="2" Classes="panel-tab active" Content="Grid" Click="OnAssetGridViewClick" IsVisible="{Binding IsAssetGridView}" />
                <Button Grid.Column="2" Classes="panel-tab" Content="Grid" Click="OnAssetGridViewClick" IsVisible="{Binding IsAssetListView}" />
                <Button Grid.Column="3" Classes="panel-tab active" Content="List" Click="OnAssetListViewClick" IsVisible="{Binding IsAssetListView}" />
                <Button Grid.Column="3" Classes="panel-tab" Content="List" Click="OnAssetListViewClick" IsVisible="{Binding IsAssetGridView}" />
                <Button Grid.Column="4" Classes="panel-tab active" Content="Approved" Click="OnApprovedAssetsTabClick" IsVisible="{Binding IsApprovedAssetTabActive}" />
                <Button Grid.Column="4" Classes="panel-tab" Content="Approved" Click="OnApprovedAssetsTabClick" IsVisible="{Binding IsPendingAssetTabActive}" />
                <Button Grid.Column="4" Classes="panel-tab" Content="Approved" Click="OnApprovedAssetsTabClick" IsVisible="{Binding IsRejectedAssetTabActive}" />
                <Button Grid.Column="5" Classes="panel-tab active" Content="Pending" Click="OnPendingAssetsTabClick" IsVisible="{Binding IsPendingAssetTabActive}" />
                <Button Grid.Column="5" Classes="panel-tab" Content="Pending" Click="OnPendingAssetsTabClick" IsVisible="{Binding IsApprovedAssetTabActive}" />
                <Button Grid.Column="5" Classes="panel-tab" Content="Pending" Click="OnPendingAssetsTabClick" IsVisible="{Binding IsRejectedAssetTabActive}" />
                <Button Grid.Column="6" Classes="panel-tab active" Content="Rejected" Click="OnRejectedAssetsTabClick" IsVisible="{Binding IsRejectedAssetTabActive}" />
                <Button Grid.Column="6" Classes="panel-tab" Content="Rejected" Click="OnRejectedAssetsTabClick" IsVisible="{Binding IsApprovedAssetTabActive}" />
                <Button Grid.Column="6" Classes="panel-tab" Content="Rejected" Click="OnRejectedAssetsTabClick" IsVisible="{Binding IsPendingAssetTabActive}" />
              </Grid>

              <TextBlock Grid.Row="3" Text="{Binding VisibleAssetLibrarySummary}" Classes="panel-subtitle" />

              <Grid Grid.Row="4" ColumnDefinitions="2*,1.15*" ColumnSpacing="10" IsVisible="{Binding IsAssetPreviewSideBySide}">
                <Grid RowDefinitions="*" IsVisible="{Binding IsAssetGridView}">
                  <ListBox ItemsSource="{Binding VisibleAssetLibraryItems}"
                           SelectedItem="{Binding SelectedAssetLibraryItem}">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="asset-card" Width="176" Margin="0,0,8,8" Padding="10" CornerRadius="8" ToolTip.Tip="{Binding Prompt}">
                          <Grid RowDefinitions="96,Auto,Auto,Auto" RowSpacing="6">
                            <Border Background="#132A43" BorderBrush="#355B85" BorderThickness="1" CornerRadius="6">
                              <Image Source="{Binding AssetPath}" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Grid.Row="1" Text="{Binding DisplayName}" Foreground="#D6E9FF" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="34" />
                            <TextBlock Grid.Row="2" Text="{Binding PromptSnippet}" Foreground="#9BB8DA" FontSize="10" TextWrapping="Wrap" MaxHeight="32" />
                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                              <Border Classes="badge" Padding="6,2">
                                <TextBlock Text="{Binding StatusBadge}" Foreground="#DDEEFF" FontSize="9" FontWeight="SemiBold" />
                              </Border>
                              <TextBlock Grid.Column="1" Text="{Binding QualityScoreLabel}" Foreground="#6FA8FF" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding VisibleAssetLibraryItems}"
                         SelectedItem="{Binding SelectedAssetLibraryItem}"
                         IsVisible="{Binding IsAssetListView}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="asset-card" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="10">
                          <Border Width="52" Height="52" CornerRadius="6" Background="#132A43" BorderBrush="#355B85" BorderThickness="1">
                            <Image Source="{Binding AssetPath}" Stretch="UniformToFill" />
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PromptSnippet}" Foreground="#9BB8DA" FontSize="10" TextWrapping="Wrap" MaxHeight="28" />
                            <TextBlock Text="{Binding AssetType}" Foreground="#7FA2CD" FontSize="10" />
                          </StackPanel>
                          <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Right">
                            <Border Classes="badge" Padding="6,2" HorizontalAlignment="Right">
                              <TextBlock Text="{Binding StatusBadge}" Foreground="#DDEEFF" FontSize="9" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{Binding QualityScoreLabel}" Foreground="#6FA8FF" FontSize="10" HorizontalAlignment="Right" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Border Grid.Column="1" Classes="subpanel-shell">
                  <Grid RowDefinitions="Auto,180,Auto,*,Auto" RowSpacing="8">
                    <TextBlock Classes="panel-title" FontSize="14" Text="Preview" />
                    <Border Grid.Row="1" Background="#0E2137" BorderBrush="#355B85" BorderThickness="1" CornerRadius="6">
                      <Grid>
                        <Image Source="{Binding SelectedAssetLibraryPreviewPath}" Stretch="Uniform" IsVisible="{Binding SelectedAssetLibraryPreviewHasImage}" />
                        <TextBlock Text="No Preview" IsVisible="{Binding HasNoSelectedAssetLibraryItem}" Foreground="#8EA5C7" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                    <TextBlock Grid.Row="2" Text="{Binding SelectedAssetLibraryPrompt}" Foreground="#9BB8DA" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Text="{Binding SelectedAssetLibraryMetadata}" Foreground="#8EA5C7" FontSize="10" TextWrapping="Wrap" />
                    <Grid Grid.Row="4" ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                      <Button Classes="panel-action-button"
                              Content="Approve"
                              Click="OnApproveSelectedAssetClick"
                              IsEnabled="{Binding CanApproveSelectedAsset}"
                              ToolTip.Tip="Move this asset into Assets/Approved and make it available for placement." />
                      <Button Grid.Column="1"
                              Classes="panel-action-button"
                              Content="Reject"
                              Click="OnRejectSelectedAssetClick"
                              IsEnabled="{Binding CanRejectSelectedAsset}"
                              ToolTip.Tip="Move this asset into Assets/Rejected." />
                      <Button Grid.Column="2"
                              Classes="panel-action-button"
                              Content="Regenerate"
                              Click="OnRegenerateSelectedAssetClick"
                              IsEnabled="{Binding CanRegenerateSelectedAsset}"
                              ToolTip.Tip="Generate a fresh variation using the stored prompt." />
                      <Button Grid.Column="3"
                              Classes="panel-action-button danger"
                              Content="Delete"
                              Click="OnDeleteSelectedAssetClick"
                              IsEnabled="{Binding CanDeleteSelectedAsset}"
                              ToolTip.Tip="Delete the selected asset file and its metadata." />
                    </Grid>
                  </Grid>
                </Border>
              </Grid>

              <Grid Grid.Row="4" RowDefinitions="*,Auto" RowSpacing="10" IsVisible="{Binding IsAssetPreviewStacked}">
                <Grid RowDefinitions="*" IsVisible="{Binding IsAssetGridView}">
                  <ListBox ItemsSource="{Binding VisibleAssetLibraryItems}" SelectedItem="{Binding SelectedAssetLibraryItem}">
                    <ListBox.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                      </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border Classes="asset-card" Width="168" Margin="0,0,8,8" Padding="10" CornerRadius="8">
                          <Grid RowDefinitions="88,Auto,Auto,Auto" RowSpacing="6">
                            <Border Background="#132A43" BorderBrush="#355B85" BorderThickness="1" CornerRadius="6">
                              <Image Source="{Binding AssetPath}" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Grid.Row="1" Text="{Binding DisplayName}" Foreground="#D6E9FF" FontWeight="SemiBold" TextWrapping="Wrap" />
                            <TextBlock Grid.Row="2" Text="{Binding PromptSnippet}" Foreground="#9BB8DA" FontSize="10" TextWrapping="Wrap" MaxHeight="30" />
                            <Grid Grid.Row="3" ColumnDefinitions="Auto,*" ColumnSpacing="6">
                              <Border Classes="badge" Padding="6,2" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding StatusBadge}" Foreground="#DDEEFF" FontSize="9" FontWeight="SemiBold" />
                              </Border>
                              <TextBlock Grid.Column="1" Text="{Binding QualityScoreLabel}" Foreground="#6FA8FF" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Right" />
                            </Grid>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Grid>
                <ListBox Grid.Row="0" ItemsSource="{Binding VisibleAssetLibraryItems}" SelectedItem="{Binding SelectedAssetLibraryItem}" IsVisible="{Binding IsAssetListView}">
                  <ListBox.ItemTemplate>
                    <DataTemplate>
                      <Border Classes="asset-card" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                        <Grid ColumnDefinitions="52,*,Auto" ColumnSpacing="10">
                          <Border Width="48" Height="48" CornerRadius="6" Background="#132A43" BorderBrush="#355B85" BorderThickness="1">
                            <Image Source="{Binding AssetPath}" Stretch="UniformToFill" />
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="3">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PromptSnippet}" Foreground="#9BB8DA" FontSize="10" TextWrapping="Wrap" MaxHeight="28" />
                          </StackPanel>
                          <StackPanel Grid.Column="2" Spacing="6" HorizontalAlignment="Right">
                            <Border Classes="badge" Padding="6,2" HorizontalAlignment="Right">
                              <TextBlock Text="{Binding StatusBadge}" Foreground="#DDEEFF" FontSize="9" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Text="{Binding QualityScoreLabel}" Foreground="#6FA8FF" FontSize="10" HorizontalAlignment="Right" />
                          </StackPanel>
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
                <Border Grid.Row="1" Classes="subpanel-shell">
                  <Grid RowDefinitions="Auto,160,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Classes="panel-title" FontSize="14" Text="Preview" />
                    <Border Grid.Row="1" Background="#0E2137" BorderBrush="#355B85" BorderThickness="1" CornerRadius="6">
                      <Grid>
                        <Image Source="{Binding SelectedAssetLibraryPreviewPath}" Stretch="Uniform" IsVisible="{Binding SelectedAssetLibraryPreviewHasImage}" />
                        <TextBlock Text="No Preview" IsVisible="{Binding HasNoSelectedAssetLibraryItem}" Foreground="#8EA5C7" HorizontalAlignment="Center" VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                    <TextBlock Grid.Row="2" Text="{Binding SelectedAssetLibraryPrompt}" Foreground="#9BB8DA" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3" Text="{Binding SelectedAssetLibraryMetadata}" Foreground="#8EA5C7" FontSize="10" TextWrapping="Wrap" />
                    <Grid Grid.Row="4" ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                      <Button Classes="panel-action-button" Content="Approve" Click="OnApproveSelectedAssetClick" IsEnabled="{Binding CanApproveSelectedAsset}" ToolTip.Tip="Move this asset into Assets/Approved and make it available for placement." />
                      <Button Grid.Column="1" Classes="panel-action-button" Content="Reject" Click="OnRejectSelectedAssetClick" IsEnabled="{Binding CanRejectSelectedAsset}" ToolTip.Tip="Move this asset into Assets/Rejected." />
                      <Button Grid.Column="2" Classes="panel-action-button" Content="Regenerate" Click="OnRegenerateSelectedAssetClick" IsEnabled="{Binding CanRegenerateSelectedAsset}" ToolTip.Tip="Generate a fresh variation using the stored prompt." />
                      <Button Grid.Column="3" Classes="panel-action-button danger" Content="Delete" Click="OnDeleteSelectedAssetClick" IsEnabled="{Binding CanDeleteSelectedAsset}" ToolTip.Tip="Delete the selected asset file and its metadata." />
                    </Grid>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Border>
          </ContentControl>

          <Border Grid.Row="3"
                  IsVisible="{Binding IsAssetsPanelNoticeVisibleInLeftDock}"
                  Classes="subpanel-shell">
            <StackPanel Spacing="8">
              <TextBlock Classes="panel-title" FontSize="14" Text="Assets Docked Elsewhere" />
              <TextBlock Classes="panel-subtitle"
                         Text="{Binding AssetsPanelPlacement, StringFormat=The Assets panel is currently docked in: {0}. Use its header menu to dock it back here.}"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Grid.Row="3"
                  IsVisible="{Binding IsHistoryTabActive}"
                  Classes="subpanel-shell">
            <StackPanel Spacing="6">
              <TextBlock Text="🕘 History tab is staged." Classes="panel-title" FontSize="14" />
              <TextBlock Text="Undo/redo history remains active in the dedicated timeline panel below."
                         Classes="panel-subtitle"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <GridSplitter x:Name="LeftCenterSplitter"
                    Grid.Column="2"
                    Width="4"
                    Background="{StaticResource SplitterBrush}"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    ShowsPreview="True" />

      <Grid Grid.Column="3" RowDefinitions="*,Auto" RowSpacing="8" Margin="0,0">
        <Border Grid.Row="0" Classes="panel-shell" Background="#1E1E1E" IsVisible="{Binding IsViewportMode}">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
              <TextBlock Text="Viewport" Foreground="#E8E8E8" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
              <ScrollViewer Grid.Column="1"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Disabled"
                            HorizontalAlignment="Right"
                            IsVisible="{Binding HasActiveScenePath}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Classes="toolbar-action quiet" Content="+ Player" Command="{Binding AddPlayerEntityCommand}" ToolTip.Tip="Add Player entity and relaunch runtime" />
                  <Button Classes="toolbar-action quiet" Content="+ NPC" Command="{Binding AddNpcEntityCommand}" ToolTip.Tip="Add NPC entity and relaunch runtime" />
                  <Button Classes="toolbar-action quiet" Content="+ Prop" Command="{Binding AddPropEntityCommand}" ToolTip.Tip="Add Prop entity and relaunch runtime" />
                  <Button Classes="toolbar-action quiet" Content="↶ Undo" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" ToolTip.Tip="Undo latest scene change&#x0a;Shortcut: Ctrl+Z" />
                  <Button Classes="toolbar-action quiet" Content="↷ Redo" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" ToolTip.Tip="Redo reverted scene change&#x0a;Shortcut: Ctrl+Y" />
                  <Button Classes="toolbar-action quiet" Content="🗑" Command="{Binding DeleteSelectedEntityCommand}" ToolTip.Tip="Delete selected entity&#x0a;Shortcut: Delete&#x0a;Also available via marker right-click menu." />
                </StackPanel>
              </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="1" Spacing="6" IsVisible="{Binding HasActiveScenePath}">
              <WrapPanel Orientation="Horizontal">
                <Border Classes="viewport-chip" Margin="0,0,6,6">
                  <TextBlock Text="🖱 Drag" Foreground="#CFE5FF" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <Border Classes="viewport-chip" Margin="0,0,6,6">
                  <TextBlock Text="✏ Double-click Edit" Foreground="#CFE5FF" FontSize="11" FontWeight="SemiBold" />
                </Border>
                <Border Classes="viewport-chip" Margin="0,0,6,6">
                  <TextBlock Text="🗑 Delete key / Menu" Foreground="#CFE5FF" FontSize="11" FontWeight="SemiBold" />
                </Border>
              </WrapPanel>
              <TextBlock Text="Undo/redo tracks add, move, and delete."
                         Foreground="#93A7C7"
                         FontSize="11"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="2" Name="ViewportFocusBorder" Background="#06080D" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="8" Padding="10">
              <Grid x:Name="ViewportWorkspaceGrid" ColumnDefinitions="*,280" ColumnSpacing="8">
                <Border Background="#0B1220" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="8" Padding="10">
                  <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <StackPanel Spacing="6" IsVisible="{Binding HasActiveScenePath}">
                      <WrapPanel Orientation="Horizontal">
                        <Border Background="#132235" CornerRadius="6" Padding="8,4" Margin="0,0,8,6">
                          <TextBlock Text="{Binding ViewportEntityCountLabel}" Foreground="#DCEBFF" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#0F2338" CornerRadius="6" Padding="7,4" Margin="0,0,8,6">
                          <TextBlock Text="{Binding ViewportRenderFrameLabel}" Foreground="#8FD2FF" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#122C4A" CornerRadius="6" Padding="7,4" Margin="0,0,8,6">
                          <TextBlock Text="■ Player" Foreground="#4AA3FF" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#162B1C" CornerRadius="6" Padding="7,4" Margin="0,0,8,6">
                          <TextBlock Text="■ NPC" Foreground="#65C97A" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#1D2330" CornerRadius="6" Padding="7,4" Margin="0,0,8,6">
                          <TextBlock Text="■ Prop" Foreground="#9AA6BA" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                      </WrapPanel>
                      <Grid ColumnDefinitions="Auto,*">
                        <ToggleSwitch IsChecked="{Binding IsViewportEntityPreviewListVisible}"
                                      OnContent="List On"
                                      OffContent="List Off"
                                      Foreground="#AFC2DF"
                                      VerticalAlignment="Center"
                                      ToolTip.Tip="Toggle optional live entity preview list panel." />
                        <ScrollViewer Grid.Column="1"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalAlignment="Right">
                          <StackPanel Orientation="Horizontal" Spacing="6">
                            <Border Background="#122B46" BorderBrush="#4AA3FF" BorderThickness="1" CornerRadius="6" Padding="7,3">
                              <TextBlock Text="{Binding ViewportSelectionStateLabel}" Foreground="#CFE7FF" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <Border Background="#16273F" BorderBrush="#5D9EE2" BorderThickness="1" CornerRadius="6" Padding="7,3" IsVisible="{Binding IsDirectPropertyEditActive}">
                              <TextBlock Text="{Binding DirectPropertyEditBadge}" Foreground="#DDF0FF" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding ViewportLivePreviewLabel}" Foreground="#7FB4FF" FontSize="11" VerticalAlignment="Center" />
                          </StackPanel>
                        </ScrollViewer>
                      </Grid>
                    </StackPanel>

                    <Grid Grid.Row="1">
                      <Canvas Name="ViewportCanvas" Background="#070B14" ClipToBounds="True" Focusable="True" />
                      <Border IsVisible="{Binding IsViewportEmpty}" Classes="subpanel-shell" Background="#0B1322E8" CornerRadius="16" Padding="40,36" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="16" Width="456">
                          <TextBlock Text="No scene loaded" Classes="panel-title" FontSize="26" HorizontalAlignment="Center" />
                          <TextBlock Text="Create a new scene or open an existing one to begin editing." Classes="panel-subtitle" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" />
                          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10">
                            <Button Classes="panel-action-button primary empty-state-cta" Content="Create New Scene" Click="OnNewSceneClick" />
                            <Button Classes="panel-action-button empty-state-cta" Content="Open Existing Scene" Click="OnOpenSceneClick" />
                          </StackPanel>
                        </StackPanel>
                      </Border>
                      <Border Background="#070B14AA"
                              CornerRadius="4"
                              Padding="8,4"
                              Margin="6"
                              VerticalAlignment="Bottom"
                              HorizontalAlignment="Left"
                              IsVisible="{Binding HasActiveScenePath}"
                              IsHitTestVisible="False">
                        <TextBlock Text="Pan: left-drag · Zoom: wheel · Marquee: Ctrl+drag · Context: right-click"
                                   Foreground="#B8C4D8"
                                   FontSize="10"
                                   TextWrapping="Wrap"
                                   MaxWidth="420" />
                      </Border>
                    </Grid>
                  </Grid>
                </Border>

                <Border x:Name="ViewportSelectionInspectorBorder"
                        Grid.Column="1"
                        Classes="subpanel-shell"
                        IsVisible="{Binding HasActiveScenePath}">
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="6" VerticalAlignment="Top">
                    <StackPanel Spacing="2">
                      <TextBlock Text="Selection" Classes="panel-title" FontSize="13" />
                      <TextBlock Text="Live summary next to the canvas. Full fields: Inspector → Scene Properties."
                                 Classes="panel-subtitle"
                                 FontSize="10"
                                 TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock Grid.Row="1"
                               Text="{Binding SelectedEntitySummary}"
                               Foreground="#C8D6EA"
                               TextWrapping="Wrap"
                               MaxLines="4" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding ViewportPlaybackSummary}"
                               Foreground="#8FC2FF"
                               FontSize="11"
                               TextWrapping="Wrap"
                               MaxLines="3" />
                    <ScrollViewer Grid.Row="3"
                                  MaxHeight="200"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                      <StackPanel Spacing="8">
                        <Border Classes="subpanel-shell" Padding="8,6">
                          <TextBlock Text="{Binding SelectionInteractionHint}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding ViewportEntities}" IsVisible="{Binding IsViewportEntityPreviewListVisible}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="#0F1B2E" BorderBrush="{Binding ListBorderBrush}" BorderThickness="1.2" CornerRadius="6" Padding="8,6" Margin="0,0,0,6">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                  <Border Width="{Binding RenderWidth}"
                                          Height="{Binding RenderHeight}"
                                          Background="{Binding RenderBrush}"
                                          BorderBrush="#D4E7FF"
                                          BorderThickness="1.2"
                                          CornerRadius="3"
                                          VerticalAlignment="Center" />
                                  <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8F2FF" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding TypeBadge}" Foreground="#9BB4D6" FontSize="10" />
                                    <TextBlock Text="{Binding ParentBadge}" Foreground="#7FA2CD" FontSize="10" />
                                    <TextBlock Text="{Binding X, StringFormat=X {0:F2}}" Foreground="#8EA5C7" FontSize="10" />
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Spacing="1" HorizontalAlignment="Right">
                                    <Border Background="#1A2F4C" BorderBrush="#6FB8FF" BorderThickness="1" CornerRadius="8" Padding="6,1" HorizontalAlignment="Right" IsVisible="{Binding IsSelectionBadgeVisible}">
                                      <TextBlock Text="SELECTED" Foreground="#CFE7FF" FontSize="9" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="{Binding Y, StringFormat=Y {0:F2}}" Foreground="#8EA5C7" FontSize="10" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding Scale, StringFormat=S {0:F2}}" Foreground="#8EA5C7" FontSize="10" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding RenderColorHex}" Foreground="#8EA5C7" FontSize="10" HorizontalAlignment="Right" />
                                  </StackPanel>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="0" Background="#090B11" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12" IsVisible="{Binding IsCodeMode}">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="Code Mode — Runtime C++ Editor" Foreground="#EEF4FF" FontSize="16" FontWeight="SemiBold" />
              <Button Grid.Column="1" Content="Save &amp; Recompile" Click="OnSaveCodeClick" ToolTip.Tip="Save generated C++ edits, recompile, and relaunch runtime" />
            </Grid>
            <avaloniaEdit:TextEditor Grid.Row="1"
                                     Name="CodeEditor"
                                     Margin="0,10,0,0"
                                     FontFamily="Consolas, Menlo, Monospace"
                                     FontSize="14"
                                     ShowLineNumbers="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#06080D"
                                     Foreground="#D8E8FF" />
          </Grid>
        </Border>

        <Border Grid.Row="1"
                Classes="panel-shell"
                Background="#101722"
                IsVisible="{Binding IsChatCopilotPanelVisible}">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
            <TextBlock Text="Chat Co-Pilot" Classes="panel-title" FontSize="18" />

            <StackPanel Grid.Row="1" Spacing="8">
              <TextBlock Text="Describe Your Game" Foreground="#C8D6EA" FontSize="13" FontWeight="SemiBold" />
              <TextBox Text="{Binding ChatPrompt}" Height="96" AcceptsReturn="True" TextWrapping="Wrap" Watermark="A cozy single-player colony sim with light RPG progression..." />
              <Button Classes="generate-cta" Content="{Binding GenerateButtonLabel}" Click="OnGenerateAndPlayClick" IsEnabled="{Binding CanGenerate}" />
              <TextBlock Text="{Binding StatusMessage}" Foreground="#AFC2DF" TextWrapping="Wrap" FontSize="12" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <GridSplitter x:Name="CenterRightSplitter"
                    Grid.Column="4"
                    Width="4"
                    Background="{StaticResource SplitterBrush}"
                    ResizeDirection="Columns"
                    ResizeBehavior="PreviousAndNext"
                    ShowsPreview="True" />

      <Border x:Name="RightDockBorder" Grid.Column="5" Classes="panel-shell" Margin="0">
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel x:Name="RightDockDetachedPanelsHost" Spacing="10">
        <ContentControl x:Name="AssetsPanelRightHost" />
        <ContentControl x:Name="AiInterviewRightHost" />
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
          <Grid Classes="panel-header" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <StackPanel Spacing="2">
              <TextBlock Text="Inspector" Classes="panel-title" FontSize="15" ToolTip.Tip="Selection properties, scene systems, and runtime tools." />
              <TextBlock Text="Scene Properties: transforms and apply. Advanced: runtime feed, export, scene systems, and AI." Classes="panel-subtitle" TextWrapping="Wrap" />
            </StackPanel>
            <Button Grid.Column="1" Classes="panel-header-action" Content="Hide" Click="OnToggleRightPaneClick" ToolTip.Tip="Hide the right dock." />
          </Grid>
          <TextBlock Grid.Row="1"
                     Text="Simple keeps the core editing flow visible. Advanced reveals scene systems, diagnostics, and publishing tools."
                     Foreground="#9DB0CC"
                     TextWrapping="Wrap" />

          <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="6" Margin="0,2,0,0">
            <Button Classes="panel-tab active"
                    Content="Simple"
                    Click="OnShowSimpleInspectorClick"
                    IsVisible="{Binding IsSimpleInspectorEnabled}" />
            <Button Classes="panel-tab"
                    Content="Simple"
                    Click="OnShowSimpleInspectorClick"
                    IsVisible="{Binding IsAdvancedInspectorEnabled}" />
            <Button Grid.Column="1"
                    Classes="panel-tab active"
                    Content="Advanced"
                    Click="OnShowAdvancedInspectorClick"
                    IsVisible="{Binding IsAdvancedInspectorEnabled}" />
            <Button Grid.Column="1"
                    Classes="panel-tab"
                    Content="Advanced"
                    Click="OnShowAdvancedInspectorClick"
                    IsVisible="{Binding IsSimpleInspectorEnabled}" />
            <TextBlock Grid.Column="2"
                       Text="{Binding InspectorDepthLabel, StringFormat=Inspector: {0}}"
                       Foreground="#8EA5C7"
                       FontSize="11"
                       VerticalAlignment="Center" />
            <Grid Grid.Column="3" ColumnDefinitions="Auto,Auto" ColumnSpacing="6" IsVisible="{Binding IsAdvancedInspectorEnabled}">
              <TextBlock Text="Debug Console" Foreground="#D5E4F8" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1"
                            Classes="deep-toggle"
                            IsChecked="{Binding IsDebugConsoleEnabled}"
                            ToolTip.Tip="Show runtime diagnostics and development logs." />
            </Grid>
          </Grid>

          <Border Grid.Row="3"
                  Background="#0B1524"
                  BorderBrush="#264566"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10,8">
            <TextBlock Text="{Binding WorkspaceModeDescription}"
                       Foreground="#AFC2DF"
                       FontSize="11"
                       TextWrapping="Wrap" />
          </Border>

          <Expander Grid.Row="4" IsExpanded="True" HorizontalAlignment="Stretch">
            <Expander.Header>
              <TextBlock Text="Runtime Preview" Foreground="#EEF4FF" FontSize="14" FontWeight="SemiBold" />
            </Expander.Header>
            <Border BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto" RowSpacing="8">
              <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="8" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="🟢 Vulkan Runtime Live Feed" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding RuntimePreviewSummary}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding RuntimeSelectedEntityPreview}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <TextBlock Grid.Row="1" Text="Runtime Status" Foreground="#D5E4F8" FontWeight="SemiBold" />
              <TextBlock Grid.Row="2" Text="{Binding RuntimeLaunchStatus, StringFormat=Live in Vulkan status: {0}}" Foreground="#AFC2DF" />
              <TextBlock Grid.Row="3" Text="Generated Entity List (scene/scene_scaffold.json)" Foreground="#D5E4F8" FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="4" MaxHeight="120">
                <TextBlock Text="{Binding RuntimeEntityList}" Foreground="#AFC2DF" TextWrapping="Wrap" FontFamily="Consolas, Menlo, Monospace" />
              </ScrollViewer>
              <Button Grid.Row="5" Classes="generate-cta" Content="Relaunch Runtime" Click="OnPlayRuntimeClick" ToolTip.Tip="Rebuild generated runtime and relaunch generated_gameplay_runner" />
            </Grid>
          </Border>
          </Expander>

          <Border Grid.Row="5"
                  BorderBrush="#2B3446"
                  BorderThickness="1"
                  Background="#101722"
                  CornerRadius="8"
                  Padding="10"
                  IsVisible="{Binding IsAdvancedInspectorEnabled}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="8">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <TextBlock Text="🚀" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Export + Publish Checklist" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{Binding ExportChecklistProgressPercent, StringFormat={}{0}%}" Foreground="#6FA8FF" FontWeight="Bold" VerticalAlignment="Center" />
              </Grid>
              <TextBlock Grid.Row="1"
                         Text="{Binding ExportStatus}"
                         Foreground="#AFC2DF"
                         FontSize="11"
                         TextWrapping="Wrap" />
              <ProgressBar Grid.Row="2"
                           Minimum="0"
                           Maximum="{Binding ExportChecklistTotalCount}"
                           Value="{Binding ExportChecklistCompletedCount}"
                           Height="7"
                           Background="#0B1524"
                           Foreground="#4AA3FF" />
              <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                <TextBlock Text="🚦" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding SteamReadinessSummary}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                <Border Grid.Column="2" Background="#2D3E5C" CornerRadius="10" Padding="6,2" IsVisible="{Binding HasSteamReadinessWarnings}">
                  <TextBlock Text="Warnings" Foreground="#FFD27D" FontSize="10" FontWeight="SemiBold" />
                </Border>
              </Grid>
              <TextBlock Grid.Row="4"
                         Text="{Binding SteamReadinessWarnings}"
                         Foreground="#8EA5C7"
                         FontSize="10"
                         TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="5" MaxHeight="128">
                <ItemsControl ItemsSource="{Binding ExportChecklistItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6"
                              Padding="8"
                              CornerRadius="6"
                              Background="#0B1524"
                              BorderBrush="#264566"
                              BorderThickness="1"
                              ToolTip.Tip="{Binding Tooltip}">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1" Text="{Binding ProgressIcon}" Foreground="#D6E9FF" VerticalAlignment="Center" />
                          <StackPanel Grid.Column="2" Spacing="1">
                            <TextBlock Text="{Binding Label}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Status}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                          </StackPanel>
                          <TextBlock Grid.Column="3" Text="{Binding SeverityIcon}" FontSize="13" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
              <Grid Grid.Row="6" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <TextBlock Text="Progress:" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="{Binding ExportChecklistCompletedCount}" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="/" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="{Binding ExportChecklistTotalCount}" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="steps complete" Foreground="#9FC2E5" FontSize="11" />
                </StackPanel>
                <Button Grid.Column="1" Content="⚙ Run Export" Click="OnRunExportChecklistClick" />
                <Button Grid.Column="2" Content="📁 Open Folder" Click="OnOpenExportFolderClick" IsEnabled="{Binding HasExportFolderOutput}" />

                <TextBlock Grid.Row="1"
                           Text="{Binding ExportFolderPath, StringFormat=Folder: {0}}"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Row="2"
                           Text="{Binding ExportPackagePath, StringFormat=ZIP: {0}}"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Row="2" Grid.Column="2" Content="⬇ Download ZIP" Click="OnOpenExportZipClick" IsEnabled="{Binding HasExportPackageOutput}" />
                <Button Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Content="🛰 Publish to Steam (Dry-Run)" Click="OnPublishToSteamClick" ToolTip.Tip="Runs publish gate + local audit trail only. No upload yet." />
                <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="{Binding PublishDryRunStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                <TextBlock Grid.Row="5" Text="Steam Release Notes" Foreground="#9FC2E5" FontSize="11" VerticalAlignment="Center" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Text="{Binding SteamReleaseNotes}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="72"
                         Watermark="Describe this release for Steam store copy and patch notes..." />
                <Button Grid.Row="6"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Content="☁️ Upload to Steam (Stub)"
                        Click="OnUploadToSteamStubClick"
                        IsEnabled="{Binding CanRunSteamUploadStub}"
                        ToolTip.Tip="Generates upload ZIP + audit trail and simulates upload progress. No real Steam API calls." />
                <ProgressBar Grid.Row="7"
                             Grid.ColumnSpan="3"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding SteamUploadProgressPercent}"
                             Height="7"
                             Background="#0B1524"
                             Foreground="#6FA8FF" />
                <TextBlock Grid.Row="8"
                           Grid.ColumnSpan="3"
                           Text="{Binding SteamUploadStatus}"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <Border Grid.Row="9"
                        Grid.ColumnSpan="3"
                        BorderBrush="#264566"
                        BorderThickness="1"
                        Background="#0B1524"
                        CornerRadius="6"
                        Padding="8">
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                      <TextBlock Text="🛠" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="Installer Builder" Foreground="#D6E9FF" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <Button Grid.Column="2" Content="Build Installer" Click="OnBuildInstallerClick" IsEnabled="{Binding CanRunInstallerBuild}" />
                      <Button Grid.Column="3" Content="Open Installer" Click="OnOpenInstallerOutputClick" IsEnabled="{Binding HasInstallerOutput}" />
                    </Grid>
                    <ProgressBar Grid.Row="1"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding InstallerBuildProgressPercent}"
                                 Height="7"
                                 Background="#09111D"
                                 Foreground="#4AA3FF" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding InstallerBuildStatus}"
                               Foreground="#9FC2E5"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3"
                               Text="{Binding InstallerOutputPath, StringFormat=Installer output: {0}}"
                               Foreground="#8EA5C7"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="4" MaxHeight="72" VerticalScrollBarVisibility="Auto">
                      <TextBlock Text="{Binding InstallerBuildLog}"
                                 Foreground="#7FA6CF"
                                 FontSize="10"
                                 FontFamily="Consolas, Menlo, Monospace"
                                 TextWrapping="Wrap" />
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Border>


          <Border Grid.Row="8"
                  BorderBrush="#2B3446"
                  BorderThickness="1"
                  Background="#101722"
                  CornerRadius="8"
                  Padding="10"
                  IsVisible="{Binding IsAdvancedInspectorEnabled}">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
              <TextBlock Text="🧠 Scene Systems + AI" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="1"
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <Button Classes="panel-tab" Content="📖" Click="OnSystemTabClick" Tag="Story" />
                  <Button Classes="panel-tab" Content="🧍" Click="OnSystemTabClick" Tag="LivingNpcs" />
                  <Button Classes="panel-tab" Content="🌦" Click="OnSystemTabClick" Tag="Weather" />
                  <Button Classes="panel-tab" Content="🏘" Click="OnSystemTabClick" Tag="Settlement" />
                  <Button Classes="panel-tab" Content="⚔" Click="OnSystemTabClick" Tag="Combat" />
                  <Button Classes="panel-tab" Content="🌗" Click="OnSystemTabClick" Tag="DayNight" />
                  <Button Classes="panel-tab" Content="🏠" Click="OnSystemTabClick" Tag="Buildings" />
                  <Button Classes="panel-tab" Content="🎒" Click="OnSystemTabClick" Tag="InventoryRecipes" />
                  <Button Classes="panel-tab" Content="💬" Click="OnSystemTabClick" Tag="Dialogs" />
                  <Button Classes="panel-tab" Content="🤖" Click="OnSystemTabClick" Tag="AI" />
                  <Button Classes="panel-tab" Content="🧠" Click="OnSystemTabClick" Tag="CoCreator" />
                  <Button Classes="panel-tab" Content="⬇" Click="OnOpenModelsAndLlmSettingsClick" ToolTip.Tip="Models &amp; LLM" />
                  <Button Classes="panel-tab" Content="⚙" Click="OnSystemTabClick" Tag="Settings" />
                </StackPanel>
              </ScrollViewer>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsDayNightTabActive}">
                <TextBlock Text="Day/Night Cycle" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Speed" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding DayCycleSpeedEditor}" />
                  <TextBlock Grid.Column="2" Text="Progress" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding DayProgressEditor}" />
                  <TextBlock Grid.Column="4" Text="Day" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="5" Text="{Binding DayCountEditor}" />
                </Grid>
                <Button Classes="system-action" Content="Apply Day/Night" Click="OnApplyDayNightClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsWeatherTabActive}">
                <TextBlock Text="Dynamic Weather" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Current" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding WeatherCurrentEditor}" Watermark="sunny/rain/storm/snow/sandstorm" />
                  <TextBlock Grid.Column="2" Text="Target" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding WeatherTargetEditor}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Intensity" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding WeatherIntensityEditor}" />
                  <TextBlock Grid.Column="2" Text="Transition(s)" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding WeatherTransitionSecondsEditor}" />
                  <TextBlock Grid.Column="4" Text="Next change(s)" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="5" Text="{Binding WeatherNextTransitionSecondsEditor}" />
                </Grid>
                <Button Classes="system-action" Content="Apply Weather" Click="OnApplyWeatherClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsLivingNpcsTabActive}">
                <TextBlock Text="Living NPCs + Free-Will" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <CheckBox Content="Global Free-Will Enabled" IsChecked="{Binding LivingNpcsFreeWillEnabledEditor}" />
                  <CheckBox Grid.Column="1" Content="LLM Enabled" IsChecked="{Binding LivingNpcsLlmEnabledEditor}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Spark chance/sec" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding LivingNpcsSparkChancePerSecondEditor}" />
                  <TextBlock Grid.Column="2" Text="Max sparks/NPC/day" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding LivingNpcsMaxSparksPerNpcPerDayEditor}" />
                </Grid>
                <TextBox Text="{Binding LivingNpcsModelPathEditor}" Watermark="llama.cpp model path (e.g., models/llm-q4-k.gguf)" />
                <Button Classes="system-action" Content="Save Living NPC Settings" Click="OnSaveLivingNpcsSettingsClick" />
                <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding LivingNpcsPerformanceSummary}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsRagCacheSize, StringFormat=RAG Cache Size: {0} entries}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsRagHitRate, StringFormat=RAG Hit Rate: {0:P0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsNarrativeFlavorHitRate, StringFormat=Narrative Flavor Hit Rate: {0:P0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsGenerationalMemorySize, StringFormat=Generational Memory Size: {0} entries}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsLegacyRecallHitRate, StringFormat=Legacy Recall Hit Rate: {0:P0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsLastMsqAdaptationSource, StringFormat=Last MSQ Adaptation Source: {0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsLastNarrativeCheckpoint, StringFormat=Last Narrative Checkpoint: {0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsLastNarrativeCheckpointStatus, StringFormat=Narrative Checkpoint Status: {0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsSparkSourcePreference, StringFormat=Spark Source Priority: {0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsSelectedSparkSource, StringFormat=Selected NPC Last Spark Source: {0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsSelectedRagHitRate, StringFormat=Selected NPC RAG Hit Rate: {0:P0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LivingNpcsSelectedNpcDaySummary, StringFormat=Selected NPC Day Summary: {0}}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </ScrollViewer>
                <TextBlock Text="Scripted Behaviors (SB2)" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                  <TextBlock Text="State" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <ComboBox Grid.Column="1"
                            ItemsSource="{Binding AvailableScriptedBehaviorStates}"
                            SelectedItem="{Binding ScriptedBehaviorStateEditor}" />
                  <Button Grid.Column="2" Classes="system-action" Content="Refresh List" Click="OnRefreshScriptedBehaviorsClick" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Params" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding ScriptedBehaviorParamsEditor}" Watermark="duration_hours=0.25 target_entity_id=42" />
                </Grid>
                <Button Classes="system-action" Content="Assign Scripted Behavior to Selection" Click="OnAssignScriptedBehaviorClick" />
                <TextBlock Text="{Binding ScriptedBehaviorStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="5" Padding="8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Current NPC scripted state preview (Scripted Priority vs Spark Allowed)" Foreground="#AFC2DF" FontSize="11" />
                    <ItemsControl ItemsSource="{Binding ScriptedBehaviorNpcPreview}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding .}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="5" Padding="8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="{Binding LivingNpcsSparksToday, StringFormat=Sparks today: {0}}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                    <TextBlock Text="Recent sparks" Foreground="#AFC2DF" FontSize="11" />
                    <ItemsControl ItemsSource="{Binding LivingNpcsRecentSparks}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding .}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
                <Button Classes="system-action" Content="Re-seed Selected NPC Defaults" Click="OnReseedLivingNpcDefaultsClick" />
                <TextBlock Text="{Binding LivingNpcsStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsSettlementTabActive}">
                <TextBlock Text="Settlement Overview" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Village" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding SettlementVillageNameEditor}" />
                  <TextBlock Grid.Column="2" Text="Population" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="3" Text="{Binding SettlementPopulation}" Foreground="#D6E9FF" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Morale" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding SettlementMoraleEditor}" />
                  <TextBlock Grid.Column="2" Text="Food" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding SettlementFoodEditor}" />
                </Grid>
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Stockpile" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding SettlementStockpileEditor}" />
                </Grid>
                <Button Classes="system-action" Content="Save Living NPC Settings" Click="OnSaveLivingNpcsSettingsClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsCombatTabActive}">
                <TextBlock Text="Combat Mode" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <Button Classes="system-action" Content="Toggle Combat Mode" Click="OnToggleCombatModeClick" />
                <TextBlock Text="{Binding CombatModeEnabledEditor, StringFormat=Combat Active: {0}}" Foreground="#8EA5C7" VerticalAlignment="Center" TextWrapping="Wrap" />
                <Button Classes="system-action" Content="Toggle Realtime Combat on Selection" Click="OnToggleRealtimeCombatSelectionClick" />
                <TextBlock Text="{Binding RealtimeCombatSelectionSummary}" Foreground="#8EA5C7" VerticalAlignment="Center" TextWrapping="Wrap" />
                <TextBlock Text="{Binding RealtimeCombatAnimationPreview}" Foreground="#8EA5C7" VerticalAlignment="Center" TextWrapping="Wrap" />
                <TextBlock Text="{Binding RealtimeCombatWorldIntegrationPreview}" Foreground="#8EA5C7" VerticalAlignment="Center" TextWrapping="Wrap" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsBuildingsTabActive}">
                <TextBlock Text="Buildable Entities" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding BuildableEntities}" SelectedItem="{Binding SelectedBuildableEntity}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Type" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding SelectedBuildableType}" />
                  <TextBlock Grid.Column="2" Text="Grid X" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding SelectedBuildableGridX}" />
                  <TextBlock Grid.Column="4" Text="Grid Y" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="5" Text="{Binding SelectedBuildableGridY}" />
                </Grid>
                <Button Content="Apply Buildable" Click="OnApplyBuildableClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsInventoryRecipesTabActive}">
                <TextBlock Text="Inventory + Recipes" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBlock Text="{Binding PlayerInventorySummary, StringFormat=Player: {0}}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <TextBox Watermark="Recipe Name" Text="{Binding RecipeNameEditor}" />
                  <TextBox Grid.Column="1" Watermark="inputs csv (wood:2,stone:1)" Text="{Binding RecipeInputsEditor}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                  <TextBox Watermark="Output Item" Text="{Binding RecipeOutputEditor}" />
                  <TextBox Grid.Column="1" Width="70" Text="{Binding RecipeQuantityEditor}" />
                  <Button Grid.Column="2" Content="Add/Update" Click="OnAddRecipeClick" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Recipes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="5" Padding="6" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Name}" Foreground="#AFC2DF" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsDialogsTabActive}">
                <TextBlock Text="NPC Dialog Draft" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding DialogNpcs}" SelectedItem="{Binding SelectedDialogNpc}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBox Watermark="Start Node" Text="{Binding DialogStartNodeEditor}" />
                <TextBox Watermark="Node Id" Text="{Binding DialogNodeIdEditor}" />
                <TextBox Watermark="Node Text" Text="{Binding DialogNodeTextEditor}" />
                <TextBox Watermark="Choice Text" Text="{Binding DialogChoiceTextEditor}" />
                <TextBox Watermark="Choice Next Node" Text="{Binding DialogChoiceNextNodeEditor}" />
                <Button Content="Apply Dialog Draft" Click="OnApplyDialogDraftClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsAiTabActive}">
                <TextBlock Text="Python AI Orchestration" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBox Text="{Binding AiPromptEditor}" Watermark="Modify Scene with Prompt" />
                <WrapPanel Orientation="Horizontal">
                  <Button Content="Generate NPC" Click="OnGenerateNpcClick" MinWidth="108" Margin="0,0,6,6" />
                  <Button Content="Add 3 Houses" Click="OnAdd3HousesClick" MinWidth="108" Margin="0,0,6,6" />
                  <Button Content="Modify Scene" Click="OnModifyScenePromptClick" MinWidth="108" Margin="0,0,6,6" />
                  <Button Content="Generate with Kit-Bashing" Click="OnGenerateKitBashClick" MinWidth="132" Margin="0,0,6,6" />
                  <Button Content="Generate Loot" Click="OnGenerateLootClick" MinWidth="108" Margin="0,0,6,6" />
                  <Button Content="Live Edit Scene" Click="OnLiveEditSceneClick" MinWidth="120" Margin="0,0,6,6" />
                  <Button Content="Render 2D" Click="OnRender2DClick" MinWidth="88" Margin="0,0,6,6" />
                  <Button Content="Render 3D" Click="OnRender3DClick" MinWidth="88" Margin="0,0,6,6" />
                </WrapPanel>
                <ScrollViewer MaxHeight="84">
                  <TextBlock Text="{Binding AiCommandLog}" Foreground="#8EA5C7" FontFamily="Consolas, Menlo, Monospace" FontSize="10" TextWrapping="Wrap" />
                </ScrollViewer>
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                  <StackPanel Spacing="6">
                    <StackPanel Spacing="8">
                      <WrapPanel Orientation="Horizontal">
                        <TextBlock Text="Project Health" Foreground="#D6E9FF" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,10,4" />
                        <TextBlock Text="{Binding ProjectHealthScore, StringFormat={}{0}/100}" Foreground="{Binding ProjectHealthBrush}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,4" />
                        <TextBlock Text="{Binding ProjectHealthBand}" Foreground="{Binding ProjectHealthBrush}" VerticalAlignment="Center" Margin="0,0,10,4" />
                        <TextBlock Text="{Binding LightweightMode, StringFormat=Mode: {0}}" Foreground="#9FC2E5" VerticalAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,4" />
                      </WrapPanel>
                      <WrapPanel Orientation="Horizontal">
                        <Button Content="Run Optimization Check" Click="OnRunOptimizationCheckClick" MinWidth="140" Margin="0,0,6,6" />
                        <Button Content="Optimize Project" Click="OnOptimizeProjectOneClick" MinWidth="120" Margin="0,0,6,6" />
                        <Button Content="Switch to Lightweight Mode" Click="OnSwitchLightweightModeClick" MinWidth="168" Margin="0,0,6,6" />
                      </WrapPanel>
                    </StackPanel>
                    <TextBlock Text="{Binding PerformanceHealthSummary}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding LightweightModeSuggestion}" Foreground="#AFC2DF" FontSize="10" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding GuardrailStatus}" Foreground="#F0B68B" FontSize="10" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding OptimizationStatus}" Foreground="#8EA5C7" FontSize="10" TextWrapping="Wrap" />
                    <TextBlock Text="Recent Changes" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <ItemsControl ItemsSource="{Binding RecentOptimizationChanges}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#101B2C" BorderBrush="#264566" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                            <StackPanel Spacing="2">
                              <TextBlock Text="{Binding ActionType}" Foreground="#EAF3FF" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding Summary}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                              <TextBlock Text="{Binding Delta}" Foreground="#8EA5C7" FontSize="10" />
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="Optimization Suggestions" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <ItemsControl ItemsSource="{Binding OptimizationSuggestions}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#101B2C" BorderBrush="#264566" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,4">
                            <StackPanel Spacing="4">
                              <TextBlock Text="{Binding Title}" Foreground="#EAF3FF" FontWeight="SemiBold" />
                              <TextBlock Text="{Binding Summary}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                              <WrapPanel Orientation="Horizontal">
                                <Button Content="Preview" Tag="{Binding Id}" Click="OnPreviewOptimizationSuggestionClick" Margin="0,0,6,6" />
                                <Button Content="Apply" Tag="{Binding Id}" Click="OnApplyOptimizationSuggestionClick" Margin="0,0,6,6" />
                                <Button Content="Ignore" Tag="{Binding Id}" Click="OnIgnoreOptimizationSuggestionClick" Margin="0,0,6,6" />
                                <TextBlock Text="{Binding IsSafeToAutoApply, StringFormat=Safe: {0}}"
                                           Foreground="#8EA5C7"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6" />
                              </WrapPanel>
                            </StackPanel>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Border Background="#0A1321" BorderBrush="#213A59" BorderThickness="1" CornerRadius="4" Padding="6">
                      <TextBlock Text="{Binding SelectedOptimizationPreview}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                    </Border>
                  </StackPanel>
                </Border>
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,6,0,0">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Models &amp; LLM Settings" Foreground="#D6E9FF" FontWeight="SemiBold" />
                    <TextBlock Text="Add your Hugging Face token, run Quick Setup, and watch model rows for Installed / Not found / download progress — same flow as first launch."
                               Foreground="#9FC2E5"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <Button Content="Open Models &amp; LLM Settings"
                            Click="OnOpenModelsAndLlmSettingsClick"
                            HorizontalAlignment="Left" />
                    <TextBlock Text="{Binding ModelManagerStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsModelsTabActive}">
                <TextBlock Text="Models &amp; LLM" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBlock Text="Token first, then Quick Setup or individual downloads. Status matches Settings; progress uses the main-window overlay while downloading."
                           Foreground="#9FC2E5"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBlock Text="Models &amp; LLM" Foreground="#D6E9FF" FontWeight="SemiBold" />
                      <Button Grid.Column="1" Content="Open AI Quick Access" Click="OnSystemTabClick" Tag="AI" IsEnabled="{Binding CanRunModelManagerActions}" />
                    </Grid>
                    <TextBlock Text="{Binding ModelRecommendationSummary}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                    <WrapPanel Orientation="Horizontal" ItemWidth="200">
                      <Button Content="Quick Start (ForgeGuard + Free-Will)"
                              Click="OnQuickStartModelsClick"
                              IsEnabled="{Binding CanRunModelManagerActions}"
                              Margin="0,0,6,6" />
                      <Button Content="Run Onboarding"
                              Click="OnRunModelOnboardingClick"
                              IsEnabled="{Binding CanRunModelManagerActions}"
                              Margin="0,0,6,6" />
                      <Button Content="Setup Recommended Models"
                              Click="OnSetupRecommendedModelsClick"
                              IsEnabled="{Binding CanRunModelManagerActions}"
                              Margin="0,0,6,6" />
                      <Button Content="Download &amp; Enable Free-Will Model" Click="OnSetupFreeWillModelClick" IsEnabled="{Binding CanRunModelManagerActions}" Margin="0,0,6,6" />
                      <Button Content="Refresh Models" Click="OnRefreshModelsClick" IsEnabled="{Binding CanRunModelManagerActions}" Margin="0,0,6,6" />
                    </WrapPanel>
                    <ItemsControl ItemsSource="{Binding ModelManagerEntries}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border Background="#101B2C" BorderBrush="#264566" BorderThickness="1" CornerRadius="5" Padding="6" Margin="0,0,0,4">
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*">
                              <StackPanel Grid.Row="0" Spacing="2">
                                <TextBlock Text="{Binding DisplayName}" Foreground="#EAF3FF" FontWeight="SemiBold" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Status}" Foreground="#7EC0FF" FontSize="11" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding EstimatedSize}" Foreground="#9FB7D8" FontSize="10" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Recommendation}" Foreground="#8EA5C7" FontSize="10" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding LastError}" Foreground="#FFB39F" FontSize="10" TextWrapping="Wrap" IsVisible="{Binding CanRetry}" />
                              </StackPanel>
                              <WrapPanel Grid.Row="1"
                                         Orientation="Horizontal"
                                         Margin="0,8,0,0">
                                <Button Content="Download"
                                        Tag="{Binding FriendlyName}"
                                        Click="OnDownloadManagedModelClick"
                                        IsEnabled="{Binding #RootWindow.DataContext.CanRunModelManagerActions}"
                                        Margin="0,0,6,6" />
                                <Button Content="Retry"
                                        Tag="{Binding FriendlyName}"
                                        Click="OnRetryManagedModelClick"
                                        IsVisible="{Binding CanRetry}"
                                        IsEnabled="{Binding #RootWindow.DataContext.CanRunModelManagerActions}"
                                        Margin="0,0,6,6" />
                                <Button Content="Remove"
                                        Tag="{Binding FriendlyName}"
                                        Click="OnRemoveManagedModelClick"
                                        IsVisible="{Binding IsRemovable}"
                                        IsEnabled="{Binding #RootWindow.DataContext.CanRunModelManagerActions}"
                                        Margin="0,0,6,6" />
                              </WrapPanel>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Text="{Binding ForgeGuardKeepInstalledMessage}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ModelManagerStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsSettingsTabActive}">
                <TextBlock Text="Settings" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBlock Text="Configure editor-level systems and workspace behavior from one place."
                           Foreground="#9FC2E5"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                  <StackPanel Spacing="6">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                      <TextBlock Text="Model Setup" Foreground="#D6E9FF" FontWeight="SemiBold" />
                      <Button Grid.Column="1" Content="Open Models &amp; LLM" Click="OnOpenModelsAndLlmSettingsClick" />
                    </Grid>
                    <TextBlock Text="Full model setup lives in Preferences → Models &amp; LLM (token, Quick Setup, and per-model actions)."
                               Foreground="#9FC2E5"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding ModelManagerStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsCoCreatorTabActive}">
                <TextBlock Text="AI Co-Creator Live" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBox Text="{Binding BiomeEditor}" Watermark="Biome (e.g., desert, tundra, temperate)" />
                <TextBox Text="{Binding WorldStyleGuideEditor}" Watermark="World style guide for narrative + visual tone" />
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="6">
                  <Button Content="Save Context" Click="OnSaveCoCreatorContextClick" />
                  <Button Grid.Column="1" Content="Refresh Suggestions" Click="OnRefreshCoCreatorClick" />
                  <Button Grid.Column="2" Content="Rebuild Navmesh" Click="OnRebuildNavmeshClick" />
                  <Button Grid.Column="3" Content="Toggle Live" Click="OnToggleCoCreatorLiveClick" />
                </Grid>
                <Button Content="Evolve Selected NPC Dialog" Click="OnEvolveSelectedNpcDialogClick" />
                <TextBlock Text="Faction Reputation" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <Grid ColumnDefinitions="*,80,80" ColumnSpacing="6">
                  <TextBox Text="{Binding SelectedFactionIdEditor}" Watermark="Faction id (e.g., guild_builders)" />
                  <Button Grid.Column="1" Content="+ Rep" Click="OnFactionRepIncreaseClick" />
                  <Button Grid.Column="2" Content="- Rep" Click="OnFactionRepDecreaseClick" />
                </Grid>
                <TextBox Text="{Binding ReputationDeltaEditor}" Watermark="Rep delta (default 5)" />
                <ScrollViewer MaxHeight="70">
                  <TextBlock Text="{Binding FactionStatusSummary}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                </ScrollViewer>
                <TextBlock Text="NPC Relationships" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="6">
                  <TextBox Text="{Binding SelectedRelationshipNpcId}" Watermark="NPC id" />
                  <Button Grid.Column="1" Content="Apply Relationship" Click="OnApplyRelationshipClick" />
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <TextBox Watermark="Trust" Text="{Binding RelationshipTrustEditor}" />
                  <TextBox Grid.Column="1" Watermark="Respect" Text="{Binding RelationshipRespectEditor}" />
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <TextBox Watermark="Grudge" Text="{Binding RelationshipGrudgeEditor}" />
                  <TextBox Grid.Column="1" Watermark="Debt" Text="{Binding RelationshipDebtEditor}" />
                </Grid>
                <TextBox Watermark="Loyalty" Text="{Binding RelationshipLoyaltyEditor}" />
                <ScrollViewer MaxHeight="78">
                  <TextBlock Text="{Binding RelationshipStatusSummary}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                </ScrollViewer>
                <TextBlock Text="Economy Snapshot" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <TextBlock Text="{Binding EconomySummary}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                <ScrollViewer MaxHeight="76">
                  <TextBlock Text="{Binding TradeRouteSummary}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                </ScrollViewer>
                <TextBlock Text="{Binding CoCreatorStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                <ComboBox ItemsSource="{Binding CoCreatorSuggestions}" SelectedItem="{Binding SelectedCoCreatorSuggestion}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="5" Padding="8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Why this fits your world right now" Foreground="#D6E9FF" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CoCreatorWhyThisFits}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <Button Content="Accept Suggestion" Click="OnAcceptCoCreatorSuggestionClick" />
                  <Button Grid.Column="1" Content="Reject Suggestion" Click="OnRejectCoCreatorSuggestionClick" />
                </Grid>
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsStoryTabActive}">
                <TextBlock Text="Story Bible + Campaign" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBlock Text="Lore (one line per item)" Foreground="#AFC2DF" FontSize="11" />
                <TextBox Text="{Binding StoryLoreEditor}" AcceptsReturn="True" MinHeight="54" />
                <TextBlock Text="Major NPCs (one line per item)" Foreground="#AFC2DF" FontSize="11" />
                <TextBox Text="{Binding StoryNpcEditor}" AcceptsReturn="True" MinHeight="54" />
                <TextBlock Text="Key Events + Faction Notes" Foreground="#AFC2DF" FontSize="11" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <TextBox Text="{Binding StoryEventsEditor}" AcceptsReturn="True" MinHeight="54" />
                  <TextBox Grid.Column="1" Text="{Binding StoryFactionNotesEditor}" AcceptsReturn="True" MinHeight="54" />
                </Grid>
                <Button Classes="system-action" Content="Save Story Bible" Click="OnSaveStoryBibleClick" />
                <TextBlock Text="Narrator (tutorial + key moments)" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <CheckBox Content="Narrator Enabled" IsChecked="{Binding NarratorEnabledEditor}" />
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                  <TextBlock VerticalAlignment="Center" Text="Voice" Foreground="#AFC2DF" />
                  <ComboBox Grid.Column="1" ItemsSource="{Binding NarratorVoiceOptions}" SelectedItem="{Binding NarratorVoiceEditor}" />
                </Grid>
                <Button Classes="system-action" Content="Save Narrator Settings" Click="OnSaveNarratorSettingsClick" />
                <TextBlock Text="Character Voice Profile (selected NPC)" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <TextBox Text="{Binding CharacterVoiceProfileIdEditor}" Watermark="profile id (e.g., blacksmith_gruff)" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <ComboBox ItemsSource="{Binding VoiceGenderOptions}" SelectedItem="{Binding CharacterVoiceGenderEditor}" />
                  <ComboBox Grid.Column="1" ItemsSource="{Binding VoiceBuildOptions}" SelectedItem="{Binding CharacterVoiceBuildEditor}" />
                </Grid>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <ComboBox ItemsSource="{Binding VoicePersonalityOptions}" SelectedItem="{Binding CharacterVoicePersonalityEditor}" />
                  <ComboBox Grid.Column="1" ItemsSource="{Binding VoiceStyleOptions}" SelectedItem="{Binding CharacterVoiceStyleEditor}" />
                </Grid>
                <TextBox Text="{Binding CharacterVoiceBaseVoiceEditor}" Watermark="base voice id (auto/default/en+f3/...)" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                  <TextBox Text="{Binding CharacterVoicePitchEditor}" Watermark="pitch (-50..50)" />
                  <TextBox Grid.Column="1" Text="{Binding CharacterVoiceRateEditor}" Watermark="rate (-40..40)" />
                  <TextBox Grid.Column="2" Text="{Binding CharacterVoiceVolumeEditor}" Watermark="volume (0.2..1.6)" />
                </Grid>
                <Button Content="Save Selected NPC Voice" Click="OnSaveSelectedNpcVoiceClick" />
                <TextBlock Text="Campaign Beat" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <TextBox Text="{Binding StoryBeatIdEditor}" Watermark="beat_id" />
                  <TextBox Grid.Column="1" Text="{Binding StoryBeatTitleEditor}" Watermark="Beat title" />
                </Grid>
                <TextBox Text="{Binding StoryBeatSummaryEditor}" Watermark="Beat summary" />
                <CheckBox Content="Beat Completed" IsChecked="{Binding StoryBeatCompletedEditor}" />
                <CheckBox Content="Generate cutscene on this beat" IsChecked="{Binding StoryBeatCutsceneTriggerEditor}" />
                <Button Content="Add / Update Beat" Click="OnUpsertStoryBeatClick" />
                <TextBlock Text="Campaign Beats (click to load into editor)" Foreground="#AFC2DF" FontSize="11" />
                <ComboBox ItemsSource="{Binding StoryBeats}" SelectionChanged="OnStoryBeatSelectionChanged">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="AI Story Beat Suggestions (requires explicit sign-off)" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <ComboBox ItemsSource="{Binding StoryBeatSuggestions}" SelectedItem="{Binding SelectedStoryBeatSuggestion}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <StackPanel>
                        <TextBlock Text="{Binding Label}" />
                        <TextBlock Text="{Binding WhyThisFits}" Foreground="#AFC2DF" FontSize="10" TextWrapping="Wrap" />
                      </StackPanel>
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                  <Button Content="Edit Suggestion" Click="OnEditStorySuggestionClick" />
                  <Button Grid.Column="1" Content="Accept Suggestion" Click="OnAcceptStorySuggestionClick" />
                  <Button Grid.Column="2" Content="Reject Suggestion" Click="OnRejectStorySuggestionClick" />
                </Grid>
                <TextBlock Text="Queue Story Event (with one ripple)" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <TextBox Text="{Binding StoryEventIdEditor}" Watermark="event_id" />
                  <TextBox Grid.Column="1" Text="{Binding StoryEventBeatIdEditor}" Watermark="beat_id" />
                </Grid>
                <TextBox Text="{Binding StoryEventTitleEditor}" Watermark="Event title" />
                <TextBox Text="{Binding StoryNarratorLineEditor}" Watermark="Narrator line (optional, for tutorials/key moments)" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                  <TextBox Text="{Binding StoryRippleTypeEditor}" Watermark="ripple type" />
                  <TextBox Grid.Column="1" Text="{Binding StoryRippleTargetEditor}" Watermark="target id" />
                  <TextBox Grid.Column="2" Text="{Binding StoryRippleValueEditor}" Watermark="value" />
                </Grid>
                <TextBox Text="{Binding StoryRippleDimensionEditor}" Watermark="dimension (relationship only)" />
                <Button Content="Queue Story Event" Click="OnQueueStoryEventClick" />
                <TextBlock Text="{Binding StoryStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
              </StackPanel>
            </Grid>
          </Border>

          <Expander Grid.Row="6" IsExpanded="False" HorizontalAlignment="Stretch">
            <Expander.Header>
              <TextBlock Text="Asset Browser" Foreground="#EEF4FF" FontSize="14" FontWeight="SemiBold" />
            </Expander.Header>
            <Border BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="Browse PNG/OBJ; drag a card into the viewport to place." Foreground="#A8A8A8" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap" />
                <Button Grid.Column="1" Content="Refresh" Click="OnRefreshAssetsClick" ToolTip.Tip="Reload imported assets from scene_scaffold.json." />
                <Button Grid.Column="2" Content="Import" Click="OnImportAssetClick" ToolTip.Tip="Import PNG or OBJ into the local asset browser&#x0a;Shortcut: Ctrl+I" />
              </Grid>
              <TextBox Grid.Row="1"
                       Watermark="Search assets..."
                       Text="{Binding AssetSearchText}"
                       ToolTip.Tip="Filter by asset name, id, or kind." />
              <ComboBox Grid.Row="2"
                        Width="124"
                        HorizontalAlignment="Left"
                        SelectedItem="{Binding SelectedAssetKindFilter}"
                        ItemsSource="{Binding AssetKindFilterOptions}"
                        ToolTip.Tip="Filter by PNG or OBJ." />
              <TextBlock Grid.Row="3" Text="Drag asset cards directly onto the viewport to place new props. A ghost preview follows your drop target." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="4" MaxHeight="184">
                <ItemsControl ItemsSource="{Binding FilteredImportedAssets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6"
                              Padding="8"
                              CornerRadius="6"
                              Classes="asset-card"
                              Tag="{Binding Id}"
                              PointerPressed="OnAssetChipPointerPressed"
                              ToolTip.Tip="Asset chip&#x0a;Drag into viewport to place as prop.">
                        <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="8">
                          <Border Width="48" Height="48" CornerRadius="6" Background="#0F2239" BorderBrush="#355B85" BorderThickness="1">
                            <Grid>
                              <Image Source="{Binding PreviewPath}" Stretch="UniformToFill" IsVisible="{Binding HasPreviewImage}" />
                              <TextBlock Text="{Binding ThumbnailGlyph}" IsVisible="{Binding HasNoPreviewImage}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D6E9FF" />
                            </Grid>
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding KindLabel}" Foreground="#8EA5C7" FontSize="11" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="⇢" Foreground="#9FC2E5" VerticalAlignment="Center" FontSize="16" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
              <Border Grid.Row="5" IsVisible="{Binding HasNoAssetResults}" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <TextBlock Text="No assets match this filter yet." Foreground="#8EA5C7" FontSize="11" />
              </Border>
              <Border Grid.Row="6" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Selected Asset Preview" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedImportedAssetName}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedImportedAssetKind, StringFormat=Kind: {0}}" Foreground="#8EA5C7" FontSize="11" />
                  <Image Height="72" Stretch="Uniform" Source="{Binding SelectedImportedAssetPreviewPath}" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>
          </Expander>

          <Border Grid.Row="7" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
              <StackPanel Spacing="2">
                <TextBlock Text="Scene Properties" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Text="Name, transform, tint, and asset preview for the current selection. Apply writes scene_scaffold.json."
                           Foreground="#8EA5C7"
                           FontSize="10"
                           TextWrapping="Wrap" />
              </StackPanel>
              <TextBlock Grid.Row="1" Text="{Binding SelectedEntitySummary}" Foreground="#C8D6EA" TextWrapping="Wrap" />
              <TextBox x:Name="SceneEntityNameTextBox" Grid.Row="2" Watermark="Entity Name (or mixed)" Text="{Binding SelectedEntityNameEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Selection name field&#x0a;Rename one entity or batch-label multi-select." />
              <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                <TextBlock Text="X" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="1" Text="{Binding SelectedEntityPositionXEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="X position (world units)." />
                <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="3" Text="{Binding SelectedEntityPositionYEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Y position (world units)." />
              </Grid>
              <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                <TextBlock Text="Scale" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="1" Text="{Binding SelectedEntityScaleEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Uniform scale multiplier." />
                <TextBlock Grid.Column="2" Text="Color" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="3" Text="{Binding SelectedEntityColorEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Tint color in hex, e.g. #4AA3FF." />
              </Grid>
              <Border Grid.Row="5" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Selection Asset Preview" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedEntityAssetName}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedEntityAssetKind, StringFormat=Kind: {0}}" Foreground="#8EA5C7" FontSize="11" />
                  <Image Height="64" Stretch="Uniform" Source="{Binding SelectedEntityAssetPreviewPath}" />
                  <Border Height="12" Background="{Binding SelectedEntityColorEditor}" CornerRadius="3" />
                </StackPanel>
              </Border>
              <Button Grid.Row="6" Content="✨ Apply Selection → Runtime" Command="{Binding ApplySelectionPropertiesCommand}" IsEnabled="{Binding HasSelection}" />
              <TextBlock Grid.Row="7" Text="Live viewport updates instantly. Apply commits to scene_scaffold.json + runtime relaunch." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
            </Grid>
          </Border>
        </Grid>
        </StackPanel>
        </ScrollViewer>
      </Border>

      <Button x:Name="LeftDockRevealer"
              Grid.Column="3"
              Classes="edge-revealer"
              HorizontalAlignment="Left"
              VerticalAlignment="Center"
              Margin="0,0,0,0"
              Click="OnShowLeftDockClick"
              IsVisible="False"
              ToolTip.Tip="Restore the left dock.">
        <TextBlock Text="{Binding ActiveLeftPanelTitle}" Classes="edge-revealer-label" />
      </Button>

      <Button x:Name="RightDockRevealer"
              Grid.Column="3"
              Classes="edge-revealer"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Click="OnShowRightDockClick"
              IsVisible="False"
              ToolTip.Tip="Restore the right dock.">
        <TextBlock Text="Inspector" Classes="edge-revealer-label" />
      </Button>
    </Grid>

    <GridSplitter x:Name="WorkspaceTimelineSplitter"
                  Grid.Row="2"
                  Height="4"
                  Background="{StaticResource SplitterBrush}"
                  ResizeDirection="Rows"
                  ResizeBehavior="PreviousAndNext"
                  ShowsPreview="True" />

    <Border x:Name="TimelineDockBorder" Grid.Row="3" Classes="panel-shell" Margin="0">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
          <TextBlock Text="🎞" FontSize="16" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1" Text="Timeline" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="2" Classes="timeline-icon" Content="{Binding TimelinePlayPauseGlyph}" Command="{Binding ToggleTimelinePlaybackCommand}" ToolTip.Tip="Play/Pause timeline preview" />
          <Button Grid.Column="3" Classes="timeline-icon" Content="⏮" Command="{Binding StopTimelinePlaybackCommand}" ToolTip.Tip="Stop and rewind timeline" />
          <Button Grid.Column="4" Classes="timeline-icon" Content="➕◇" Command="{Binding AddTimelineKeyframeCommand}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Add keyframe for selected entities" />
          <ToggleSwitch Grid.Column="5" Classes="deep-toggle" IsChecked="{Binding IsTimelineLooping}" />
          <Border Grid.Column="6" CornerRadius="8" Background="#133155" BorderBrush="#2A5D95" BorderThickness="1" Padding="8,2">
            <TextBlock Text="{Binding TimelinePlaybackStatePill}" Foreground="#D5E9FF" FontSize="11" FontWeight="SemiBold" />
          </Border>
          <Border Grid.Column="7" CornerRadius="8" Background="#132136" BorderBrush="#2B3A52" BorderThickness="1" Padding="8,2">
            <TextBlock Text="{Binding TimelinePlaybackHint}" Foreground="#AFC2DF" FontSize="11" />
          </Border>
          <TextBlock Grid.Column="8" Text="{Binding TimelineCurrentTimeLabel}" Foreground="#AFC2DF" VerticalAlignment="Center" />
          <TextBlock Grid.Column="9" Text="{Binding TimelineMode, StringFormat=Mode: {0}}" Foreground="#8EA5C7" VerticalAlignment="Center" />
          <Button Grid.Column="10" Content="Hide" Click="OnToggleTimelineDockClick" />
        </Grid>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <Button Classes="timeline-mode" Content="📍 Pos" Command="{Binding SetTimelineModeCommand}" CommandParameter="Position" />
            <Button Classes="timeline-mode" Content="🔳 Scale" Command="{Binding SetTimelineModeCommand}" CommandParameter="Scale" />
            <Button Classes="timeline-mode" Content="🎨 Color" Command="{Binding SetTimelineModeCommand}" CommandParameter="Color" />
            <TextBlock Text="{Binding TimelineStateLabel}" Foreground="#9FC2E5" FontSize="11" VerticalAlignment="Center" />
            <TextBlock Text="Keyframe Position / Scale / Color. Loop toggles one-shot vs looping."
                       Foreground="#8EA5C7"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="8,0,0,0" />
          </StackPanel>
        </ScrollViewer>

        <Slider Grid.Row="2"
                Minimum="0"
                Maximum="{Binding TimelineDurationSeconds}"
                Value="{Binding TimelineCurrentTime}"
                TickFrequency="0.25"
                IsSnapToTickEnabled="False" />

        <Border Grid.Row="3" Background="#0A111C" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="6">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding TimelineMarkers}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#13233A" BorderBrush="#2E4564" BorderThickness="1" CornerRadius="4" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="●" Foreground="#6FA8FF" IsVisible="{Binding IsActive}" />
                      <TextBlock Text="{Binding Icon}" />
                      <TextBlock Text="{Binding TimeLabel}" Foreground="#C8D6EA" FontSize="11" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,8,0,0">
          <TextBlock Text="🕘" FontSize="16" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1" Text="History" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="{Binding HistoryTimeline.Count, StringFormat=Steps: {0}}" Foreground="#8EA5C7" FontSize="11" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="5" MaxHeight="108" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding HistoryTimeline}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="history-chip"
                        Command="{Binding #RootWindow.DataContext.JumpToHistoryCommand}"
                        CommandParameter="{Binding Revision}">
                  <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                    <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding RevisionLabel}" Foreground="#8EA5C7" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Spacing="2">
                      <TextBlock Text="{Binding Description}" TextWrapping="NoWrap" />
                      <TextBlock Text="{Binding IsCurrent, StringFormat=Current: {0}}" Foreground="#6FA8FF" FontSize="10" IsVisible="{Binding IsCurrent}" />
                      <TextBlock Text="Future / Redo" Foreground="#7A8DAA" FontSize="10" IsVisible="{Binding IsFuture}" />
                    </StackPanel>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <GridSplitter x:Name="TimelineActivitySplitter"
                  Grid.Row="4"
                  Height="4"
                  Background="{StaticResource SplitterBrush}"
                  ResizeDirection="Rows"
                  ResizeBehavior="PreviousAndNext"
                  ShowsPreview="True" />

    <Border x:Name="ActivityDockBorder" Grid.Row="5" Classes="panel-shell" Margin="0" Padding="0">
      <TabControl Classes="editor-dock-tabs" TabStripPlacement="Top">
        <TabItem x:Name="AiInterviewDockTab" Header="AI Interview">
          <ContentControl x:Name="AiInterviewBottomHost">
          <Grid x:Name="AiInterviewPanelHost" Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
            <Grid Classes="panel-header" ColumnDefinitions="*,Auto,Auto">
              <StackPanel Spacing="2">
                <TextBlock Text="{Binding AiInterviewHeader}" Classes="panel-title" ToolTip.Tip="Structured AI interview for shaping the active project." />
                <TextBlock Text="Capture focused project direction step by step." Classes="panel-subtitle" />
              </StackPanel>
              <TextBlock Grid.Column="1" Text="{Binding AiInterviewProgressLabel}" Foreground="#8EA5C7" VerticalAlignment="Center" />
              <Button Grid.Column="2" Classes="panel-header-action" Content="⋯" ToolTip.Tip="AI Interview panel placement">
                <Button.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="Dock Left" IsEnabled="False" />
                    <MenuItem Header="Dock Right" Click="OnDockAiInterviewRightClick" />
                    <MenuItem Header="Dock Bottom" Click="OnDockAiInterviewBottomClick" />
                    <MenuItem Header="Float" Click="OnFloatAiInterviewClick" />
                    <MenuItem Header="Hide" Click="OnHideAiInterviewClick" />
                  </ContextMenu>
                </Button.ContextMenu>
              </Button>
            </Grid>
            <ProgressBar Grid.Row="1" Minimum="0" Maximum="{Binding AiInterviewProgressMaximum}" Value="{Binding AiInterviewProgressValue}" Height="8" />
            <Border Grid.Row="2" Classes="subpanel-shell" Padding="12">
              <TextBlock Text="{Binding AiInterviewQuestion}" Foreground="#EAF3FF" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
            </Border>
            <StackPanel Grid.Row="3" Spacing="10">
              <Button Classes="panel-action-button"
                      Content="Think of something"
                      HorizontalAlignment="Left"
                      Click="OnShowAiInterviewSuggestionsClick"
                      ToolTip.Tip="Show three suggestion cards to help unblock your answer." />
              <WrapPanel IsVisible="{Binding IsAiInterviewSuggestionsVisible}" ItemWidth="220" Orientation="Horizontal">
                <Button Classes="suggestion-card" Content="{Binding AiInterviewSuggestionOne}" Tag="{Binding AiInterviewSuggestionOne}" Click="OnAiInterviewSuggestionClick" Margin="0,0,8,8" />
                <Button Classes="suggestion-card" Content="{Binding AiInterviewSuggestionTwo}" Tag="{Binding AiInterviewSuggestionTwo}" Click="OnAiInterviewSuggestionClick" Margin="0,0,8,8" />
                <Button Classes="suggestion-card" Content="{Binding AiInterviewSuggestionThree}" Tag="{Binding AiInterviewSuggestionThree}" Click="OnAiInterviewSuggestionClick" Margin="0,0,8,8" />
              </WrapPanel>
            </StackPanel>
            <Grid Grid.Row="4" ColumnDefinitions="*,Auto" ColumnSpacing="10">
              <Border Classes="subpanel-shell" Padding="10">
                <TextBox Text="{Binding AiInterviewAnswer}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="116" Watermark="Write your answer here..." />
              </Border>
              <Button Grid.Column="1"
                      Classes="panel-action-button primary"
                      Content="Send"
                      VerticalAlignment="Bottom"
                      Click="OnSendAiInterviewAnswerClick"
                      ToolTip.Tip="Submit this answer. Shortcut: Ctrl+Enter" />
            </Grid>
            <ScrollViewer Grid.Row="5" VerticalScrollBarVisibility="Auto">
              <ItemsControl ItemsSource="{Binding AiInterviewHistory}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="subpanel-shell" Margin="0,0,0,10" Padding="0">
                      <Expander IsExpanded="False">
                        <Expander.Header>
                          <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8" Margin="10,8">
                            <Border Classes="badge" Padding="8,2">
                              <TextBlock Text="{Binding StepBadge}" Foreground="#DDEEFF" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{Binding Question}" Foreground="#D6E9FF" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                          </Grid>
                        </Expander.Header>
                        <StackPanel Margin="12,0,12,12" Spacing="8">
                          <TextBlock Text="Question" Foreground="#8EA5C7" FontSize="10" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Question}" Foreground="#D6E9FF" TextWrapping="Wrap" />
                          <TextBlock Text="Answer" Foreground="#8EA5C7" FontSize="10" FontWeight="SemiBold" />
                          <TextBlock Text="{Binding Answer}" Foreground="#CFE5FF" TextWrapping="Wrap" />
                          <TextBlock Text="{Binding FollowUp}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                        </StackPanel>
                      </Expander>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
          </ContentControl>
        </TabItem>
        <TabItem x:Name="AssetsDockTab" Header="Assets" IsVisible="False">
          <ContentControl x:Name="AssetsPanelBottomHost" Margin="4" />
        </TabItem>
        <TabItem x:Name="ActivityLogDockTab" Header="Activity Log" IsVisible="False">
          <ContentControl x:Name="ActivityLogBottomHost">
          <Grid x:Name="ActivityLogPanelHost" Margin="4" RowDefinitions="Auto,Auto,*" RowSpacing="8">
            <Grid Classes="panel-header" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="🧾" FontSize="16" VerticalAlignment="Center" />
              <TextBlock Grid.Column="1" Text="Activity Log" Classes="panel-title" VerticalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding PipelineProgress, StringFormat=Pipeline: {0}}" Foreground="#8EA5C7" FontSize="11" VerticalAlignment="Center" />
              <Button Grid.Column="3" Classes="panel-header-action" Content="Hide" Click="OnHideActivityLogClick" ToolTip.Tip="Hide the bottom activity log." />
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="{Binding StatusMessage}"
                       Foreground="#9FC2E5"
                       FontSize="11"
                       TextWrapping="Wrap" />
            <Border Grid.Row="2" Background="#0A111C" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8" MinHeight="96">
              <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding AiCommandLog}"
                           Foreground="#AFC2DF"
                           FontSize="11"
                           FontFamily="Consolas, Menlo, Monospace"
                           TextWrapping="Wrap" />
              </ScrollViewer>
            </Border>
          </Grid>
          </ContentControl>
        </TabItem>
      </TabControl>
    </Border>

    <Border Grid.Row="6" Classes="panel-shell" Padding="8,6" Margin="0" Background="#252525" BorderThickness="1,0,0,0">
      <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnSpacing="10">
        <Border Classes="badge">
          <TextBlock Text="{Binding SceneNameLabel}" Foreground="#EAF3FF" FontSize="11" FontWeight="SemiBold" />
        </Border>
        <Border Grid.Column="1" Classes="badge" Background="#16273F" BorderBrush="#4E7DB0">
          <TextBlock Text="{Binding SceneDirtyLabel}" Foreground="#DDEEFF" FontSize="11" FontWeight="SemiBold" />
        </Border>
        <TextBlock Grid.Column="2" Text="{Binding SceneValidationStatus}" Foreground="#AFC2DF" FontSize="11" VerticalAlignment="Center" />
        <TextBlock Grid.Column="3" Text="{Binding FpsStatusLabel}" Foreground="#AFC2DF" FontSize="11" VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="{Binding NpcCountStatusLabel}" Foreground="#AFC2DF" FontSize="11" VerticalAlignment="Center" />
      </Grid>
    </Border>

    <Border Grid.RowSpan="7"
            IsVisible="{Binding IsStatusToastVisible}"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,22,22,0"
            Width="360"
            Classes="toast-shell"
            Background="{Binding StatusToastBackground}"
            BorderBrush="{Binding StatusToastBorderBrush}"
            ZIndex="18">
      <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
        <TextBlock Text="{Binding StatusToastTitle}" Foreground="#F3F8FF" FontSize="12" FontWeight="Bold" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
          <Button Content="{Binding StatusToastActionLabel}"
                  Command="{Binding StatusToastActionCommand}"
                  IsVisible="{Binding IsStatusToastActionVisible}"
                  Background="{Binding StatusToastActionBackground}"
                  Foreground="#F3F8FF"
                  BorderBrush="{Binding StatusToastActionBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="10,4" />
          <Button Content="Dismiss"
                  Command="{Binding DismissStatusToastCommand}"
                  Background="#263C58"
                  Foreground="#D9E9FF"
                  BorderBrush="#466383"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="10,4" />
        </StackPanel>
        <TextBlock Grid.Row="1"
                   Grid.ColumnSpan="2"
                   Text="{Binding StatusToastMessage}"
                   Foreground="#E8F3FF"
                   FontSize="12"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />
        <TextBlock Grid.Row="2"
                   Grid.ColumnSpan="2"
                   Text="{Binding StatusToastGuidance}"
                   Foreground="{Binding StatusToastAccentBrush}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   IsVisible="{Binding IsStatusToastError}" />
      </Grid>
    </Border>

    <Border Grid.RowSpan="7"
            IsVisible="{Binding IsHelpOverlayVisible}"
            Background="#081120E8"
            BorderBrush="#4AA3FF"
            BorderThickness="1.2"
            CornerRadius="10"
            Padding="14"
            Margin="38,28"
            ZIndex="15">
      <StackPanel Spacing="8">
        <TextBlock Text="How to use (Alpha)" Foreground="#E8F3FF" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="1) File → New Scene or open a project, then use Generate / Play from the toolbar as needed. 2) Edit in the viewport (pan, zoom, select, drag entities). 3) File → Save Scene (Ctrl+S) and Open Scene (Ctrl+O)."
                   Foreground="#CFE5FF"
                   TextWrapping="Wrap" />
        <TextBlock Text="Ctrl+Shift+O opens the command palette for common actions. Selection strip by the canvas is a quick summary; Scene Properties in the Inspector has full fields."
                   Foreground="#A9CBF2"
                   TextWrapping="Wrap" />
        <TextBlock Text="Delete safety: press Delete twice within 2 seconds to confirm keyboard removal." Foreground="#A9CBF2" TextWrapping="Wrap" />
        <TextBlock Text="Autosave writes scene snapshots + active project file whenever scene/code changes are applied." Foreground="#A9CBF2" TextWrapping="Wrap" />
        <Button Content="Close Help" HorizontalAlignment="Left" Command="{Binding ToggleHelpOverlayCommand}" />
      </StackPanel>
    </Border>

    <Border x:Name="StartupOnboardingOverlay"
            Grid.RowSpan="7"
            IsVisible="False"
            Background="#070F1BEF"
            BorderBrush="#4AA3FF"
            BorderThickness="1.2"
            CornerRadius="10"
            Padding="18"
            Margin="40,28"
            ZIndex="20">
        <StackPanel Spacing="10" MaxWidth="720" HorizontalAlignment="Stretch" Margin="4,0">
        <TextBlock Text="Welcome to Soul Loom" Foreground="#E8F3FF" FontSize="24" FontWeight="Bold" />
        <TextBlock Text="Checking local model state before the welcome step. Quick Setup and Models &amp; LLM use the same status labels (Installed / Not found) and download progress overlay."
                   Foreground="#CFE5FF"
                   TextWrapping="Wrap" />
        <TextBlock x:Name="StartupOnboardingStatusText"
                   Text="Preparing first-launch check…"
                   Foreground="#9FCCFF"
                   FontSize="13"
                   TextWrapping="Wrap" />
        <ProgressBar x:Name="StartupOnboardingProgressBar"
                     IsIndeterminate="True"
                     Height="8"
                     Background="#0B1524"
                     Foreground="#4AA3FF" />
      </StackPanel>
    </Border>

    <Button x:Name="FocusModeExitButton"
            Grid.RowSpan="7"
            IsVisible="False"
            Content="Exit Focus"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,10,10,0"
            Padding="12,7"
            Background="#102742"
            BorderBrush="#5AAFFF"
            BorderThickness="1.2"
            Foreground="#E8F3FF"
            CornerRadius="8"
            ZIndex="23"
            Click="OnToggleFocusModeClick" />

    <Grid Grid.RowSpan="7"
          IsVisible="{Binding IsDownloadProgressVisible}"
          Background="#09111CF4"
          ZIndex="24">
      <Border HorizontalAlignment="Stretch"
              VerticalAlignment="Center"
              MinWidth="320"
              MaxWidth="760"
              Margin="28,24"
              Background="#0C1626"
              BorderBrush="#5AAFFF"
              BorderThickness="1.2"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding DownloadProgressTitle}" Foreground="#E8F3FF" FontSize="21" FontWeight="Bold" TextWrapping="Wrap" />
          <TextBlock Text="This may take a few minutes depending on your internet speed."
                     Foreground="#9FC2E5"
                     FontSize="12"
                     TextWrapping="Wrap" />
          <TextBlock Text="{Binding DownloadProgressSummary}" Foreground="#CFE5FF" FontSize="13" TextWrapping="Wrap" />
          <ProgressBar Height="10"
                       Minimum="0"
                       Maximum="100"
                       IsIndeterminate="{Binding IsDownloadProgressIndeterminate}"
                       Value="{Binding DownloadProgressPercent}"
                       Background="#0B1524"
                       Foreground="#4AA3FF" />
          <StackPanel Spacing="4">
            <TextBlock Text="{Binding DownloadProgressCurrentFile}" Foreground="#AFC2DF" TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="12">
              <TextBlock Text="{Binding DownloadProgressSpeed}" Foreground="#8EC9FF" />
              <TextBlock Text="{Binding DownloadProgressEta}" Foreground="#8EC9FF" />
            </StackPanel>
          </StackPanel>
          <Button Content="Cancel Download"
                  HorizontalAlignment="Left"
                  Click="OnCancelModelDownloadClick" />
        </StackPanel>
      </Border>
    </Grid>

    <Grid Grid.RowSpan="7"
          IsVisible="{Binding IsDownloadErrorVisible}"
          Background="#09111CF6"
          ZIndex="25">
      <Border HorizontalAlignment="Stretch"
              VerticalAlignment="Center"
              MinWidth="320"
              MaxWidth="760"
              Margin="28,24"
              Background="#1B1113"
              BorderBrush="#FF8A73"
              BorderThickness="1.2"
              CornerRadius="12"
              Padding="18">
        <StackPanel Spacing="10">
          <TextBlock Text="{Binding DownloadErrorTitle}" Foreground="#FFD9D1" FontSize="21" FontWeight="Bold" TextWrapping="Wrap" />
          <TextBlock Text="{Binding DownloadErrorMessage}" Foreground="#FFE5DD" FontSize="13" TextWrapping="Wrap" />
          <TextBlock Text="{Binding DownloadErrorGuidance}" Foreground="#FBCABF" FontSize="12" TextWrapping="Wrap" />
          <WrapPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Click="OnDismissModelErrorClick" Margin="0,0,8,8" />
            <Button Content="Open Models &amp; LLM" Click="OnOpenModelsAndLlmSettingsClick" Margin="0,0,8,8" />
            <Button Content="Retry"
                    Click="OnRetryModelOperationClick"
                    IsEnabled="{Binding IsModelErrorRetryEnabled}"
                    Margin="0,0,8,8" />
          </WrapPanel>
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.RowSpan="5"
            IsVisible="{Binding IsAssetBrowserDragPreviewVisible}"
            Margin="{Binding AssetBrowserDragPreviewMargin}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#11243B"
            BorderBrush="#4AA3FF"
            BorderThickness="1.5"
            CornerRadius="10"
            Padding="8"
            Opacity="0.95"
            ZIndex="10"
            IsHitTestVisible="False">
      <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="8" MinWidth="190">
        <Border Width="40" Height="40" CornerRadius="7" Background="#0F2239" BorderBrush="#355B85" BorderThickness="1">
          <Grid>
            <Image Source="{Binding AssetDragGhostPreviewPath}" Stretch="UniformToFill" IsVisible="{Binding AssetDragGhostHasPreviewImage}" />
            <TextBlock Text="{Binding AssetDragGhostGlyph}" IsVisible="{Binding AssetDragGhostHasNoPreviewImage}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D6E9FF" />
          </Grid>
        </Border>
        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
          <TextBlock Text="{Binding AssetDragGhostTitle}" Foreground="#E8F3FF" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="Drop into viewport to place" Foreground="#9FC2E5" FontSize="10" />
        </StackPanel>
        <Border Grid.Column="2" VerticalAlignment="Center" Background="#1B3654" CornerRadius="8" Padding="5,2">
          <TextBlock Text="{Binding AssetDragGhostKind}" Foreground="#D6E9FF" FontSize="10" />
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
