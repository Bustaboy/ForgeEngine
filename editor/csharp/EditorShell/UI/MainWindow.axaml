<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:vm="clr-namespace:GameForge.Editor.EditorShell.ViewModels"
        x:Name="RootWindow"
        x:Class="GameForge.Editor.EditorShell.UI.MainWindow"
        Title="GameForge Editor Shell"
        Width="1460"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Background="#080A0F"
        mc:Ignorable="d">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#12161F" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#2B3446" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4AA3FF" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.ribbon-icon">
      <Setter Property="Background" Value="#1A2232" />
      <Setter Property="BorderBrush" Value="#334257" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E5EDF7" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Width" Value="58" />
      <Setter Property="Height" Value="58" />
      <Setter Property="FontSize" Value="18" />
    </Style>

    <Style Selector="Button.generate-cta">
      <Setter Property="Background" Value="#1D6EE8" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="ToggleSwitch.deep-toggle">
      <Setter Property="OnContent" Value="On" />
      <Setter Property="OffContent" Value="Off" />
    </Style>

    <Style Selector="Button.history-chip">
      <Setter Property="Background" Value="#111929" />
      <Setter Property="BorderBrush" Value="#2B3A52" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#D6E6FA" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Button.timeline-icon">
      <Setter Property="Background" Value="#142033" />
      <Setter Property="BorderBrush" Value="#2B3A52" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E5EDF7" />
      <Setter Property="Padding" Value="10,8" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="MinWidth" Value="44" />
      <Setter Property="FontSize" Value="16" />
    </Style>

    <Style Selector="Button.timeline-mode">
      <Setter Property="Background" Value="#101A29" />
      <Setter Property="BorderBrush" Value="#2B3A52" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="#AFC2DF" />
      <Setter Property="Padding" Value="9,6" />
      <Setter Property="MinWidth" Value="54" />
    </Style>

    <Style Selector="Button.panel-tab">
      <Setter Property="Background" Value="#111A2A" />
      <Setter Property="BorderBrush" Value="#2B3A52" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#9FB7D8" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="MinWidth" Value="40" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.panel-tab.active">
      <Setter Property="Background" Value="#1D2D46" />
      <Setter Property="BorderBrush" Value="#4AA3FF" />
      <Setter Property="Foreground" Value="#EEF4FF" />
    </Style>

    <Style Selector="Border.asset-card">
      <Setter Property="Background" Value="#0B1524" />
      <Setter Property="BorderBrush" Value="#264566" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.asset-card:pointerover">
      <Setter Property="Background" Value="#12243A" />
      <Setter Property="BorderBrush" Value="#4AA3FF" />
      <Setter Property="BorderThickness" Value="1.4" />
    </Style>

    <Style Selector="TreeView#HierarchyTree TreeViewItem">
      <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
    </Style>
  </Window.Styles>
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+P" Command="{Binding PlayRuntimeCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,*,Auto,Auto,Auto" Margin="14" RowSpacing="12">
    <Border Grid.Row="0" Background="#0C1018" BorderBrush="#293349" BorderThickness="1" CornerRadius="10" Padding="12,10">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <StackPanel Orientation="Horizontal" Spacing="20">
          <StackPanel Spacing="5">
            <TextBlock Text="FILE" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="🆕" Click="OnNewProjectClick" ToolTip.Tip="New Project Wizard&#x0a;Start a local-first single-player project.&#x0a;Shortcut: Ctrl+N" />
              <Button Classes="ribbon-icon" Content="📂" Click="OnOpenProjectClick" ToolTip.Tip="Open Project (.gfproj.json)&#x0a;Load editor state from local project file." />
              <Button Classes="ribbon-icon" Content="💾" Click="OnSaveProjectClick" ToolTip.Tip="Save Project (.gfproj.json)&#x0a;Saves current editor session and prototype root.&#x0a;Shortcut: Ctrl+S" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="GENERATE" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="⚡" Click="OnGenerateFromBriefClick" ToolTip.Tip="Generate from Brief" />
              <Button Classes="ribbon-icon" Content="🤖" Click="OnGenerateAndPlayClick" ToolTip.Tip="Generate &amp; Play" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="RUNTIME" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="▶" Click="OnPlayRuntimeClick" ToolTip.Tip="Play Runtime&#x0a;Build and launch the Vulkan runtime preview.&#x0a;Shortcut: Ctrl+Shift+P" />
              <Button Classes="ribbon-icon" Content="⏹" ToolTip.Tip="Stop Runtime (placeholder)" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="TOOLS" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="🧩" ToolTip.Tip="Inspector Tools (placeholder)" Width="{Binding RibbonIconSize}" Height="{Binding RibbonIconSize}" />
              <Button Classes="ribbon-icon" Content="📊" ToolTip.Tip="Debug Console" />
              <Button Classes="ribbon-icon" Content="⚙" Click="OnOpenSettingsClick" ToolTip.Tip="Preferences &amp; Settings&#x0a;Tune autosave, theme, and runtime defaults with live preview.&#x0a;Shortcut: Ctrl+Shift+S" Width="{Binding RibbonIconSize}" Height="{Binding RibbonIconSize}" />
              <Button Classes="ribbon-icon" Content="❔" Command="{Binding ToggleHelpOverlayCommand}" ToolTip.Tip="How to use overlay&#x0a;Quick workflow hints for no-code-first editing." />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="EXPORT" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="📦" Click="OnOpenExportChecklistClick" ToolTip.Tip="Open Export + Publish Checklist" />
              <Button Classes="ribbon-icon" Content="🛠" Click="OnBuildInstallerClick" ToolTip.Tip="Build native installer (MSI / DEB / AppImage / DMG)" IsEnabled="{Binding CanRunInstallerBuild}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="{Binding ProjectFileStatusLabel}" VerticalAlignment="Center" Foreground="#9FC2E5" FontSize="12" />
          <TextBlock Text="{Binding AutosaveStatusLabel}" VerticalAlignment="Center" Foreground="#9FC2E5" FontSize="12" />
          <TextBlock Text="{Binding RuntimePreferencesSummary}" VerticalAlignment="Center" Foreground="#9FC2E5" FontSize="12" />
          <TextBlock Text="Code Mode" VerticalAlignment="Center" Foreground="#D2DEEE" FontSize="12" />
          <ToggleSwitch Classes="deep-toggle" IsChecked="{Binding IsCodeMode}" VerticalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="70,280,*,360" RowDefinitions="*" ColumnSpacing="12">
      <Border Grid.Column="0" Background="#0C1018" BorderBrush="#293349" BorderThickness="1" CornerRadius="10" Padding="8">
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="🖱" ToolTip.Tip="Select" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="✏" ToolTip.Tip="Paint" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="⬛" ToolTip.Tip="Terrain" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="💡" ToolTip.Tip="Lighting" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="🎥" ToolTip.Tip="Camera" />
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Background="#0C1018" BorderBrush="#293349" BorderThickness="1" CornerRadius="10" Padding="10">
        <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Border Background="#1D2D46" CornerRadius="7" Padding="8,5">
              <TextBlock Text="{Binding ActiveLeftPanelIcon}" FontSize="16" />
            </Border>
            <StackPanel Spacing="1">
              <TextBlock Text="{Binding ActiveLeftPanelTitle}" Foreground="#EEF4FF" FontWeight="SemiBold" />
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{Binding ActiveLeftPanelSubtitle}" Foreground="#8EA5C7" FontSize="11" />
                <TextBlock Text="{Binding HierarchyEntityCountBadge}" Foreground="#7EC0FF" FontSize="11" IsVisible="{Binding IsHierarchyTabActive}" />
                <TextBlock Text="{Binding HierarchySelectionBadge}" Foreground="#7EC0FF" FontSize="11" IsVisible="{Binding IsHierarchyTabActive}" />
              </StackPanel>
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
            <Button Classes="panel-tab active"
                    Content="🌲"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Hierarchy"
                    IsVisible="{Binding IsHierarchyTabActive}"
                    ToolTip.Tip="Hierarchy tab: entity tree and re-parenting." />
            <Button Classes="panel-tab"
                    Content="🌲"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Hierarchy"
                    IsVisible="{Binding IsHierarchyTabInactive}"
                    ToolTip.Tip="Hierarchy tab: entity tree and re-parenting." />
            <Button Classes="panel-tab active"
                    Content="🗂"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Assets"
                    IsVisible="{Binding IsAssetsTabActive}"
                    ToolTip.Tip="Assets tab: thumbnail browser with drag-to-viewport placement." />
            <Button Classes="panel-tab"
                    Content="🗂"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="Assets"
                    IsVisible="{Binding IsAssetsTabInactive}"
                    ToolTip.Tip="Assets tab: thumbnail browser with drag-to-viewport placement." />
            <Button Classes="panel-tab active"
                    Content="🕘"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="History"
                    IsVisible="{Binding IsHistoryTabActive}"
                    ToolTip.Tip="History tab (coming next): full timeline remains in the lower history panel." />
            <Button Classes="panel-tab"
                    Content="🕘"
                    Command="{Binding SetLeftPanelTabCommand}"
                    CommandParameter="History"
                    IsVisible="{Binding IsHistoryTabInactive}"
                    ToolTip.Tip="History tab (coming next): full timeline remains in the lower history panel." />
          </StackPanel>

          <Border Grid.Row="2"
                  IsVisible="{Binding IsHierarchyTabActive}"
                  Background="#0B1524"
                  BorderBrush="#2B3A52"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="8,6"
                  Margin="0,0,0,8"
                  VerticalAlignment="Top">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="6">
              <StackPanel Spacing="1">
                <TextBlock Text="🖱 Inspect • 🧲 drag selected entities onto a 🗂 group"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding HierarchyTreeSummary}"
                           Foreground="#6FA8FF"
                           FontSize="10" />
              </StackPanel>
              <Button Grid.Column="1"
                      Classes="panel-tab"
                      Content="⤢"
                      Command="{Binding ExpandHierarchyCommand}"
                      ToolTip.Tip="Expand all hierarchy nodes." />
              <Button Grid.Column="2"
                      Classes="panel-tab"
                      Content="⤡"
                      Command="{Binding CollapseHierarchyCommand}"
                      ToolTip.Tip="Collapse all hierarchy nodes." />
              <Button Grid.Column="3"
                      Classes="panel-tab"
                      Content="🗂 Create Group"
                      Command="{Binding CreateHierarchyGroupCommand}"
                      ToolTip.Tip="Create Group: add an empty hierarchy group entity for organizing scene objects." />
            </Grid>
          </Border>

          <TreeView Grid.Row="3"
                    Name="HierarchyTree"
                    ItemsSource="{Binding HierarchyRoots}"
                    SelectedItem="{Binding SelectedHierarchyNode}"
                    IsVisible="{Binding IsHierarchyTabActive}"
                    Background="#09111D"
                    BorderBrush="#2B3446"
                    BorderThickness="1"
                    Padding="8">
            <TreeView.ItemTemplate>
              <TreeDataTemplate DataType="vm:MainWindowViewModel+HierarchyNode" ItemsSource="{Binding Children}">
                <Border Padding="5,4" CornerRadius="5" Tag="{Binding EntityId}" PointerPressed="OnHierarchyNodePointerPressed" DragDrop.AllowDrop="True" DragDrop.Drop="OnHierarchyNodeDrop" DragDrop.DragOver="OnHierarchyNodeDragOver" ToolTip.Tip="Hierarchy item&#x0a;Click to select, drag to re-parent onto groups in scene tree.">
                  <StackPanel Orientation="Horizontal" Spacing="8">
                    <Border Background="#14243B"
                            BorderBrush="#36557E"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="4,2"
                            VerticalAlignment="Top">
                      <TextBlock Text="{Binding Icon}" Foreground="#D6E9FF" />
                    </Border>
                    <StackPanel Spacing="1">
                      <TextBlock Text="{Binding Label}" Foreground="#D6E9FF" />
                      <TextBlock Text="{Binding DetailText}"
                                 Foreground="#7FA2CD"
                                 FontSize="10"
                                 IsVisible="{Binding HasDetailText}" />
                    </StackPanel>
                  </StackPanel>
                  <Border.ContextMenu>
                    <ContextMenu>
                      <MenuItem Header="✏ Rename"
                                Tag="{Binding EntityId}"
                                Click="OnHierarchyRenameClick" />
                      <MenuItem Header="🗑 Delete"
                                Tag="{Binding EntityId}"
                                Click="OnHierarchyDeleteClick" />
                      <MenuItem Header="🧩 Ungroup / Detach"
                                Tag="{Binding EntityId}"
                                Click="OnHierarchyUngroupClick" />
                    </ContextMenu>
                  </Border.ContextMenu>
                </Border>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>

          <Border Grid.Row="3"
                  IsVisible="{Binding IsHierarchyTabActive}"
                  Background="#0B1524"
                  BorderBrush="#2B3A52"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="8,6"
                  Margin="8"
                  VerticalAlignment="Bottom"
                  DragDrop.AllowDrop="True"
                  DragDrop.Drop="OnHierarchyRootDrop"
                  DragDrop.DragOver="OnHierarchyNodeDragOver"
                  ToolTip.Tip="Drop any hierarchy entity here to move it to root.">
            <TextBlock Text="↥ Drop here to move entity to root"
                       Foreground="#8EA5C7"
                       FontSize="11"
                       HorizontalAlignment="Center" />
          </Border>

          <Border Grid.Row="3"
                  IsVisible="{Binding IsAssetsTabActive}"
                  Background="#09111D"
                  BorderBrush="#2B3446"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Text="🗂 Assets" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <StackPanel Grid.Column="1" Spacing="1" HorizontalAlignment="Right">
                  <TextBlock Text="{Binding AssetResultsSummary}"
                             Foreground="#8EA5C7"
                             FontSize="11"
                             HorizontalAlignment="Right" />
                  <TextBlock Text="{Binding AssetLastRefreshLabel}"
                             Foreground="#6FA8FF"
                             FontSize="10"
                             HorizontalAlignment="Right" />
                </StackPanel>
              </Grid>
              <Grid Grid.Row="1" ColumnDefinitions="*,110,Auto,Auto" ColumnSpacing="6">
                <TextBox Watermark="Search assets (name + type + id)"
                         Text="{Binding AssetSearchText}"
                         ToolTip.Tip="Search by name, kind, id, or import path." />
                <ComboBox Grid.Column="1"
                          SelectedItem="{Binding SelectedAssetKindFilter}"
                          ItemsSource="{Binding AssetKindFilterOptions}"
                          ToolTip.Tip="Filter assets by file type." />
                <Button Grid.Column="2" Content="Refresh Assets" Click="OnRefreshAssetsClick" />
                <Button Grid.Column="3" Content="Import…" Click="OnImportAssetClick" />
              </Grid>
              <TextBlock Grid.Row="2"
                         Text="Thumbnail-first browser: PNG previews + OBJ cards. Drag any card into the viewport to place an instance."
                         Foreground="#8EA5C7"
                         FontSize="11"
                         TextWrapping="Wrap" />
              <TextBlock Grid.Row="2"
                         Margin="0,18,0,0"
                         Text="{Binding AssetFilterSummaryLabel}"
                         Foreground="#6FA8FF"
                         FontSize="10"
                         FontWeight="SemiBold"
                         TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="3">
                <StackPanel Spacing="8">
                  <Border IsVisible="{Binding IsAssetBrowserDragPreviewVisible}"
                          Background="#11243B"
                          BorderBrush="#4AA3FF"
                          BorderThickness="1.4"
                          CornerRadius="8"
                          Padding="8"
                          Opacity="0.92">
                    <Grid ColumnDefinitions="50,*,Auto" ColumnSpacing="8">
                      <Border Width="48" Height="48" CornerRadius="8" Background="#0F2239" BorderBrush="#355B85" BorderThickness="1">
                        <Grid>
                          <Image Source="{Binding AssetDragGhostPreviewPath}" Stretch="UniformToFill" IsVisible="{Binding AssetDragGhostHasPreviewImage}" />
                          <TextBlock Text="{Binding AssetDragGhostGlyph}" IsVisible="{Binding AssetDragGhostHasNoPreviewImage}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D6E9FF" />
                        </Grid>
                      </Border>
                      <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="Ghost preview active" Foreground="#D6E9FF" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding AssetDragGhostTitle}" Foreground="#9FC2E5" FontSize="10" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                      <Border Grid.Column="2" VerticalAlignment="Center" Background="#1B3654" CornerRadius="9" Padding="5,1">
                        <TextBlock Text="{Binding AssetDragGhostKind}" Foreground="#D6E9FF" FontSize="10" />
                      </Border>
                    </Grid>
                  </Border>
                  <ItemsControl ItemsSource="{Binding FilteredImportedAssets}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" ItemWidth="118" ItemHeight="152" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Width="110"
                                Height="144"
                                Padding="8"
                                Margin="0,0,8,8"
                                CornerRadius="8"
                                Classes="asset-card"
                                Tag="{Binding Id}"
                                PointerPressed="OnAssetChipPointerPressed"
                                ToolTip.Tip="Drag to viewport"
                                Background="{Binding CardToneHex}"
                                BorderBrush="{Binding CardBorderHex}">
                          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="6">
                            <Border Width="92" Height="88" CornerRadius="6" Background="#0F2239" BorderBrush="#355B85" BorderThickness="1" HorizontalAlignment="Center">
                              <Grid>
                                <Image Source="{Binding PreviewPath}" Stretch="UniformToFill" IsVisible="{Binding HasPreviewImage}" />
                                <TextBlock Text="{Binding ThumbnailGlyph}"
                                           IsVisible="{Binding HasNoPreviewImage}"
                                           FontSize="28"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="#D6E9FF" />
                              </Grid>
                            </Border>
                            <Border Grid.Row="1"
                                    HorizontalAlignment="Center"
                                    Background="#1B3654"
                                    CornerRadius="10"
                                    Padding="6,2">
                              <TextBlock Text="{Binding ThumbnailBadge}" Foreground="#D6E9FF" FontSize="10" FontWeight="SemiBold" />
                            </Border>
                            <StackPanel Grid.Row="2" Spacing="2">
                              <TextBlock Text="{Binding DisplayName}"
                                         Foreground="#D6E9FF"
                                         FontSize="11"
                                         FontWeight="SemiBold"
                                         HorizontalAlignment="Center"
                                         TextAlignment="Center"
                                         MaxLines="2"
                                         TextTrimming="CharacterEllipsis" />
                              <TextBlock Text="{Binding KindLabel}"
                                         Foreground="#8EA5C7"
                                         FontSize="10"
                                         HorizontalAlignment="Center" />
                            </StackPanel>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Border IsVisible="{Binding HasNoAssetResults}" Padding="10" CornerRadius="6" BorderBrush="#264566" BorderThickness="1" Background="#0B1524">
                    <TextBlock Text="No assets match this filter yet." Foreground="#8EA5C7" FontSize="11" />
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </Grid>
          </Border>

          <Border Grid.Row="3"
                  IsVisible="{Binding IsHistoryTabActive}"
                  Background="#09111D"
                  BorderBrush="#2B3446"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="10">
            <StackPanel Spacing="6">
              <TextBlock Text="🕘 History tab is staged." Foreground="#D6E9FF" FontWeight="SemiBold" />
              <TextBlock Text="Undo/redo history remains active in the dedicated timeline panel below."
                         Foreground="#8EA5C7"
                         FontSize="11"
                         TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <Grid Grid.Column="2" RowDefinitions="*,220" RowSpacing="12">
        <Border Grid.Row="0" Background="#0A0D13" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12" IsVisible="{Binding IsViewportMode}">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="Scene Viewport" Foreground="#EEF4FF" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="+ 👤 Player" Command="{Binding AddPlayerEntityCommand}" ToolTip.Tip="Add Player entity and relaunch runtime" />
              <Button Grid.Column="2" Content="+ 🧍 NPC" Command="{Binding AddNpcEntityCommand}" ToolTip.Tip="Add NPC entity and relaunch runtime" />
              <Button Grid.Column="3" Content="+ 📦 Prop" Command="{Binding AddPropEntityCommand}" HorizontalAlignment="Left" ToolTip.Tip="Add Prop entity and relaunch runtime" />
              <Button Grid.Column="4" Content="↶ Undo" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" ToolTip.Tip="Undo latest scene change&#x0a;Shortcut: Ctrl+Z" />
              <Button Grid.Column="5" Content="↷ Redo" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" ToolTip.Tip="Redo reverted scene change&#x0a;Shortcut: Ctrl+Y" />
              <Button Grid.Column="6" Content="🗑" Command="{Binding DeleteSelectedEntityCommand}" ToolTip.Tip="Delete selected entity&#x0a;Shortcut: Delete&#x0a;Also available via marker right-click menu." />
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
              <Border Background="#12243A" BorderBrush="#2F4F77" BorderThickness="1" CornerRadius="6" Padding="8,3">
                <TextBlock Text="🖱 Drag" Foreground="#CFE5FF" FontSize="11" FontWeight="SemiBold" />
              </Border>
              <Border Background="#12243A" BorderBrush="#2F4F77" BorderThickness="1" CornerRadius="6" Padding="8,3">
                <TextBlock Text="✏ Double-click Edit" Foreground="#CFE5FF" FontSize="11" FontWeight="SemiBold" />
              </Border>
              <Border Background="#12243A" BorderBrush="#2F4F77" BorderThickness="1" CornerRadius="6" Padding="8,3">
                <TextBlock Text="🗑 Delete key / Menu" Foreground="#CFE5FF" FontSize="11" FontWeight="SemiBold" />
              </Border>
              <TextBlock Text="Undo/redo tracks add, move, and delete."
                         Foreground="#93A7C7"
                         FontSize="12"
                         VerticalAlignment="Center"
                         TextWrapping="Wrap" />
            </StackPanel>

            <Border Grid.Row="2" Background="#06080D" BorderBrush="#264566" BorderThickness="1" CornerRadius="8" Padding="10">
              <Grid ColumnDefinitions="2*,*" ColumnSpacing="12">
                <Border Background="#0B1220" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="8" Padding="10">
                  <Grid RowDefinitions="Auto,*" RowSpacing="8">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" ColumnSpacing="10">
                      <Border Background="#132235" CornerRadius="6" Padding="8,4">
                        <TextBlock Text="{Binding ViewportEntityCountLabel}" Foreground="#DCEBFF" FontSize="11" FontWeight="SemiBold" />
                      </Border>
                      <Border Grid.Column="1" Background="#0F2338" CornerRadius="6" Padding="7,4">
                        <TextBlock Text="{Binding ViewportRenderFrameLabel}" Foreground="#8FD2FF" FontSize="11" FontWeight="SemiBold" />
                      </Border>
                      <Border Grid.Column="2" Background="#122C4A" CornerRadius="6" Padding="7,4">
                        <TextBlock Text="■ Player" Foreground="#4AA3FF" FontSize="11" FontWeight="SemiBold" />
                      </Border>
                      <Border Grid.Column="3" Background="#162B1C" CornerRadius="6" Padding="7,4">
                        <TextBlock Text="■ NPC" Foreground="#65C97A" FontSize="11" FontWeight="SemiBold" />
                      </Border>
                      <Border Grid.Column="4" Background="#1D2330" CornerRadius="6" Padding="7,4" HorizontalAlignment="Left">
                        <TextBlock Text="■ Prop" Foreground="#9AA6BA" FontSize="11" FontWeight="SemiBold" />
                      </Border>
                      <ToggleSwitch Grid.Column="5"
                                    IsChecked="{Binding IsViewportEntityPreviewListVisible}"
                                    OnContent="List On"
                                    OffContent="List Off"
                                    Foreground="#AFC2DF"
                                    VerticalAlignment="Center"
                                    ToolTip.Tip="Toggle optional live entity preview list panel." />
                      <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                        <Border Background="#122B46" BorderBrush="#4AA3FF" BorderThickness="1" CornerRadius="6" Padding="7,3">
                          <TextBlock Text="{Binding ViewportSelectionStateLabel}" Foreground="#CFE7FF" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <Border Background="#16273F" BorderBrush="#5D9EE2" BorderThickness="1" CornerRadius="6" Padding="7,3" IsVisible="{Binding IsDirectPropertyEditActive}">
                          <TextBlock Text="{Binding DirectPropertyEditBadge}" Foreground="#DDF0FF" FontSize="10" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <TextBlock Text="{Binding ViewportLivePreviewLabel}" Foreground="#7FB4FF" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right" />
                      </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1">
                      <Canvas Name="ViewportCanvas" Background="#070B14" ClipToBounds="True" />
                      <Border IsVisible="{Binding IsViewportEmpty}" Background="#0B1322AA" CornerRadius="6" Padding="12,8" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="No entities in scene scaffold yet. Add entities or generate content to preview live." Foreground="#9FB7D8" FontSize="12" TextWrapping="Wrap" TextAlignment="Center" Width="320" />
                      </Border>
                      <TextBlock Text="Drag entities directly. Double-click for direct property edit. Right-click for quick actions. Ctrl+Click multi-select. Timeline playback and keyframes update this viewport renderer live."
                                 Foreground="#7F98BD"
                                 FontSize="11"
                                 Margin="6"
                                 VerticalAlignment="Top"
                                 HorizontalAlignment="Left" />
                    </Grid>
                  </Grid>
                </Border>

                <Border Grid.Column="1" Background="#0B1524" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="8" Padding="10">
                  <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
                    <TextBlock Text="Selection Inspector" Foreground="#EEF4FF" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="1" Text="{Binding SelectedEntitySummary}" Foreground="#C8D6EA" TextWrapping="Wrap" />
                    <TextBlock Grid.Row="2" Text="{Binding ViewportPlaybackSummary}" Foreground="#8FC2FF" FontSize="11" />
                    <ScrollViewer Grid.Row="3" MaxHeight="280">
                      <StackPanel Spacing="8">
                        <Border Background="#102038" CornerRadius="6" Padding="8,6">
                          <TextBlock Text="{Binding SelectionInteractionHint}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                        </Border>
                        <ItemsControl ItemsSource="{Binding ViewportEntities}" IsVisible="{Binding IsViewportEntityPreviewListVisible}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Background="#0F1B2E" BorderBrush="{Binding ListBorderBrush}" BorderThickness="1.2" CornerRadius="6" Padding="8,6" Margin="0,0,0,6">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                  <Border Width="{Binding RenderWidth}"
                                          Height="{Binding RenderHeight}"
                                          Background="{Binding RenderBrush}"
                                          BorderBrush="#D4E7FF"
                                          BorderThickness="1.2"
                                          CornerRadius="3"
                                          VerticalAlignment="Center" />
                                  <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="#E8F2FF" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding TypeBadge}" Foreground="#9BB4D6" FontSize="10" />
                                    <TextBlock Text="{Binding ParentBadge}" Foreground="#7FA2CD" FontSize="10" />
                                    <TextBlock Text="{Binding X, StringFormat=X {0:F2}}" Foreground="#8EA5C7" FontSize="10" />
                                  </StackPanel>
                                  <StackPanel Grid.Column="2" Spacing="1" HorizontalAlignment="Right">
                                    <Border Background="#1A2F4C" BorderBrush="#6FB8FF" BorderThickness="1" CornerRadius="8" Padding="6,1" HorizontalAlignment="Right" IsVisible="{Binding IsSelectionBadgeVisible}">
                                      <TextBlock Text="SELECTED" Foreground="#CFE7FF" FontSize="9" FontWeight="SemiBold" />
                                    </Border>
                                    <TextBlock Text="{Binding Y, StringFormat=Y {0:F2}}" Foreground="#8EA5C7" FontSize="10" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding Scale, StringFormat=S {0:F2}}" Foreground="#8EA5C7" FontSize="10" HorizontalAlignment="Right" />
                                    <TextBlock Text="{Binding RenderColorHex}" Foreground="#8EA5C7" FontSize="10" HorizontalAlignment="Right" />
                                  </StackPanel>
                                </Grid>
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="0" Background="#090B11" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12" IsVisible="{Binding IsCodeMode}">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="Code Mode — Runtime C++ Editor" Foreground="#EEF4FF" FontSize="16" FontWeight="SemiBold" />
              <Button Grid.Column="1" Content="Save &amp; Recompile" Click="OnSaveCodeClick" ToolTip.Tip="Save generated C++ edits, recompile, and relaunch runtime" />
            </Grid>
            <avaloniaEdit:TextEditor Grid.Row="1"
                                     Name="CodeEditor"
                                     Margin="0,10,0,0"
                                     FontFamily="Consolas, Menlo, Monospace"
                                     FontSize="14"
                                     ShowLineNumbers="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#06080D"
                                     Foreground="#D8E8FF" />
          </Grid>
        </Border>

        <Border Grid.Row="1" Background="#101722" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
            <TextBlock Text="Chat Co-Pilot" FontSize="18" FontWeight="Bold" Foreground="#EEF4FF" />

            <StackPanel Grid.Row="1" Spacing="8">
              <TextBlock Text="Describe Your Game" Foreground="#C8D6EA" FontSize="13" FontWeight="SemiBold" />
              <TextBox Text="{Binding ChatPrompt}" Height="96" AcceptsReturn="True" TextWrapping="Wrap" Watermark="A cozy single-player colony sim with light RPG progression..." />
              <Button Classes="generate-cta" Content="{Binding GenerateButtonLabel}" Click="OnGenerateAndPlayClick" IsEnabled="{Binding CanGenerate}" />
              <TextBlock Text="{Binding StatusMessage}" Foreground="#AFC2DF" TextWrapping="Wrap" FontSize="12" />
            </StackPanel>

            <Border Grid.Row="2"
                    IsVisible="{Binding IsStatusToastVisible}"
                    Background="#17304D"
                    BorderBrush="#3F6EA1"
                    BorderThickness="1.2"
                    CornerRadius="9"
                    Padding="12,10"
                    HorizontalAlignment="Stretch">
              <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="4">
                <TextBlock Text="{Binding StatusToastTitle}" Foreground="#F3F8FF" FontSize="12" FontWeight="Bold" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                  <Button Content="{Binding StatusToastActionLabel}"
                          Command="{Binding StatusToastActionCommand}"
                          IsVisible="{Binding IsStatusToastActionVisible}"
                          Background="#2B6CB0"
                          Foreground="#F3F8FF"
                          BorderBrush="#5A95D4"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10,4" />
                  <Button Content="Dismiss"
                          Command="{Binding DismissStatusToastCommand}"
                          Background="#263C58"
                          Foreground="#D9E9FF"
                          BorderBrush="#466383"
                          BorderThickness="1"
                          CornerRadius="6"
                          Padding="10,4" />
                </StackPanel>
                <TextBlock Grid.Row="1"
                           Grid.ColumnSpan="2"
                           Text="{Binding StatusToastMessage}"
                           Foreground="#E8F3FF"
                           FontSize="12"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Grid.Row="2"
                           Grid.ColumnSpan="2"
                           Text="{Binding StatusToastGuidance}"
                           Foreground="#9FCCFF"
                           FontSize="11"
                           TextWrapping="Wrap"
                           IsVisible="{Binding IsStatusToastError}" />
              </Grid>
            </Border>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Column="3" Background="#0C1018" BorderBrush="#293349" BorderThickness="1" CornerRadius="10" Padding="12">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
          <TextBlock Text="Properties Inspector" Foreground="#EEF4FF" FontSize="18" FontWeight="Bold" />
          <TextBlock Grid.Row="1" Text="Beginner-first defaults with optional professional depth." Foreground="#9DB0CC" TextWrapping="Wrap" />

          <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBlock Text="Advanced Inspector" Foreground="#D5E4F8" VerticalAlignment="Center" />
            <ToggleSwitch Grid.Column="1" Classes="deep-toggle" IsChecked="{Binding IsAdvancedInspectorEnabled}" ToolTip.Tip="Settings field&#x0a;Enable deeper entity/runtime controls for power users." />
          </Grid>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <TextBlock Text="Debug Console" Foreground="#D5E4F8" VerticalAlignment="Center" />
            <ToggleSwitch Grid.Column="1" Classes="deep-toggle" IsChecked="{Binding IsDebugConsoleEnabled}" ToolTip.Tip="Settings field&#x0a;Show runtime diagnostics and development logs." />
          </Grid>

          <Border Grid.Row="4" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" RowSpacing="8">
              <TextBlock Text="Runtime Preview" Foreground="#EEF4FF" FontSize="16" FontWeight="SemiBold" />
              <Border Grid.Row="1" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="8" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="🟢 Vulkan Runtime Live Feed" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding RuntimePreviewSummary}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding RuntimeSelectedEntityPreview}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <TextBlock Grid.Row="2" Text="Runtime Status" Foreground="#D5E4F8" FontWeight="SemiBold" />
              <TextBlock Grid.Row="3" Text="{Binding RuntimeLaunchStatus, StringFormat=Live in Vulkan status: {0}}" Foreground="#AFC2DF" />
              <TextBlock Grid.Row="4" Text="Generated Entity List (scene/scene_scaffold.json)" Foreground="#D5E4F8" FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="5" MaxHeight="140">
                <TextBlock Text="{Binding RuntimeEntityList}" Foreground="#AFC2DF" TextWrapping="Wrap" FontFamily="Consolas, Menlo, Monospace" />
              </ScrollViewer>
              <Button Grid.Row="6" Classes="generate-cta" Content="Relaunch Runtime" Click="OnPlayRuntimeClick" ToolTip.Tip="Rebuild generated runtime and relaunch generated_gameplay_runner" />
            </Grid>
          </Border>


          <Border Grid.Row="5"
                  BorderBrush="#2B3446"
                  BorderThickness="1"
                  Background="#101722"
                  CornerRadius="8"
                  Padding="10"
                  IsVisible="{Binding IsExportChecklistVisible}">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="8">
              <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                <TextBlock Text="🚀" FontSize="16" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="Export + Publish Checklist" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
                <TextBlock Grid.Column="2" Text="{Binding ExportChecklistProgressPercent, StringFormat={}{0}%}" Foreground="#6FA8FF" FontWeight="Bold" VerticalAlignment="Center" />
              </Grid>
              <TextBlock Grid.Row="1"
                         Text="{Binding ExportStatus}"
                         Foreground="#AFC2DF"
                         FontSize="11"
                         TextWrapping="Wrap" />
              <ProgressBar Grid.Row="2"
                           Minimum="0"
                           Maximum="{Binding ExportChecklistTotalCount}"
                           Value="{Binding ExportChecklistCompletedCount}"
                           Height="7"
                           Background="#0B1524"
                           Foreground="#4AA3FF" />
              <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="6">
                <TextBlock Text="🚦" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding SteamReadinessSummary}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                <Border Grid.Column="2" Background="#2D3E5C" CornerRadius="10" Padding="6,2" IsVisible="{Binding HasSteamReadinessWarnings}">
                  <TextBlock Text="Warnings" Foreground="#FFD27D" FontSize="10" FontWeight="SemiBold" />
                </Border>
              </Grid>
              <TextBlock Grid.Row="4"
                         Text="{Binding SteamReadinessWarnings}"
                         Foreground="#8EA5C7"
                         FontSize="10"
                         TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="5" MaxHeight="128">
                <ItemsControl ItemsSource="{Binding ExportChecklistItems}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6"
                              Padding="8"
                              CornerRadius="6"
                              Background="#0B1524"
                              BorderBrush="#264566"
                              BorderThickness="1"
                              ToolTip.Tip="{Binding Tooltip}">
                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1" Text="{Binding ProgressIcon}" Foreground="#D6E9FF" VerticalAlignment="Center" />
                          <StackPanel Grid.Column="2" Spacing="1">
                            <TextBlock Text="{Binding Label}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Status}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                          </StackPanel>
                          <TextBlock Grid.Column="3" Text="{Binding SeverityIcon}" FontSize="13" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
              <Grid Grid.Row="6" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto,Auto" RowSpacing="6" ColumnSpacing="8">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                  <TextBlock Text="Progress:" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="{Binding ExportChecklistCompletedCount}" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="/" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="{Binding ExportChecklistTotalCount}" Foreground="#9FC2E5" FontSize="11" />
                  <TextBlock Text="steps complete" Foreground="#9FC2E5" FontSize="11" />
                </StackPanel>
                <Button Grid.Column="1" Content="⚙ Run Export" Click="OnRunExportChecklistClick" />
                <Button Grid.Column="2" Content="📁 Open Folder" Click="OnOpenExportFolderClick" IsEnabled="{Binding HasExportFolderOutput}" />

                <TextBlock Grid.Row="1"
                           Text="{Binding ExportFolderPath, StringFormat=Folder: {0}}"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />

                <TextBlock Grid.Row="2"
                           Text="{Binding ExportPackagePath, StringFormat=ZIP: {0}}"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button Grid.Row="2" Grid.Column="2" Content="⬇ Download ZIP" Click="OnOpenExportZipClick" IsEnabled="{Binding HasExportPackageOutput}" />
                <Button Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Content="🛰 Publish to Steam (Dry-Run)" Click="OnPublishToSteamClick" ToolTip.Tip="Runs publish gate + local audit trail only. No upload yet." />
                <TextBlock Grid.Row="4" Grid.ColumnSpan="3" Text="{Binding PublishDryRunStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                <TextBlock Grid.Row="5" Text="Steam Release Notes" Foreground="#9FC2E5" FontSize="11" VerticalAlignment="Center" />
                <TextBox Grid.Row="5"
                         Grid.Column="1"
                         Grid.ColumnSpan="2"
                         Text="{Binding SteamReleaseNotes}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="72"
                         Watermark="Describe this release for Steam store copy and patch notes..." />
                <Button Grid.Row="6"
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        Content="☁️ Upload to Steam (Stub)"
                        Click="OnUploadToSteamStubClick"
                        IsEnabled="{Binding CanRunSteamUploadStub}"
                        ToolTip.Tip="Generates upload ZIP + audit trail and simulates upload progress. No real Steam API calls." />
                <ProgressBar Grid.Row="7"
                             Grid.ColumnSpan="3"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding SteamUploadProgressPercent}"
                             Height="7"
                             Background="#0B1524"
                             Foreground="#6FA8FF" />
                <TextBlock Grid.Row="8"
                           Grid.ColumnSpan="3"
                           Text="{Binding SteamUploadStatus}"
                           Foreground="#8EA5C7"
                           FontSize="11"
                           TextWrapping="Wrap" />
                <Border Grid.Row="9"
                        Grid.ColumnSpan="3"
                        BorderBrush="#264566"
                        BorderThickness="1"
                        Background="#0B1524"
                        CornerRadius="6"
                        Padding="8">
                  <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="6">
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                      <TextBlock Text="🛠" VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1" Text="Installer Builder" Foreground="#D6E9FF" FontWeight="SemiBold" VerticalAlignment="Center" />
                      <Button Grid.Column="2" Content="Build Installer" Click="OnBuildInstallerClick" IsEnabled="{Binding CanRunInstallerBuild}" />
                      <Button Grid.Column="3" Content="Open Installer" Click="OnOpenInstallerOutputClick" IsEnabled="{Binding HasInstallerOutput}" />
                    </Grid>
                    <ProgressBar Grid.Row="1"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding InstallerBuildProgressPercent}"
                                 Height="7"
                                 Background="#09111D"
                                 Foreground="#4AA3FF" />
                    <TextBlock Grid.Row="2"
                               Text="{Binding InstallerBuildStatus}"
                               Foreground="#9FC2E5"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <TextBlock Grid.Row="3"
                               Text="{Binding InstallerOutputPath, StringFormat=Installer output: {0}}"
                               Foreground="#8EA5C7"
                               FontSize="11"
                               TextWrapping="Wrap" />
                    <ScrollViewer Grid.Row="4" MaxHeight="72" VerticalScrollBarVisibility="Auto">
                      <TextBlock Text="{Binding InstallerBuildLog}"
                                 Foreground="#7FA6CF"
                                 FontSize="10"
                                 FontFamily="Consolas, Menlo, Monospace"
                                 TextWrapping="Wrap" />
                    </ScrollViewer>
                  </Grid>
                </Border>
              </Grid>
            </Grid>
          </Border>


          <Border Grid.Row="8" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,*" RowSpacing="8">
              <TextBlock Text="🧠 Scene Systems + AI" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
              <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
                <Button Classes="panel-tab" Content="🌗" Click="OnSystemTabClick" Tag="DayNight" />
                <Button Classes="panel-tab" Content="🏠" Click="OnSystemTabClick" Tag="Buildings" />
                <Button Classes="panel-tab" Content="🎒" Click="OnSystemTabClick" Tag="InventoryRecipes" />
                <Button Classes="panel-tab" Content="💬" Click="OnSystemTabClick" Tag="Dialogs" />
                <Button Classes="panel-tab" Content="🤖" Click="OnSystemTabClick" Tag="AI" />
                <Button Classes="panel-tab" Content="🧠" Click="OnSystemTabClick" Tag="CoCreator" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsDayNightTabActive}">
                <TextBlock Text="Day/Night Cycle" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Speed" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding DayCycleSpeedEditor}" />
                  <TextBlock Grid.Column="2" Text="Progress" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding DayProgressEditor}" />
                  <TextBlock Grid.Column="4" Text="Day" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="5" Text="{Binding DayCountEditor}" />
                </Grid>
                <Button Content="Apply Day/Night" Click="OnApplyDayNightClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsBuildingsTabActive}">
                <TextBlock Text="Buildable Entities" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding BuildableEntities}" SelectedItem="{Binding SelectedBuildableEntity}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="6">
                  <TextBlock Text="Type" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="1" Text="{Binding SelectedBuildableType}" />
                  <TextBlock Grid.Column="2" Text="Grid X" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="3" Text="{Binding SelectedBuildableGridX}" />
                  <TextBlock Grid.Column="4" Text="Grid Y" Foreground="#AFC2DF" VerticalAlignment="Center" />
                  <TextBox Grid.Column="5" Text="{Binding SelectedBuildableGridY}" />
                </Grid>
                <Button Content="Apply Buildable" Click="OnApplyBuildableClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsInventoryRecipesTabActive}">
                <TextBlock Text="Inventory + Recipes" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBlock Text="{Binding PlayerInventorySummary, StringFormat=Player: {0}}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <TextBox Watermark="Recipe Name" Text="{Binding RecipeNameEditor}" />
                  <TextBox Grid.Column="1" Watermark="inputs csv (wood:2,stone:1)" Text="{Binding RecipeInputsEditor}" />
                </Grid>
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6">
                  <TextBox Watermark="Output Item" Text="{Binding RecipeOutputEditor}" />
                  <TextBox Grid.Column="1" Width="70" Text="{Binding RecipeQuantityEditor}" />
                  <Button Grid.Column="2" Content="Add/Update" Click="OnAddRecipeClick" />
                </Grid>
                <ItemsControl ItemsSource="{Binding Recipes}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="5" Padding="6" Margin="0,0,0,4">
                        <TextBlock Text="{Binding Name}" Foreground="#AFC2DF" />
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsDialogsTabActive}">
                <TextBlock Text="NPC Dialog Draft" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <ComboBox ItemsSource="{Binding DialogNpcs}" SelectedItem="{Binding SelectedDialogNpc}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBox Watermark="Start Node" Text="{Binding DialogStartNodeEditor}" />
                <TextBox Watermark="Node Id" Text="{Binding DialogNodeIdEditor}" />
                <TextBox Watermark="Node Text" Text="{Binding DialogNodeTextEditor}" />
                <TextBox Watermark="Choice Text" Text="{Binding DialogChoiceTextEditor}" />
                <TextBox Watermark="Choice Next Node" Text="{Binding DialogChoiceNextNodeEditor}" />
                <Button Content="Apply Dialog Draft" Click="OnApplyDialogDraftClick" />
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsAiTabActive}">
                <TextBlock Text="Python AI Orchestration" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBox Text="{Binding AiPromptEditor}" Watermark="Modify Scene with Prompt" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                  <Button Content="Generate NPC" Click="OnGenerateNpcClick" />
                  <Button Grid.Column="1" Content="Add 3 Houses" Click="OnAdd3HousesClick" />
                  <Button Grid.Column="2" Content="Modify Scene" Click="OnModifyScenePromptClick" />
                </Grid>
                <ScrollViewer MaxHeight="84">
                  <TextBlock Text="{Binding AiCommandLog}" Foreground="#8EA5C7" FontFamily="Consolas, Menlo, Monospace" FontSize="10" TextWrapping="Wrap" />
                </ScrollViewer>
              </StackPanel>

              <StackPanel Grid.Row="2" Spacing="6" IsVisible="{Binding IsCoCreatorTabActive}">
                <TextBlock Text="AI Co-Creator Live" Foreground="#D6E9FF" FontWeight="SemiBold" />
                <TextBox Text="{Binding BiomeEditor}" Watermark="Biome (e.g., desert, tundra, temperate)" />
                <TextBox Text="{Binding WorldStyleGuideEditor}" Watermark="World style guide for narrative + visual tone" />
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                  <Button Content="Save Context" Click="OnSaveCoCreatorContextClick" />
                  <Button Grid.Column="1" Content="Refresh Suggestions" Click="OnRefreshCoCreatorClick" />
                  <Button Grid.Column="2" Content="Toggle Live" Click="OnToggleCoCreatorLiveClick" />
                </Grid>
                <Button Content="Evolve Selected NPC Dialog" Click="OnEvolveSelectedNpcDialogClick" />
                <TextBlock Text="Faction Reputation" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <Grid ColumnDefinitions="*,80,80" ColumnSpacing="6">
                  <TextBox Text="{Binding SelectedFactionIdEditor}" Watermark="Faction id (e.g., guild_builders)" />
                  <Button Grid.Column="1" Content="+ Rep" Click="OnFactionRepIncreaseClick" />
                  <Button Grid.Column="2" Content="- Rep" Click="OnFactionRepDecreaseClick" />
                </Grid>
                <TextBox Text="{Binding ReputationDeltaEditor}" Watermark="Rep delta (default 5)" />
                <ScrollViewer MaxHeight="70">
                  <TextBlock Text="{Binding FactionStatusSummary}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                </ScrollViewer>
                <TextBlock Text="Economy Snapshot" Foreground="#D6E9FF" FontWeight="SemiBold" Margin="0,4,0,0" />
                <TextBlock Text="{Binding EconomySummary}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                <ScrollViewer MaxHeight="76">
                  <TextBlock Text="{Binding TradeRouteSummary}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                </ScrollViewer>
                <TextBlock Text="{Binding CoCreatorStatus}" Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                <ComboBox ItemsSource="{Binding CoCreatorSuggestions}" SelectedItem="{Binding SelectedCoCreatorSuggestion}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" TextWrapping="Wrap" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
                <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="5" Padding="8">
                  <StackPanel Spacing="4">
                    <TextBlock Text="Why this fits your world right now" Foreground="#D6E9FF" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding CoCreatorWhyThisFits}" Foreground="#AFC2DF" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="6">
                  <Button Content="Accept Suggestion" Click="OnAcceptCoCreatorSuggestionClick" />
                  <Button Grid.Column="1" Content="Reject Suggestion" Click="OnRejectCoCreatorSuggestionClick" />
                </Grid>
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Row="6" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto" RowSpacing="8">
              <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <TextBlock Text="🗂 Asset Browser" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
                <Button Grid.Column="1" Content="Refresh Assets" Click="OnRefreshAssetsClick" ToolTip.Tip="Reload imported assets from scene_scaffold.json." />
                <Button Grid.Column="2" Content="Import Asset" Click="OnImportAssetClick" ToolTip.Tip="Import PNG or OBJ into the local asset browser&#x0a;Shortcut: Ctrl+I" />
              </Grid>
              <TextBox Grid.Row="1"
                       Watermark="Search assets..."
                       Text="{Binding AssetSearchText}"
                       ToolTip.Tip="Filter by asset name, id, or kind." />
              <ComboBox Grid.Row="2"
                        Width="124"
                        HorizontalAlignment="Left"
                        SelectedItem="{Binding SelectedAssetKindFilter}"
                        ItemsSource="{Binding AssetKindFilterOptions}"
                        ToolTip.Tip="Filter by PNG or OBJ." />
              <TextBlock Grid.Row="3" Text="Drag asset cards directly onto the viewport to place new props. A ghost preview follows your drop target." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="4" MaxHeight="184">
                <ItemsControl ItemsSource="{Binding FilteredImportedAssets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6"
                              Padding="8"
                              CornerRadius="6"
                              Classes="asset-card"
                              Tag="{Binding Id}"
                              PointerPressed="OnAssetChipPointerPressed"
                              ToolTip.Tip="Asset chip&#x0a;Drag into viewport to place as prop.">
                        <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="8">
                          <Border Width="48" Height="48" CornerRadius="6" Background="#0F2239" BorderBrush="#355B85" BorderThickness="1">
                            <Grid>
                              <Image Source="{Binding PreviewPath}" Stretch="UniformToFill" IsVisible="{Binding HasPreviewImage}" />
                              <TextBlock Text="{Binding ThumbnailGlyph}" IsVisible="{Binding HasNoPreviewImage}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D6E9FF" />
                            </Grid>
                          </Border>
                          <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding KindLabel}" Foreground="#8EA5C7" FontSize="11" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="⇢" Foreground="#9FC2E5" VerticalAlignment="Center" FontSize="16" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
              <Border Grid.Row="5" IsVisible="{Binding HasNoAssetResults}" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <TextBlock Text="No assets match this filter yet." Foreground="#8EA5C7" FontSize="11" />
              </Border>
              <Border Grid.Row="6" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Selected Asset Preview" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedImportedAssetName}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedImportedAssetKind, StringFormat=Kind: {0}}" Foreground="#8EA5C7" FontSize="11" />
                  <Image Height="72" Stretch="Uniform" Source="{Binding SelectedImportedAssetPreviewPath}" />
                </StackPanel>
              </Border>
            </Grid>
          </Border>

          <Border Grid.Row="7" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
              <TextBlock Text="🎛 Scene Properties" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
              <TextBlock Grid.Row="1" Text="{Binding SelectedEntitySummary}" Foreground="#C8D6EA" TextWrapping="Wrap" />
              <TextBox x:Name="SceneEntityNameTextBox" Grid.Row="2" Watermark="Entity Name (or mixed)" Text="{Binding SelectedEntityNameEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Selection name field&#x0a;Rename one entity or batch-label multi-select." />
              <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                <TextBlock Text="X" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="1" Text="{Binding SelectedEntityPositionXEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="X position (world units)." />
                <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="3" Text="{Binding SelectedEntityPositionYEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Y position (world units)." />
              </Grid>
              <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                <TextBlock Text="Scale" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="1" Text="{Binding SelectedEntityScaleEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Uniform scale multiplier." />
                <TextBlock Grid.Column="2" Text="Color" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="3" Text="{Binding SelectedEntityColorEditor, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Tint color in hex, e.g. #4AA3FF." />
              </Grid>
              <Border Grid.Row="5" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Selection Asset Preview" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedEntityAssetName}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedEntityAssetKind, StringFormat=Kind: {0}}" Foreground="#8EA5C7" FontSize="11" />
                  <Image Height="64" Stretch="Uniform" Source="{Binding SelectedEntityAssetPreviewPath}" />
                  <Border Height="12" Background="{Binding SelectedEntityColorEditor}" CornerRadius="3" />
                </StackPanel>
              </Border>
              <Button Grid.Row="6" Content="✨ Apply Selection → Runtime" Command="{Binding ApplySelectionPropertiesCommand}" IsEnabled="{Binding HasSelection}" />
              <TextBlock Grid.Row="7" Text="Live viewport updates instantly. Apply commits to scene_scaffold.json + runtime relaunch." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#0C1018" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8">
          <TextBlock Text="🎞" FontSize="16" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1" Text="Timeline" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="2" Classes="timeline-icon" Content="{Binding TimelinePlayPauseGlyph}" Command="{Binding ToggleTimelinePlaybackCommand}" ToolTip.Tip="Play/Pause timeline preview" />
          <Button Grid.Column="3" Classes="timeline-icon" Content="⏮" Command="{Binding StopTimelinePlaybackCommand}" ToolTip.Tip="Stop and rewind timeline" />
          <Button Grid.Column="4" Classes="timeline-icon" Content="➕◇" Command="{Binding AddTimelineKeyframeCommand}" IsEnabled="{Binding HasSelection}" ToolTip.Tip="Add keyframe for selected entities" />
          <ToggleSwitch Grid.Column="5" Classes="deep-toggle" IsChecked="{Binding IsTimelineLooping}" />
          <Border Grid.Column="6" CornerRadius="8" Background="#133155" BorderBrush="#2A5D95" BorderThickness="1" Padding="8,2">
            <TextBlock Text="{Binding TimelinePlaybackStatePill}" Foreground="#D5E9FF" FontSize="11" FontWeight="SemiBold" />
          </Border>
          <Border Grid.Column="7" CornerRadius="8" Background="#132136" BorderBrush="#2B3A52" BorderThickness="1" Padding="8,2">
            <TextBlock Text="{Binding TimelinePlaybackHint}" Foreground="#AFC2DF" FontSize="11" />
          </Border>
          <TextBlock Grid.Column="8" Text="{Binding TimelineCurrentTimeLabel}" Foreground="#AFC2DF" VerticalAlignment="Center" />
          <TextBlock Grid.Column="9" Text="{Binding TimelineMode, StringFormat=Mode: {0}}" Foreground="#8EA5C7" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
          <Button Classes="timeline-mode" Content="📍 Pos" Command="{Binding SetTimelineModeCommand}" CommandParameter="Position" />
          <Button Classes="timeline-mode" Content="🔳 Scale" Command="{Binding SetTimelineModeCommand}" CommandParameter="Scale" />
          <Button Classes="timeline-mode" Content="🎨 Color" Command="{Binding SetTimelineModeCommand}" CommandParameter="Color" />
          <TextBlock Text="{Binding TimelineStateLabel}" Foreground="#9FC2E5" FontSize="11" VerticalAlignment="Center" />
          <TextBlock Text="Keyframe Position / Scale / Color. Loop toggle controls one-shot vs looping preview."
                     Foreground="#8EA5C7"
                     FontSize="11"
                     VerticalAlignment="Center"
                     Margin="8,0,0,0" />
        </StackPanel>

        <Slider Grid.Row="2"
                Minimum="0"
                Maximum="{Binding TimelineDurationSeconds}"
                Value="{Binding TimelineCurrentTime}"
                TickFrequency="0.25"
                IsSnapToTickEnabled="False" />

        <Border Grid.Row="3" Background="#0A111C" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="6">
          <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding TimelineMarkers}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="4" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Background="#13233A" BorderBrush="#2E4564" BorderThickness="1" CornerRadius="4" Padding="6,4">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                      <TextBlock Text="●" Foreground="#6FA8FF" IsVisible="{Binding IsActive}" />
                      <TextBlock Text="{Binding Icon}" />
                      <TextBlock Text="{Binding TimeLabel}" Foreground="#C8D6EA" FontSize="11" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Border>

        <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10" Margin="0,8,0,0">
          <TextBlock Text="🕘" FontSize="16" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1" Text="History" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="{Binding HistoryTimeline.Count, StringFormat=Steps: {0}}" Foreground="#8EA5C7" FontSize="11" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="5" MaxHeight="108" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding HistoryTimeline}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="history-chip"
                        Command="{Binding #RootWindow.DataContext.JumpToHistoryCommand}"
                        CommandParameter="{Binding Revision}">
                  <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                    <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding RevisionLabel}" Foreground="#8EA5C7" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Spacing="2">
                      <TextBlock Text="{Binding Description}" TextWrapping="NoWrap" />
                      <TextBlock Text="{Binding IsCurrent, StringFormat=Current: {0}}" Foreground="#6FA8FF" FontSize="10" IsVisible="{Binding IsCurrent}" />
                      <TextBlock Text="Future / Redo" Foreground="#7A8DAA" FontSize="10" IsVisible="{Binding IsFuture}" />
                    </StackPanel>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="3" Background="#0C1018" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12">
      <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
        <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto" ColumnSpacing="8">
          <TextBlock Text="🎬" FontSize="16" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1" Text="Timeline" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
          <Button Grid.Column="2" Classes="timeline-icon" Content="{Binding TimelinePlayPauseIcon}" Command="{Binding ToggleTimelinePlaybackCommand}" ToolTip.Tip="Play / Pause timeline preview" />
          <Button Grid.Column="3" Classes="timeline-icon" Content="⏹" Command="{Binding StopTimelinePlaybackCommand}" ToolTip.Tip="Stop playback and reset to 0s" />
          <TextBlock Grid.Column="4" Text="{Binding TimelineCurrentTimeLabel}" Foreground="#9FC2E5" VerticalAlignment="Center" />
          <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6">
            <TextBlock Text="Loop" Foreground="#C8D6EA" VerticalAlignment="Center" />
            <ToggleSwitch IsChecked="{Binding IsTimelineLoopEnabled}" />
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
          <Button Classes="timeline-icon" Content="◆" Command="{Binding AddTimelineKeyframeCommand}" ToolTip.Tip="Add keyframe for selected entities (position, scale, color)" />
          <Slider Grid.Column="1"
                  Minimum="0"
                  Maximum="{Binding TimelineDuration}"
                  Value="{Binding TimelineCurrentTime}"
                  TickFrequency="0.25"
                  IsSnapToTickEnabled="False" />
          <TextBlock Grid.Column="2" Text="{Binding TimelineStateLabel}" Foreground="#8EA5C7" FontSize="11" VerticalAlignment="Center" />
          <TextBlock Grid.Column="3" Text="{Binding TimelineMarkers.Count, StringFormat=Keys: {0}}" Foreground="#8EA5C7" FontSize="11" VerticalAlignment="Center" />
        </Grid>

        <ScrollViewer Grid.Row="2" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" MaxHeight="42">
          <ItemsControl ItemsSource="{Binding TimelineMarkers}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="6" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#0E1727" BorderBrush="#2B3A52" BorderThickness="1" CornerRadius="6" Padding="8,4" ToolTip.Tip="Timeline keyframe marker&#x0a;Represents snapshot data for selected animation mode.">
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="◆" Foreground="#6FA8FF" />
                    <TextBlock Text="{Binding Label}" Foreground="#C8D6EA" FontSize="11" />
                    <TextBlock Text="{Binding TrackCount, StringFormat=x{0}}" Foreground="#7A8DAA" FontSize="10" VerticalAlignment="Bottom" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="4" Background="#0C1018" BorderBrush="#2A3448" BorderThickness="1" CornerRadius="10" Padding="10,8">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="10">
        <TextBlock Text="GameForge V1 — local-first, single-player, no-code-first, Windows + Ubuntu, Vulkan-first direction" Foreground="#9DB0CC" FontSize="11" />
        <TextBlock Grid.Column="1" Text="{Binding PipelineProgress, StringFormat=Pipeline: {0}}" Foreground="#AFC2DF" FontSize="11" />
        <TextBlock Grid.Column="2" Text="{Binding RuntimeLaunchStatus, StringFormat=Runtime: {0}}" Foreground="#AFC2DF" FontSize="11" />
        <TextBlock Grid.Column="3" Text="{Binding RuntimePidLabel, StringFormat=PID: {0}}" Foreground="#AFC2DF" FontSize="11" />
        <TextBlock Grid.Column="4" Text="{Binding ShortcutHintBar}" Foreground="#8EA5C7" FontSize="10" TextTrimming="CharacterEllipsis" HorizontalAlignment="Right" ToolTip.Tip="{Binding ShortcutHintBar}" />
      </Grid>
    </Border>

    <Border Grid.RowSpan="5"
            IsVisible="{Binding IsHelpOverlayVisible}"
            Background="#081120E8"
            BorderBrush="#4AA3FF"
            BorderThickness="1.2"
            CornerRadius="10"
            Padding="14"
            Margin="38,28"
            ZIndex="15">
      <StackPanel Spacing="8">
        <TextBlock Text="How to use (Alpha)" Foreground="#E8F3FF" FontSize="16" FontWeight="Bold" />
        <TextBlock Text="1) New Project → Generate &amp; Play. 2) Edit in viewport (drag, inspect, delete). 3) Save with 💾 and reopen with 📂." Foreground="#CFE5FF" TextWrapping="Wrap" />
        <TextBlock Text="Delete safety: press Delete twice within 2 seconds to confirm keyboard removal." Foreground="#A9CBF2" TextWrapping="Wrap" />
        <TextBlock Text="Autosave writes scene snapshots + active project file whenever scene/code changes are applied." Foreground="#A9CBF2" TextWrapping="Wrap" />
        <Button Content="Close Help" HorizontalAlignment="Left" Command="{Binding ToggleHelpOverlayCommand}" />
      </StackPanel>
    </Border>

    <Border Grid.RowSpan="5"
            IsVisible="{Binding IsAssetBrowserDragPreviewVisible}"
            Margin="{Binding AssetBrowserDragPreviewMargin}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Background="#11243B"
            BorderBrush="#4AA3FF"
            BorderThickness="1.5"
            CornerRadius="10"
            Padding="8"
            Opacity="0.95"
            ZIndex="10"
            IsHitTestVisible="False">
      <Grid ColumnDefinitions="42,*,Auto" ColumnSpacing="8" MinWidth="190">
        <Border Width="40" Height="40" CornerRadius="7" Background="#0F2239" BorderBrush="#355B85" BorderThickness="1">
          <Grid>
            <Image Source="{Binding AssetDragGhostPreviewPath}" Stretch="UniformToFill" IsVisible="{Binding AssetDragGhostHasPreviewImage}" />
            <TextBlock Text="{Binding AssetDragGhostGlyph}" IsVisible="{Binding AssetDragGhostHasNoPreviewImage}" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D6E9FF" />
          </Grid>
        </Border>
        <StackPanel Grid.Column="1" Spacing="1" VerticalAlignment="Center">
          <TextBlock Text="{Binding AssetDragGhostTitle}" Foreground="#E8F3FF" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
          <TextBlock Text="Drop into viewport to place" Foreground="#9FC2E5" FontSize="10" />
        </StackPanel>
        <Border Grid.Column="2" VerticalAlignment="Center" Background="#1B3654" CornerRadius="8" Padding="5,2">
          <TextBlock Text="{Binding AssetDragGhostKind}" Foreground="#D6E9FF" FontSize="10" />
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
