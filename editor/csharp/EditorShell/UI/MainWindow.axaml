<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        x:Name="RootWindow"
        x:Class="GameForge.Editor.EditorShell.UI.MainWindow"
        Title="GameForge Editor Shell"
        Width="1460"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Background="#080A0F"
        mc:Ignorable="d">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#12161F" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#2B3446" />
    <SolidColorBrush x:Key="AccentBrush" Color="#4AA3FF" />
  </Window.Resources>

  <Window.Styles>
    <Style Selector="Button.ribbon-icon">
      <Setter Property="Background" Value="#1A2232" />
      <Setter Property="BorderBrush" Value="#334257" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#E5EDF7" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Width" Value="58" />
      <Setter Property="Height" Value="58" />
      <Setter Property="FontSize" Value="18" />
    </Style>

    <Style Selector="Button.generate-cta">
      <Setter Property="Background" Value="#1D6EE8" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Padding" Value="14,10" />
      <Setter Property="CornerRadius" Value="8" />
    </Style>

    <Style Selector="ToggleSwitch.deep-toggle">
      <Setter Property="OnContent" Value="On" />
      <Setter Property="OffContent" Value="Off" />
    </Style>

    <Style Selector="Button.history-chip">
      <Setter Property="Background" Value="#111929" />
      <Setter Property="BorderBrush" Value="#2B3A52" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#D6E6FA" />
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
  </Window.Styles>
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+Z" Command="{Binding UndoCommand}" />
    <KeyBinding Gesture="Ctrl+Y" Command="{Binding RedoCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="14" RowSpacing="12">
    <Border Grid.Row="0" Background="#0C1018" BorderBrush="#293349" BorderThickness="1" CornerRadius="10" Padding="12,10">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
        <StackPanel Orientation="Horizontal" Spacing="20">
          <StackPanel Spacing="5">
            <TextBlock Text="FILE" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="🆕" Click="OnNewPrototypeClick" ToolTip.Tip="New Prototype" />
              <Button Classes="ribbon-icon" Content="📂" ToolTip.Tip="Open Project (placeholder)" />
              <Button Classes="ribbon-icon" Content="💾" ToolTip.Tip="Save Snapshot (placeholder)" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="GENERATE" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="⚡" Click="OnGenerateFromBriefClick" ToolTip.Tip="Generate from Brief" />
              <Button Classes="ribbon-icon" Content="🤖" Click="OnGenerateAndPlayClick" ToolTip.Tip="Generate &amp; Play" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="RUNTIME" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="▶" Click="OnPlayRuntimeClick" ToolTip.Tip="Play Runtime" />
              <Button Classes="ribbon-icon" Content="⏹" ToolTip.Tip="Stop Runtime (placeholder)" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="TOOLS" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="🧩" ToolTip.Tip="Inspector Tools (placeholder)" />
              <Button Classes="ribbon-icon" Content="📊" ToolTip.Tip="Debug Console" />
            </StackPanel>
          </StackPanel>

          <StackPanel Spacing="5">
            <TextBlock Text="EXPORT" Foreground="#90A2BC" FontSize="11" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="6">
              <Button Classes="ribbon-icon" Content="📦" ToolTip.Tip="Export Build (placeholder)" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
          <TextBlock Text="Code Mode" VerticalAlignment="Center" Foreground="#D2DEEE" FontSize="12" />
          <ToggleSwitch Classes="deep-toggle" IsChecked="{Binding IsCodeMode}" VerticalAlignment="Center" />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="70,*,360" RowDefinitions="*" ColumnSpacing="12">
      <Border Grid.Column="0" Background="#0C1018" BorderBrush="#293349" BorderThickness="1" CornerRadius="10" Padding="8">
        <StackPanel Spacing="8" HorizontalAlignment="Center">
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="🖱" ToolTip.Tip="Select" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="✏" ToolTip.Tip="Paint" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="⬛" ToolTip.Tip="Terrain" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="💡" ToolTip.Tip="Lighting" />
          <Button Classes="ribbon-icon" Width="46" Height="46" Content="🎥" ToolTip.Tip="Camera" />
        </StackPanel>
      </Border>

      <Grid Grid.Column="1" RowDefinitions="*,220" RowSpacing="12">
        <Border Grid.Row="0" Background="#0A0D13" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12" IsVisible="{Binding IsViewportMode}">
          <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBlock Text="Scene Viewport" Foreground="#EEF4FF" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="+ 👤 Player" Command="{Binding AddPlayerEntityCommand}" ToolTip.Tip="Add Player entity and relaunch runtime" />
              <Button Grid.Column="2" Content="+ 🧍 NPC" Command="{Binding AddNpcEntityCommand}" ToolTip.Tip="Add NPC entity and relaunch runtime" />
              <Button Grid.Column="3" Content="+ 📦 Prop" Command="{Binding AddPropEntityCommand}" HorizontalAlignment="Left" ToolTip.Tip="Add Prop entity and relaunch runtime" />
              <Button Grid.Column="4" Content="↶ Undo" Command="{Binding UndoCommand}" IsEnabled="{Binding CanUndo}" ToolTip.Tip="Ctrl+Z" />
              <Button Grid.Column="5" Content="↷ Redo" Command="{Binding RedoCommand}" IsEnabled="{Binding CanRedo}" ToolTip.Tip="Ctrl+Y" />
              <Button Grid.Column="6" Content="🗑 Delete" Command="{Binding DeleteSelectedEntityCommand}" ToolTip.Tip="Delete selected entity" />
            </Grid>

            <TextBlock Grid.Row="1"
                       Text="No-code scene editing: click and drag entities directly in the viewport. Undo/redo tracks add, move, and delete."
                       Foreground="#93A7C7"
                       FontSize="12"
                       TextWrapping="Wrap" />

            <Border Grid.Row="2" Background="#06080D" BorderBrush="#264566" BorderThickness="1" CornerRadius="8" Padding="10">
              <Grid ColumnDefinitions="2*,*" ColumnSpacing="12">
                <Border Background="#0B1220" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="8" Padding="10">
                  <Grid>
                    <Canvas Name="ViewportCanvas" Background="#070B14" ClipToBounds="True" />
                    <TextBlock Text="Drag entities directly. Double-click empty space to inspect from right panel."
                               Foreground="#7F98BD"
                               FontSize="11"
                               Margin="6"
                               VerticalAlignment="Top"
                               HorizontalAlignment="Left" />
                  </Grid>
                </Border>

                <Border Grid.Column="1" Background="#0B1524" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="8" Padding="10">
                  <StackPanel Spacing="6">
                    <TextBlock Text="Selection Inspector" Foreground="#EEF4FF" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding SelectedEntitySummary}" Foreground="#C8D6EA" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedEntitiesCount, StringFormat=Selected: {0}}" Foreground="#AFC2DF" />
                    <TextBlock Text="{Binding SelectedEntityType, StringFormat=Type: {0}}" Foreground="#AFC2DF" />
                    <TextBlock Text="{Binding SelectedEntityX, StringFormat=X: {0:F2}}" Foreground="#AFC2DF" />
                    <TextBlock Text="{Binding SelectedEntityY, StringFormat=Y: {0:F2}}" Foreground="#AFC2DF" />
                    <TextBlock Text="Hint: Ctrl+Click toggles selection. Drag empty canvas for marquee multi-select." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
                  </StackPanel>
                </Border>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Row="0" Background="#090B11" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12" IsVisible="{Binding IsCodeMode}">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
              <TextBlock Text="Code Mode — Runtime C++ Editor" Foreground="#EEF4FF" FontSize="16" FontWeight="SemiBold" />
              <Button Grid.Column="1" Content="Save &amp; Recompile" Click="OnSaveCodeClick" ToolTip.Tip="Save generated C++ edits, recompile, and relaunch runtime" />
            </Grid>
            <avaloniaEdit:TextEditor Grid.Row="1"
                                     Name="CodeEditor"
                                     Margin="0,10,0,0"
                                     FontFamily="Consolas, Menlo, Monospace"
                                     FontSize="14"
                                     ShowLineNumbers="True"
                                     HorizontalScrollBarVisibility="Auto"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#06080D"
                                     Foreground="#D8E8FF" />
          </Grid>
        </Border>

        <Border Grid.Row="1" Background="#101722" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12">
          <Grid RowDefinitions="Auto,*,Auto" RowSpacing="8">
            <TextBlock Text="Chat Co-Pilot" FontSize="18" FontWeight="Bold" Foreground="#EEF4FF" />

            <StackPanel Grid.Row="1" Spacing="8">
              <TextBlock Text="Describe Your Game" Foreground="#C8D6EA" FontSize="13" FontWeight="SemiBold" />
              <TextBox Text="{Binding ChatPrompt}" Height="96" AcceptsReturn="True" TextWrapping="Wrap" Watermark="A cozy single-player colony sim with light RPG progression..." />
              <Button Classes="generate-cta" Content="{Binding GenerateButtonLabel}" Click="OnGenerateAndPlayClick" IsEnabled="{Binding CanGenerate}" />
              <TextBlock Text="{Binding StatusMessage}" Foreground="#AFC2DF" TextWrapping="Wrap" FontSize="12" />
            </StackPanel>

            <Border Grid.Row="2" IsVisible="{Binding IsStatusToastVisible}" Background="#17304D" CornerRadius="8" Padding="10,8" HorizontalAlignment="Right">
              <TextBlock Text="{Binding StatusToastMessage}" Foreground="#E8F3FF" FontSize="12" FontWeight="SemiBold" />
            </Border>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Column="2" Background="#0C1018" BorderBrush="#293349" BorderThickness="1" CornerRadius="10" Padding="12">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="10">
          <TextBlock Text="Properties Inspector" Foreground="#EEF4FF" FontSize="18" FontWeight="Bold" />
          <TextBlock Grid.Row="1" Text="Beginner-first defaults with optional professional depth." Foreground="#9DB0CC" TextWrapping="Wrap" />

          <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
            <TextBlock Text="Advanced Inspector" Foreground="#D5E4F8" VerticalAlignment="Center" />
            <ToggleSwitch Grid.Column="1" Classes="deep-toggle" IsChecked="{Binding IsAdvancedInspectorEnabled}" />
          </Grid>

          <Grid Grid.Row="3" ColumnDefinitions="*,Auto">
            <TextBlock Text="Debug Console" Foreground="#D5E4F8" VerticalAlignment="Center" />
            <ToggleSwitch Grid.Column="1" Classes="deep-toggle" IsChecked="{Binding IsDebugConsoleEnabled}" />
          </Grid>

          <Border Grid.Row="4" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto" RowSpacing="8">
              <TextBlock Text="Runtime Preview" Foreground="#EEF4FF" FontSize="16" FontWeight="SemiBold" />
              <Border Grid.Row="1" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="8" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="🟢 Vulkan Runtime Live Feed" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding RuntimePreviewSummary}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding RuntimeSelectedEntityPreview}" Foreground="#9FC2E5" FontSize="11" TextWrapping="Wrap" />
                </StackPanel>
              </Border>
              <TextBlock Grid.Row="2" Text="Runtime Status" Foreground="#D5E4F8" FontWeight="SemiBold" />
              <TextBlock Grid.Row="3" Text="{Binding RuntimeLaunchStatus, StringFormat=Live in Vulkan status: {0}}" Foreground="#AFC2DF" />
              <TextBlock Grid.Row="4" Text="Generated Entity List (scene/scene_scaffold.json)" Foreground="#D5E4F8" FontWeight="SemiBold" />
              <ScrollViewer Grid.Row="5" MaxHeight="140">
                <TextBlock Text="{Binding RuntimeEntityList}" Foreground="#AFC2DF" TextWrapping="Wrap" FontFamily="Consolas, Menlo, Monospace" />
              </ScrollViewer>
              <Button Grid.Row="6" Classes="generate-cta" Content="Relaunch Runtime" Click="OnPlayRuntimeClick" ToolTip.Tip="Rebuild generated runtime and relaunch generated_gameplay_runner" />
            </Grid>
          </Border>


          <Border Grid.Row="5" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="8">
              <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBlock Text="🗂 Asset Browser" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
                <Button Grid.Column="1" Content="Import Asset" Click="OnImportAssetClick" ToolTip.Tip="Import PNG or OBJ into the local asset browser" />
              </Grid>
              <TextBlock Grid.Row="1" Text="Drag asset chips directly onto the viewport to place new props." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
              <ScrollViewer Grid.Row="2" MaxHeight="156">
                <ItemsControl ItemsSource="{Binding ImportedAssets}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6" Padding="8" CornerRadius="6" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" Tag="{Binding Id}" PointerPressed="OnAssetChipPointerPressed">
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                          <Border Width="16" Height="16" Background="{Binding ColorHex}" CornerRadius="3" VerticalAlignment="Center" />
                          <StackPanel Grid.Column="1" Spacing="1">
                            <TextBlock Text="{Binding DisplayName}" Foreground="#D6E9FF" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding Kind}" Foreground="#8EA5C7" FontSize="11" />
                          </StackPanel>
                          <TextBlock Grid.Column="2" Text="⇢" Foreground="#9FC2E5" VerticalAlignment="Center" FontSize="16" />
                        </Grid>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
              <Border Grid.Row="3" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Selected Asset Preview" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedImportedAssetName}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedImportedAssetKind, StringFormat=Kind: {0}}" Foreground="#8EA5C7" FontSize="11" />
                  <Image Height="72" Stretch="Uniform" Source="{Binding SelectedImportedAssetPreviewPath}" />
                </StackPanel>
              </Border>
              <TextBlock Grid.Row="4" Text="V1 supports PNG textures + OBJ models only." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
            </Grid>
          </Border>

          <Border Grid.Row="6" BorderBrush="#2B3446" BorderThickness="1" Background="#101722" CornerRadius="8" Padding="10">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,*" RowSpacing="8">
              <TextBlock Text="🎛 Scene Properties" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" />
              <TextBlock Grid.Row="1" Text="{Binding SelectedEntitySummary}" Foreground="#C8D6EA" TextWrapping="Wrap" />
              <TextBox Grid.Row="2" Watermark="Entity Name (or mixed)" Text="{Binding SelectedEntityNameEditor}" IsEnabled="{Binding HasSelection}" />
              <Grid Grid.Row="3" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                <TextBlock Text="X" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="1" Text="{Binding SelectedEntityPositionXEditor}" IsEnabled="{Binding HasSelection}" />
                <TextBlock Grid.Column="2" Text="Y" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="3" Text="{Binding SelectedEntityPositionYEditor}" IsEnabled="{Binding HasSelection}" />
              </Grid>
              <Grid Grid.Row="4" ColumnDefinitions="Auto,*,Auto,*" ColumnSpacing="8">
                <TextBlock Text="Scale" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="1" Text="{Binding SelectedEntityScaleEditor}" IsEnabled="{Binding HasSelection}" />
                <TextBlock Grid.Column="2" Text="Color" VerticalAlignment="Center" Foreground="#AFC2DF" />
                <TextBox Grid.Column="3" Text="{Binding SelectedEntityColorEditor}" IsEnabled="{Binding HasSelection}" />
              </Grid>
              <Border Grid.Row="5" Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="8">
                <StackPanel Spacing="4">
                  <TextBlock Text="Selection Asset Preview" Foreground="#D6E9FF" FontWeight="SemiBold" />
                  <TextBlock Text="{Binding SelectedEntityAssetName}" Foreground="#AFC2DF" TextWrapping="Wrap" />
                  <TextBlock Text="{Binding SelectedEntityAssetKind, StringFormat=Kind: {0}}" Foreground="#8EA5C7" FontSize="11" />
                  <Image Height="64" Stretch="Uniform" Source="{Binding SelectedEntityAssetPreviewPath}" />
                  <Border Height="12" Background="{Binding SelectedEntityColorEditor}" CornerRadius="3" />
                </StackPanel>
              </Border>
              <Button Grid.Row="6" Content="✨ Apply Selection → Runtime" Command="{Binding ApplySelectionPropertiesCommand}" IsEnabled="{Binding HasSelection}" />
              <TextBlock Grid.Row="7" Text="Live viewport updates instantly. Apply commits to scene_scaffold.json + runtime relaunch." Foreground="#8EA5C7" FontSize="11" TextWrapping="Wrap" />
            </Grid>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="#0C1018" BorderBrush="#2B3446" BorderThickness="1" CornerRadius="10" Padding="12">
      <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
          <TextBlock Text="🕘" FontSize="16" VerticalAlignment="Center" />
          <TextBlock Grid.Column="1" Text="History" Foreground="#EEF4FF" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Grid.Column="2" Text="{Binding HistoryTimeline.Count, StringFormat=Steps: {0}}" Foreground="#8EA5C7" FontSize="11" VerticalAlignment="Center" />
        </Grid>
        <TextBlock Grid.Row="1"
                   Text="Click any step to jump scene state. Current step is highlighted; future redo steps are dimmed."
                   Foreground="#8EA5C7"
                   FontSize="11"
                   TextWrapping="Wrap" />
        <ScrollViewer Grid.Row="2" MaxHeight="138" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
          <ItemsControl ItemsSource="{Binding HistoryTimeline}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" Spacing="8" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="history-chip"
                        Command="{Binding #RootWindow.DataContext.JumpToHistoryCommand}"
                        CommandParameter="{Binding Revision}">
                  <Grid ColumnDefinitions="Auto,Auto,*" ColumnSpacing="8">
                    <TextBlock Text="{Binding Icon}" FontSize="14" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="{Binding RevisionLabel}" Foreground="#8EA5C7" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Spacing="2">
                      <TextBlock Text="{Binding Description}" TextWrapping="NoWrap" />
                      <TextBlock Text="{Binding IsCurrent, StringFormat=Current: {0}}" Foreground="#6FA8FF" FontSize="10" IsVisible="{Binding IsCurrent}" />
                      <TextBlock Text="Future / Redo" Foreground="#7A8DAA" FontSize="10" IsVisible="{Binding IsFuture}" />
                    </StackPanel>
                  </Grid>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>

    <Border Grid.Row="3" Background="#0C1018" BorderBrush="#2A3448" BorderThickness="1" CornerRadius="10" Padding="10,8">
      <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
        <TextBlock Text="GameForge V1 — local-first, single-player, no-code-first, Windows + Ubuntu, Vulkan-first direction" Foreground="#9DB0CC" FontSize="11" />
        <TextBlock Grid.Column="1" Text="{Binding PipelineProgress, StringFormat=Pipeline: {0}}" Foreground="#AFC2DF" FontSize="11" />
        <TextBlock Grid.Column="2" Text="{Binding RuntimeLaunchStatus, StringFormat=Runtime: {0}}" Foreground="#AFC2DF" FontSize="11" />
        <TextBlock Grid.Column="3" Text="{Binding RuntimePidLabel, StringFormat=PID: {0}}" Foreground="#AFC2DF" FontSize="11" />
      </Grid>
    </Border>
  </Grid>
</Window>
