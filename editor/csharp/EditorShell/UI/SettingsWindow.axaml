<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GameForge.Editor.EditorShell.UI.SettingsWindow"
        Title="ForgeEngine Settings"
        Width="720"
        Height="540"
        MinWidth="540"
        MinHeight="420"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource EditorDialogWindowBgBrush}">
  <Border Padding="18" Classes="shell-dialog-frame">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
      <StackPanel>
        <TextBlock Text="ForgeEngine Settings" Foreground="{DynamicResource EditorDialogTitleBrush}" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="Project-wide settings saved to .soulloom/settings.json" Foreground="{DynamicResource EditorDialogMutedBrush}" Margin="0,4,0,0" />
      </StackPanel>

      <TabControl Grid.Row="1" Name="SettingsTabs" Classes="shell-dialog-tabs">
        <TabItem Header="General">
          <ScrollViewer Classes="shell-dialog-tab-scroll">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Theme" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <ComboBox Name="ThemeComboBox">
              <ComboBoxItem Content="Dark" />
              <ComboBoxItem Content="Light" />
              <ComboBoxItem Content="System" />
            </ComboBox>

            <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
              <TextBlock Text="Autosave scene changes" Foreground="{DynamicResource EditorDialogTitleBrush}" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="AutosaveToggle" OnContent="On" OffContent="Off" />
            </Grid>
          </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Graphics">
          <ScrollViewer Classes="shell-dialog-tab-scroll">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Vulkan preview resolution" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <ComboBox Name="ResolutionComboBox">
              <ComboBoxItem Content="1280x720" />
              <ComboBoxItem Content="1600x900" />
              <ComboBoxItem Content="1920x1080" />
              <ComboBoxItem Content="2560x1440" />
            </ComboBox>

            <TextBlock Text="FPS limit" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <NumericUpDown Name="FpsLimitNumeric" Minimum="30" Maximum="240" Increment="5" Value="60" />
          </StackPanel>
          </ScrollViewer>
        </TabItem>


        <TabItem Header="Audio">
          <ScrollViewer Classes="shell-dialog-tab-scroll">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Exploration music track" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <TextBox Name="MusicTrackTextBox" Watermark="music_exploration" />

            <TextBlock Text="Ambient loop track" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <TextBox Name="AmbientTrackTextBox" Watermark="ambient_exploration_loop" />

            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
              <TextBlock Text="Combat music override" Foreground="{DynamicResource EditorDialogTitleBrush}" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="CombatMusicOverrideToggle" OnContent="On" OffContent="Off" />
            </Grid>

            <TextBlock Text="Master volume" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <NumericUpDown Name="MasterVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="85" />

            <TextBlock Text="Music / Ambient / UI volume" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
              <NumericUpDown Name="MusicVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="75" />
              <NumericUpDown Grid.Column="1" Name="AmbientVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="60" />
              <NumericUpDown Grid.Column="2" Name="UiVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="80" />
            </Grid>

            <TextBlock Text="SFX volume / Spatial voice limit" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <NumericUpDown Name="SfxVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="80" />
              <NumericUpDown Grid.Column="1" Name="SpatialVoiceLimitNumeric" Minimum="4" Maximum="64" Increment="2" Value="24" />
            </Grid>

            <TextBlock Text="Ducking strength (combat / UI)" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <NumericUpDown Name="CombatDuckingNumeric" Minimum="0" Maximum="100" Increment="5" Value="35" />
              <NumericUpDown Grid.Column="1" Name="UiDuckingNumeric" Minimum="0" Maximum="100" Increment="5" Value="15" />
            </Grid>

            <TextBlock Text="Reverb zone preset" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <ComboBox Name="ReverbZoneComboBox">
              <ComboBoxItem Content="outdoor" />
              <ComboBoxItem Content="indoor" />
              <ComboBoxItem Content="cave" />
              <ComboBoxItem Content="workshop" />
            </ComboBox>

            <TextBlock Text="Procedural intensity" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <NumericUpDown Name="ProceduralIntensityNumeric" Minimum="0" Maximum="100" Increment="5" Value="55" />
          </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Performance">
          <ScrollViewer Classes="shell-dialog-tab-scroll">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Unified orchestration command status" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <TextBlock
              Name="AiOrchestrationStatusLineText"
              Text="Ready: /orchestrate narrative_checkpoint|npc_day|scene_review &lt;scene_json_path&gt; [target]. scene_review target supports playtest|with_playtest|no_playtest."
              Foreground="{DynamicResource EditorDialogMutedBrush}"
              TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Enable Bot Playtesting in Review" Foreground="{DynamicResource EditorDialogTitleBrush}" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="EnableBotPlaytestingInReviewToggle" OnContent="On" OffContent="Off" />
            </Grid>
            <TextBlock Text="Last Scene Review Summary" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <TextBox Name="LastSceneReviewSummaryTextBox" AcceptsReturn="True" IsReadOnly="True" Height="92" TextWrapping="Wrap" />
          </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="AI Models" Name="ModelsAndLlmTab">
          <ScrollViewer Name="ModelsTabScrollViewer"
                        Classes="shell-dialog-tab-scroll"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16" Spacing="12">
              <TextBlock Text="Local model setup and onboarding" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
              <TextBlock Name="ModelRecommendationSummaryText"
                         Text="Add your Hugging Face token first, then Quick Setup can install ForgeGuard, Free-Will, and Coding."
                         Foreground="{DynamicResource EditorDialogMutedBrush}"
                         TextWrapping="Wrap" />

              <Border Classes="shell-dialog-inset" Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Hugging Face access" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
                  <TextBlock Text="Soul Loom now requires your Hugging Face token before first model download so setup does not stall on anonymous rate limits."
                             Foreground="{DynamicResource EditorDialogMutedBrush}"
                             TextWrapping="Wrap" />
                  <TextBlock Text="Paste token" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
                  <TextBox Name="HuggingFaceTokenTextBox" Watermark="hf_..." />
                  <WrapPanel ItemWidth="170" Orientation="Horizontal">
                    <Button Name="SaveHuggingFaceTokenButton" Content="Save Token" MinWidth="150" Margin="0,0,8,8" Click="OnSaveHuggingFaceTokenClick" />
                    <Button Name="ClearHuggingFaceTokenButton" Content="Clear Token" MinWidth="150" Margin="0,0,8,8" Click="OnClearHuggingFaceTokenClick" />
                    <Button Content="Create Account" MinWidth="150" Margin="0,0,8,8" Click="OnCreateHuggingFaceAccountClick" />
                    <Button Content="Log In" MinWidth="150" Margin="0,0,8,8" Click="OnLoginHuggingFaceClick" />
                    <Button Content="Open Access Tokens" MinWidth="170" Margin="0,0,8,8" Click="OnOpenHuggingFaceTokensClick" />
                  </WrapPanel>
                  <TextBlock Name="HuggingFaceTokenStatusText"
                             Text="No Hugging Face token configured yet."
                             Foreground="{DynamicResource EditorDialogAccentMutedBrush}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>

              <WrapPanel ItemWidth="180" Orientation="Horizontal">
                <Button Name="QuickStartModelsButton" Content="Quick Start" MinWidth="170" Margin="0,0,8,8" Click="OnQuickStartModelsClick" />
                <Button Name="DownloadForgeGuardButton" Content="Download ForgeGuard" MinWidth="170" Margin="0,0,8,8" Click="OnDownloadForgeGuardClick" />
                <Button Name="RunOnboardingButton" Content="Run Onboarding" MinWidth="170" Margin="0,0,8,8" Click="OnRunModelOnboardingClick" />
                <Button Name="SetupRecommendedModelsButton" Content="Setup Recommended" MinWidth="170" Margin="0,0,8,8" Click="OnSetupRecommendedModelsClick" />
                <Button Name="SetupFreeWillModelButton" Content="Download Free-Will" MinWidth="170" Margin="0,0,8,8" Click="OnSetupFreeWillModelClick" />
                <Button Name="DownloadCodingModelButton" Content="Download Coding" MinWidth="170" Margin="0,0,8,8" Click="OnDownloadCodingModelClick" />
                <Button Name="RetryModelOperationButton" Content="Retry Last Operation" MinWidth="170" Margin="0,0,8,8" Click="OnRetryModelOperationClick" />
                <Button Name="RefreshModelsButton" Content="Refresh Models" MinWidth="170" Margin="0,0,8,8" Click="OnRefreshModelsClick" />
              </WrapPanel>

              <Border Classes="shell-dialog-inset" Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Managed model status" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
                  <TextBox Name="ModelEntriesSummaryTextBox"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           Height="190"
                           Background="{DynamicResource PanelShellBrush}"
                           Foreground="{DynamicResource EditorDialogTitleBrush}" />
                  <TextBlock Name="ForgeGuardKeepInstalledMessageText"
                             Text="ForgeGuard stays installed as a permanent helper for guardrails and critique passes."
                             Foreground="{DynamicResource EditorDialogAccentMutedBrush}"
                             TextWrapping="Wrap" />
                  <TextBlock Name="ModelManagerStatusText"
                             Text="Model manager idle."
                             Foreground="{DynamicResource EditorDialogMutedBrush}"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="Shortcuts">
          <ScrollViewer Classes="shell-dialog-tab-scroll">
          <StackPanel Margin="16" Spacing="12">
            <Border Classes="shell-dialog-inset" Padding="12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Shortcut Summary" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
                    <TextBlock Text="Ctrl+Shift+O Command palette. Ctrl+N New Scene, Ctrl+O Open Scene, Ctrl+S Save Scene, Ctrl+Shift+S Save Scene As, Ctrl+E Export, Ctrl+Shift+P Play runtime."
                               Foreground="{DynamicResource EditorDialogMutedBrush}"
                               FontSize="11"
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <ToggleSwitch Grid.Column="1" Name="CreatorModeToggle" OnContent="On" OffContent="Off" />
                </Grid>
                <TextBlock Text="Additional editor defaults remain available below so existing behavior stays backward compatible."
                           Foreground="{DynamicResource EditorDialogMutedBrush}"
                           FontSize="11"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <TextBlock Text="Ribbon icon size" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <NumericUpDown Name="IconSizeNumeric" Minimum="40" Maximum="84" Increment="2" Value="58" />

            <TextBlock Text="Undo/redo history length" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <NumericUpDown Name="HistoryLengthNumeric" Minimum="10" Maximum="300" Increment="10" Value="120" />

            <TextBlock Text="Default new-project template" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <ComboBox Name="DefaultTemplateComboBox" />
          </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="About">
          <ScrollViewer Classes="shell-dialog-tab-scroll">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="ForgeEngine Editor V1" Foreground="{DynamicResource EditorDialogTitleBrush}" FontWeight="SemiBold" />
            <TextBlock Text="Scene-first editing on top of project storage. Settings are project-wide; scenes remain the primary editing unit."
                       Foreground="{DynamicResource EditorDialogMutedBrush}"
                       TextWrapping="Wrap" />
            <TextBlock Text="This pass focuses on polish: menus, viewport behavior, assets, AI interview, status feedback, and shell consistency."
                       Foreground="{DynamicResource EditorDialogMutedBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
          </ScrollViewer>
        </TabItem>
      </TabControl>

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBlock Name="ValidationMessageText"
                   Foreground="#FF9CB4"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,8,0" />
        <Button Grid.Column="1" Content="Cancel" Classes="shell-dialog-secondary" Click="OnCancelClick" />
        <Button Grid.Column="2" Content="Save" Classes="shell-dialog-primary" Click="OnSaveClick" />
      </Grid>
    </Grid>
  </Border>
</Window>
