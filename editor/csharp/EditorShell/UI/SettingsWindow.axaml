<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GameForge.Editor.EditorShell.UI.SettingsWindow"
        Title="Preferences &amp; Settings"
        Width="720"
        Height="540"
        MinWidth="680"
        MinHeight="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#0B111D">
  <Border Padding="18" BorderBrush="#2B3A52" BorderThickness="1" CornerRadius="12" Background="#0B111D">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
      <StackPanel>
        <TextBlock Text="⚙ Preferences &amp; Settings" Foreground="#EDF5FF" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="Local-first editor and runtime controls" Foreground="#97AECC" Margin="0,4,0,0" />
      </StackPanel>

      <TabControl Grid.Row="1" Name="SettingsTabs" Background="#101B2B" BorderBrush="#2D405D" BorderThickness="1">
        <TabItem Header="🎨 General">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Theme" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <ComboBox Name="ThemeComboBox">
              <ComboBoxItem Content="Dark" />
              <ComboBoxItem Content="Light" />
              <ComboBoxItem Content="System" />
            </ComboBox>

            <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
              <TextBlock Text="Autosave scene changes" Foreground="#DDEBFF" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="AutosaveToggle" OnContent="On" OffContent="Off" />
            </Grid>
          </StackPanel>
        </TabItem>

        <TabItem Header="🎮 Runtime">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Vulkan preview resolution" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <ComboBox Name="ResolutionComboBox">
              <ComboBoxItem Content="1280x720" />
              <ComboBoxItem Content="1600x900" />
              <ComboBoxItem Content="1920x1080" />
              <ComboBoxItem Content="2560x1440" />
            </ComboBox>

            <TextBlock Text="FPS limit" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="FpsLimitNumeric" Minimum="30" Maximum="240" Increment="5" Value="60" />
          </StackPanel>
        </TabItem>


        <TabItem Header="🔊 Audio">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Exploration music track" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <TextBox Name="MusicTrackTextBox" Watermark="music_exploration" />

            <TextBlock Text="Ambient loop track" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <TextBox Name="AmbientTrackTextBox" Watermark="ambient_exploration_loop" />

            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
              <TextBlock Text="Combat music override" Foreground="#DDEBFF" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="CombatMusicOverrideToggle" OnContent="On" OffContent="Off" />
            </Grid>

            <TextBlock Text="Master volume" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="MasterVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="85" />

            <TextBlock Text="Music / Ambient / UI volume" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
              <NumericUpDown Name="MusicVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="75" />
              <NumericUpDown Grid.Column="1" Name="AmbientVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="60" />
              <NumericUpDown Grid.Column="2" Name="UiVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="80" />
            </Grid>

            <TextBlock Text="SFX volume / Spatial voice limit" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <NumericUpDown Name="SfxVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="80" />
              <NumericUpDown Grid.Column="1" Name="SpatialVoiceLimitNumeric" Minimum="4" Maximum="64" Increment="2" Value="24" />
            </Grid>

            <TextBlock Text="Ducking strength (combat / UI)" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
              <NumericUpDown Name="CombatDuckingNumeric" Minimum="0" Maximum="100" Increment="5" Value="35" />
              <NumericUpDown Grid.Column="1" Name="UiDuckingNumeric" Minimum="0" Maximum="100" Increment="5" Value="15" />
            </Grid>

            <TextBlock Text="Reverb zone preset" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <ComboBox Name="ReverbZoneComboBox">
              <ComboBoxItem Content="outdoor" />
              <ComboBoxItem Content="indoor" />
              <ComboBoxItem Content="cave" />
              <ComboBoxItem Content="workshop" />
            </ComboBox>

            <TextBlock Text="Procedural intensity" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="ProceduralIntensityNumeric" Minimum="0" Maximum="100" Increment="5" Value="55" />
          </StackPanel>
        </TabItem>

        <TabItem Header="🧠 AI Orchestration">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Unified orchestration command status" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <TextBlock
              Name="AiOrchestrationStatusLineText"
              Text="Ready: /orchestrate narrative_checkpoint|npc_day|scene_review &lt;scene_json_path&gt; [target]. scene_review target supports playtest|with_playtest|no_playtest."
              Foreground="#97AECC"
              TextWrapping="Wrap" />
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Enable Bot Playtesting in Review" Foreground="#DDEBFF" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="EnableBotPlaytestingInReviewToggle" OnContent="On" OffContent="Off" />
            </Grid>
            <TextBlock Text="Last Scene Review Summary" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <TextBox Name="LastSceneReviewSummaryTextBox" AcceptsReturn="True" IsReadOnly="True" Height="92" TextWrapping="Wrap" />
          </StackPanel>
        </TabItem>

        <TabItem Header="🧠 Models &amp; LLM" Name="ModelsAndLlmTab">
          <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="16" Spacing="12">
              <TextBlock Text="Local model setup and onboarding" Foreground="#DDEBFF" FontWeight="SemiBold" />
              <TextBlock Name="ModelRecommendationSummaryText"
                         Text="ForgeGuard can be installed immediately. Run onboarding to unlock hardware-matched recommendations."
                         Foreground="#97AECC"
                         TextWrapping="Wrap" />

              <WrapPanel ItemWidth="180" Orientation="Horizontal">
                <Button Name="QuickStartModelsButton" Content="Quick Start" MinWidth="170" Margin="0,0,8,8" Click="OnQuickStartModelsClick" />
                <Button Name="DownloadForgeGuardButton" Content="Download ForgeGuard" MinWidth="170" Margin="0,0,8,8" Click="OnDownloadForgeGuardClick" />
                <Button Name="RunOnboardingButton" Content="Run Onboarding" MinWidth="170" Margin="0,0,8,8" Click="OnRunModelOnboardingClick" />
                <Button Name="SetupRecommendedModelsButton" Content="Setup Recommended" MinWidth="170" Margin="0,0,8,8" Click="OnSetupRecommendedModelsClick" />
                <Button Name="SetupFreeWillModelButton" Content="Download Free-Will" MinWidth="170" Margin="0,0,8,8" Click="OnSetupFreeWillModelClick" />
                <Button Name="DownloadCodingModelButton" Content="Download Coding" MinWidth="170" Margin="0,0,8,8" Click="OnDownloadCodingModelClick" />
                <Button Name="RetryModelOperationButton" Content="Retry Last Operation" MinWidth="170" Margin="0,0,8,8" Click="OnRetryModelOperationClick" />
                <Button Name="RefreshModelsButton" Content="Refresh Models" MinWidth="170" Margin="0,0,8,8" Click="OnRefreshModelsClick" />
              </WrapPanel>

              <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="6" Padding="10">
                <StackPanel Spacing="8">
                  <TextBlock Text="Managed model status" Foreground="#DDEBFF" FontWeight="SemiBold" />
                  <TextBox Name="ModelEntriesSummaryTextBox"
                           IsReadOnly="True"
                           AcceptsReturn="True"
                           TextWrapping="Wrap"
                           Height="190"
                           Background="#09111D"
                           Foreground="#DDEBFF" />
                  <TextBlock Name="ForgeGuardKeepInstalledMessageText"
                             Text="ForgeGuard stays installed as a permanent helper for guardrails and critique passes."
                             Foreground="#AFC2DF"
                             TextWrapping="Wrap" />
                  <TextBlock Name="ModelManagerStatusText"
                             Text="Model manager idle."
                             Foreground="#97AECC"
                             TextWrapping="Wrap" />
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="🧰 Editor">
          <StackPanel Margin="16" Spacing="12">
            <Border Background="#0B1524" BorderBrush="#264566" BorderThickness="1" CornerRadius="8" Padding="12">
              <StackPanel Spacing="8">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                  <StackPanel Spacing="2">
                    <TextBlock Text="Creator Mode (recommended)" Foreground="#DDEBFF" FontWeight="SemiBold" />
                    <TextBlock Text="Keeps the viewport front-and-center, starts with the simple inspector, and collapses secondary panes by default."
                               Foreground="#97AECC"
                               FontSize="11"
                               TextWrapping="Wrap" />
                  </StackPanel>
                  <ToggleSwitch Grid.Column="1" Name="CreatorModeToggle" OnContent="On" OffContent="Off" />
                </Grid>
                <TextBlock Text="Turn this off for the denser power-user workspace with outliner, timeline, activity log, and advanced inspector tools visible."
                           Foreground="#7FA6CF"
                           FontSize="11"
                           TextWrapping="Wrap" />
              </StackPanel>
            </Border>

            <TextBlock Text="Ribbon icon size" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="IconSizeNumeric" Minimum="40" Maximum="84" Increment="2" Value="58" />

            <TextBlock Text="Undo/redo history length" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="HistoryLengthNumeric" Minimum="10" Maximum="300" Increment="10" Value="120" />

            <TextBlock Text="Default new-project template" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <ComboBox Name="DefaultTemplateComboBox" />
          </StackPanel>
        </TabItem>
      </TabControl>

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBlock Name="ValidationMessageText" Foreground="#FF9CB4" VerticalAlignment="Center" TextWrapping="Wrap" />
        <Button Grid.Column="1" Content="Cancel" MinWidth="90" Click="OnCancelClick" />
        <Button Grid.Column="2" Content="Save" MinWidth="90" Click="OnSaveClick" />
      </Grid>
    </Grid>
  </Border>
</Window>
