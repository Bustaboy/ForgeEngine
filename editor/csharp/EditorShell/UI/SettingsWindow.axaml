<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GameForge.Editor.EditorShell.UI.SettingsWindow"
        Title="Preferences &amp; Settings"
        Width="720"
        Height="540"
        MinWidth="680"
        MinHeight="500"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#0B111D">
  <Border Padding="18" BorderBrush="#2B3A52" BorderThickness="1" CornerRadius="12" Background="#0B111D">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
      <StackPanel>
        <TextBlock Text="⚙ Preferences &amp; Settings" Foreground="#EDF5FF" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="Local-first editor and runtime controls" Foreground="#97AECC" Margin="0,4,0,0" />
      </StackPanel>

      <TabControl Grid.Row="1" Name="SettingsTabs" Background="#101B2B" BorderBrush="#2D405D" BorderThickness="1">
        <TabItem Header="🎨 General">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Theme" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <ComboBox Name="ThemeComboBox">
              <ComboBoxItem Content="Dark" />
              <ComboBoxItem Content="Light" />
              <ComboBoxItem Content="System" />
            </ComboBox>

            <Grid ColumnDefinitions="*,Auto" Margin="0,10,0,0">
              <TextBlock Text="Autosave scene changes" Foreground="#DDEBFF" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="AutosaveToggle" OnContent="On" OffContent="Off" />
            </Grid>
          </StackPanel>
        </TabItem>

        <TabItem Header="🎮 Runtime">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Vulkan preview resolution" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <ComboBox Name="ResolutionComboBox">
              <ComboBoxItem Content="1280x720" />
              <ComboBoxItem Content="1600x900" />
              <ComboBoxItem Content="1920x1080" />
              <ComboBoxItem Content="2560x1440" />
            </ComboBox>

            <TextBlock Text="FPS limit" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="FpsLimitNumeric" Minimum="30" Maximum="240" Increment="5" Value="60" />
          </StackPanel>
        </TabItem>


        <TabItem Header="🔊 Audio">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Exploration music track" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <TextBox Name="MusicTrackTextBox" Watermark="music_exploration" />

            <TextBlock Text="Ambient loop track" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <TextBox Name="AmbientTrackTextBox" Watermark="ambient_exploration_loop" />

            <Grid ColumnDefinitions="*,Auto" Margin="0,4,0,0">
              <TextBlock Text="Combat music override" Foreground="#DDEBFF" VerticalAlignment="Center" />
              <ToggleSwitch Grid.Column="1" Name="CombatMusicOverrideToggle" OnContent="On" OffContent="Off" />
            </Grid>

            <TextBlock Text="Master volume" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="MasterVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="85" />

            <TextBlock Text="Music / Ambient / UI volume" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
              <NumericUpDown Name="MusicVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="75" />
              <NumericUpDown Grid.Column="1" Name="AmbientVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="60" />
              <NumericUpDown Grid.Column="2" Name="UiVolumeNumeric" Minimum="0" Maximum="100" Increment="5" Value="80" />
            </Grid>
          </StackPanel>
        </TabItem>
        <TabItem Header="🧰 Editor">
          <StackPanel Margin="16" Spacing="12">
            <TextBlock Text="Ribbon icon size" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="IconSizeNumeric" Minimum="40" Maximum="84" Increment="2" Value="58" />

            <TextBlock Text="Undo/redo history length" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <NumericUpDown Name="HistoryLengthNumeric" Minimum="10" Maximum="300" Increment="10" Value="120" />

            <TextBlock Text="Default new-project template" Foreground="#DDEBFF" FontWeight="SemiBold" />
            <ComboBox Name="DefaultTemplateComboBox" />
          </StackPanel>
        </TabItem>
      </TabControl>

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <TextBlock Name="ValidationMessageText" Foreground="#FF9CB4" VerticalAlignment="Center" TextWrapping="Wrap" />
        <Button Grid.Column="1" Content="Cancel" MinWidth="90" Click="OnCancelClick" />
        <Button Grid.Column="2" Content="Save" MinWidth="90" Click="OnSaveClick" />
      </Grid>
    </Grid>
  </Border>
</Window>
