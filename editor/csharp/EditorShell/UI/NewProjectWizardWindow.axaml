<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GameForge.Editor.EditorShell.UI.NewProjectWizardWindow"
        Title="New Project Wizard"
        Width="760"
        Height="560"
        MinWidth="540"
        MinHeight="430"
        CanResize="True"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource EditorDialogWindowBgBrush}">
  <Border Padding="18" Classes="shell-dialog-frame">
    <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
      <StackPanel>
        <TextBlock Text="New Project Wizard" Foreground="{DynamicResource EditorDialogTitleBrush}" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="Template → Name → Concept → Create" Foreground="{DynamicResource EditorDialogMutedBrush}" Margin="0,4,0,0" />
      </StackPanel>

      <Border Grid.Row="1" Classes="shell-dialog-inset" Padding="10,8">
        <TextBlock Name="StepLabel" Foreground="{DynamicResource EditorDialogTitleBrush}" FontSize="13" />
      </Border>

      <ScrollViewer Grid.Row="2" Classes="shell-dialog-tab-scroll">
      <Grid>
        <StackPanel Name="TemplateStepPanel" Spacing="10">
          <TextBlock Text="Pick a starter template" Foreground="{DynamicResource EditorDialogTitleBrush}" FontSize="17" FontWeight="SemiBold" />
          <TextBlock Text="Templates preload scene scaffold + brief defaults so beginners can prototype immediately." Foreground="{DynamicResource EditorDialogMutedBrush}" TextWrapping="Wrap" />
          <ListBox Name="TemplateListBox" Classes="shell-dialog-list">
            <ListBox.ItemTemplate>
              <DataTemplate>
                <Border Classes="shell-dialog-inset" Margin="0,0,0,8" Padding="10">
                  <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                    <TextBlock Text="{Binding Icon}" FontSize="20" VerticalAlignment="Top" />
                    <StackPanel Grid.Column="1" Spacing="2">
                      <TextBlock Text="{Binding DisplayName}" Foreground="{DynamicResource EditorDialogTitleBrush}" FontSize="15" FontWeight="SemiBold" />
                      <TextBlock Text="{Binding BriefSummary}" Foreground="{DynamicResource EditorDialogAccentMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </StackPanel>

        <StackPanel Name="NamingStepPanel" IsVisible="False" Spacing="10">
          <TextBlock Text="Name your project" Foreground="{DynamicResource EditorDialogTitleBrush}" FontSize="17" FontWeight="SemiBold" />
          <TextBox Name="ProjectNameTextBox" Watermark="My Cozy Prototype" FontSize="15" />
          <TextBlock Text="Used for project folder naming + initial brief title." Foreground="{DynamicResource EditorDialogMutedBrush}" FontSize="12" />
        </StackPanel>

        <StackPanel Name="ConceptStepPanel" IsVisible="False" Spacing="10">
          <TextBlock Text="Quick concept (optional)" Foreground="{DynamicResource EditorDialogTitleBrush}" FontSize="17" FontWeight="SemiBold" />
          <TextBox Name="ConceptTextBox" Height="180" AcceptsReturn="True" TextWrapping="Wrap"
                   Watermark="Add a one-line twist, theme, or prototype objective..." />
          <TextBlock Text="Skip this if you want the template defaults only." Foreground="{DynamicResource EditorDialogMutedBrush}" FontSize="12" />
        </StackPanel>
      </Grid>
      </ScrollViewer>

      <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
        <TextBlock Name="ValidationMessageText"
                   Foreground="#FF9CB4"
                   VerticalAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,0,8,0" />
        <Button Name="BackButton" Grid.Column="1" Content="Back" Classes="shell-dialog-secondary" Click="OnBackClick" />
        <Button Name="NextButton" Grid.Column="2" Content="Next" Classes="shell-dialog-secondary" Click="OnNextClick" />
        <Button Name="CreateButton" Grid.Column="3" Content="Create Project" Classes="shell-dialog-primary" Click="OnCreateClick" IsVisible="False" />
      </Grid>
    </Grid>
  </Border>
</Window>
