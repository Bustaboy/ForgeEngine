<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <!-- Shared with MainWindow + secondary dialogs (single source of truth) -->
  <Thickness x:Key="SpacingSmall">4</Thickness>
  <Thickness x:Key="SpacingMedium">8</Thickness>
  <Thickness x:Key="SpacingLarge">10</Thickness>

  <SolidColorBrush x:Key="AccentBrush" Color="#478CBF" />
  <SolidColorBrush x:Key="PanelShellBrush" Color="#252525" />
  <SolidColorBrush x:Key="PanelShellBorderBrush" Color="#3D3D3D" />
  <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#2A2A2A" />
  <SolidColorBrush x:Key="PanelSurfaceBorderBrush" Color="#454545" />
  <SolidColorBrush x:Key="PanelHoverBrush" Color="#333333" />
  <SolidColorBrush x:Key="BadgeBrush" Color="#353535" />
  <SolidColorBrush x:Key="BadgeBorderBrush" Color="#5A5A5A" />
  <SolidColorBrush x:Key="ChromeMenuBrush" Color="#2D2D2D" />
  <SolidColorBrush x:Key="ChromeToolbarBrush" Color="#323232" />
  <SolidColorBrush x:Key="SplitterBrush" Color="#3A3A3A" />

  <SolidColorBrush x:Key="EditorDialogWindowBgBrush" Color="#1E1E1E" />
  <SolidColorBrush x:Key="EditorDialogTitleBrush" Color="#E8E8E8" />
  <SolidColorBrush x:Key="EditorDialogMutedBrush" Color="#A8A8A8" />
  <SolidColorBrush x:Key="EditorDialogAccentMutedBrush" Color="#9FC2E5" />

  <SolidColorBrush x:Key="ToastSuccessBackgroundBrush" Color="#14301E" />
  <SolidColorBrush x:Key="ToastSuccessBorderBrush" Color="#4C9A73" />
  <SolidColorBrush x:Key="ToastWarningBackgroundBrush" Color="#3C2A14" />
  <SolidColorBrush x:Key="ToastWarningBorderBrush" Color="#C79649" />
  <SolidColorBrush x:Key="ToastErrorBackgroundBrush" Color="#3A171B" />
  <SolidColorBrush x:Key="ToastErrorBorderBrush" Color="#B95A63" />
</ResourceDictionary>
